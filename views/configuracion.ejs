<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>GVI - Ajustes</title>
    <style>
        /* Rediseño visual: panel de ajustes */
        :root {
            --settings-blue: #3d73ff;
            --settings-blue-soft: rgba(61, 115, 255, 0.14);
            --settings-green: #2aa65a;
            --settings-amber: #ffc15a;
        }

        html,
        body {
            min-height: 100dvh;
        }

        html {
            background-color: #eef2f7;
        }

        html.dark-mode {
            background-color: #11151c;
        }

        body.settings-page {
            --settings-ink: #111827;
            --settings-muted: rgba(17, 24, 39, 0.62);
            --settings-soft: rgba(17, 24, 39, 0.76);
            --settings-line: rgba(36, 47, 70, 0.13);
            --settings-card: rgba(255, 255, 255, 0.82);
            --settings-card-strong: rgba(255, 255, 255, 0.96);
            --settings-card-hover: #ffffff;
            --settings-sidebar-surface: rgba(226, 233, 245, 0.66);
            --settings-shadow: 0 22px 62px rgba(42, 53, 77, 0.14);
            background-color: #e9eef7 !important;
            background-image:
                radial-gradient(circle at 9% 10%, rgba(61, 115, 255, 0.14), transparent 25%),
                radial-gradient(circle at 92% 0%, rgba(132, 154, 190, 0.12), transparent 25%),
                linear-gradient(180deg, #f6f8fc 0%, #e9eef7 100%) !important;
            color: var(--settings-ink);
            color-scheme: light;
        }

        body.settings-page.dark-mode {
            --settings-ink: #f6f7fb;
            --settings-muted: rgba(246, 247, 251, 0.58);
            --settings-soft: rgba(246, 247, 251, 0.74);
            --settings-line: rgba(255, 255, 255, 0.08);
            --settings-card: rgba(20, 22, 28, 0.72);
            --settings-card-strong: rgba(32, 34, 42, 0.92);
            --settings-card-hover: rgba(38, 41, 50, 0.96);
            --settings-sidebar-surface: rgba(18, 20, 27, 0.36);
            --settings-green: #6fe28f;
            --settings-shadow: 0 28px 80px rgba(0, 0, 0, 0.28);
            background-color: #12151c !important;
            background-image: none !important;
            color: var(--settings-ink);
            color-scheme: dark;
        }

        body.settings-page::before {
            display: none;
        }

        body.settings-page > *:not(.notifications-popover):not(.profile-popover):not(.update-installed-toast) {
            position: relative;
            z-index: 1;
        }

        .config-container {
            width: min(100% - 42px, 1220px);
            margin: 30px auto 64px;
            display: grid;
            grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
            gap: 22px;
        }

        .config-header {
            grid-column: 1 / -1;
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(280px, 390px);
            align-items: stretch;
            gap: clamp(18px, 3vw, 34px);
            position: relative;
            overflow: hidden;
            padding: clamp(26px, 4vw, 44px);
            border-radius: 30px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0.58)),
                radial-gradient(circle at 94% 15%, rgba(61, 115, 255, 0.14), transparent 32%);
            border: 1px solid rgba(255, 255, 255, 0.8);
            box-shadow: var(--settings-shadow);
            backdrop-filter: blur(18px);
        }

        body.dark-mode .config-header {
            background:
                linear-gradient(135deg, rgba(31, 34, 41, 0.9), rgba(23, 24, 30, 0.66)),
                radial-gradient(circle at 94% 15%, rgba(61, 115, 255, 0.18), transparent 34%);
            border-color: rgba(255, 255, 255, 0.1);
        }

        .config-header::after {
            content: "";
            position: absolute;
            width: 220px;
            height: 220px;
            right: -80px;
            bottom: -120px;
            border-radius: 999px;
            background: rgba(61, 115, 255, 0.12);
            filter: blur(8px);
        }

        .config-hero-copy {
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 176px;
        }

        .config-eyebrow {
            width: fit-content;
            margin: 0 0 18px;
            padding: 7px 10px;
            border-radius: 999px;
            background: rgba(61, 115, 255, 0.12);
            color: #9bb8ff;
            font-size: 11px;
            font-weight: 900;
            letter-spacing: 0.13em;
            text-transform: uppercase;
        }

        body.dark-mode .config-eyebrow {
            color: #8fb5ff;
            background: rgba(61, 115, 255, 0.16);
        }

        .config-header h1 {
            margin: 0;
            font-size: clamp(42px, 6vw, 78px);
            line-height: 0.92;
            letter-spacing: -0.055em;
            text-wrap: balance;
        }

        .config-header p {
            max-width: 58ch;
            margin: 16px 0 0;
            color: var(--settings-muted);
            font-size: clamp(15px, 1.6vw, 18px);
            font-weight: 700;
            line-height: 1.45;
            text-wrap: pretty;
        }

        .config-hero-side {
            position: relative;
            z-index: 1;
            display: grid;
            gap: 12px;
            align-content: center;
        }

        .version-pill {
            justify-self: end;
            min-width: 122px;
            padding: 13px 20px;
            border-radius: 18px;
            background: #111318;
            color: #fff;
            text-align: center;
            font-size: 20px;
            font-weight: 900;
            box-shadow: 0 18px 34px rgba(17, 19, 24, 0.18);
        }

        body.dark-mode .version-pill {
            background: #f5f2ee;
            color: #111318;
            box-shadow: 0 18px 34px rgba(0, 0, 0, 0.3);
        }

        .config-quick-status {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
        }

        .quick-status-card {
            min-height: 88px;
            padding: 14px;
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.66);
            border: 1px solid var(--settings-line);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.65);
        }

        body.dark-mode .quick-status-card {
            background: rgba(255, 255, 255, 0.055);
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.07);
        }

        .quick-status-card span {
            display: block;
            color: var(--settings-muted);
            font-size: 11px;
            font-weight: 900;
            letter-spacing: 0.09em;
            text-transform: uppercase;
        }

        .quick-status-card strong {
            display: block;
            margin-top: 9px;
            font-size: 17px;
            font-weight: 900;
        }

        .config-section {
            min-width: 0;
            margin: 0;
            padding: 18px;
            border-radius: 28px;
            background: var(--settings-card);
            border: 1px solid var(--settings-line);
            box-shadow: var(--settings-shadow);
            backdrop-filter: blur(14px);
            animation: settingsPanelIn 0.44s cubic-bezier(0.2, 0.8, 0.2, 1) both;
        }

        body.dark-mode .config-section {
            border-color: rgba(255, 255, 255, 0.08);
            box-shadow: 0 18px 48px rgba(0, 0, 0, 0.22);
        }

        .config-section:nth-of-type(1) { animation-delay: 0.04s; }
        .config-section:nth-of-type(2) { animation-delay: 0.08s; }
        .config-section:nth-of-type(3) {
            grid-row: span 2;
            animation-delay: 0.12s;
        }
        .config-section:nth-of-type(4) { animation-delay: 0.16s; }

        @keyframes settingsPanelIn {
            from {
                opacity: 0;
                transform: translateY(12px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .config-section h2 {
            display: flex;
            align-items: center;
            gap: 9px;
            margin: 0 0 15px;
            color: var(--settings-ink);
            font-size: 12px;
            font-weight: 900;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        .config-section h2::before {
            content: "";
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: var(--settings-blue);
            box-shadow: 0 0 0 5px var(--settings-blue-soft);
        }

        .config-list {
            display: grid;
            gap: 12px;
            background: transparent;
            border: none;
            border-radius: 0;
            overflow: visible;
            box-shadow: none;
        }

        .config-item {
            position: relative;
            display: flex;
            align-items: center;
            gap: 16px;
            min-height: 86px;
            padding: 17px;
            overflow: hidden;
            color: inherit;
            text-decoration: none;
            border: 1px solid var(--settings-line);
            border-radius: 20px;
            background: var(--settings-card-strong);
            box-shadow: 0 12px 30px rgba(42, 53, 77, 0.1);
            transition: transform 0.2s ease, border-color 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
        }

        body.dark-mode .config-item {
            background: var(--settings-card-strong);
            border-color: var(--settings-line);
            box-shadow: 0 12px 26px rgba(0, 0, 0, 0.16);
        }

        .config-item::after {
            content: "";
            position: absolute;
            inset: 0;
            opacity: 0;
            pointer-events: none;
            background: linear-gradient(110deg, rgba(61, 115, 255, 0.13), transparent 42%);
            transition: opacity 0.2s ease;
        }

        .config-item.clickable {
            cursor: pointer;
        }

        .config-item.clickable:hover {
            transform: translateY(-2px);
            border-color: rgba(61, 115, 255, 0.28);
            background: var(--settings-card-hover);
            box-shadow: 0 16px 34px rgba(0, 0, 0, 0.2);
        }

        .config-item.clickable:hover::after {
            opacity: 1;
        }

        .config-item > * {
            position: relative;
            z-index: 1;
        }

        .config-icon {
            width: 50px;
            height: 50px;
            display: grid;
            place-items: center;
            flex: 0 0 auto;
            border-radius: 17px;
            color: #fff;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22), 0 12px 22px rgba(20, 30, 45, 0.12);
        }

        .config-icon svg {
            width: 23px;
            height: 23px;
            stroke-width: 2.35px;
        }

        .icon-blue { background: linear-gradient(145deg, #3d73ff, #234fca); }
        .icon-green { background: linear-gradient(145deg, #53ca72, #248b43); }
        .icon-orange { background: linear-gradient(145deg, #d69b42, #965f18); }
        .icon-purple { background: linear-gradient(145deg, #6e67e8, #423bb8); }
        .icon-gray { background: linear-gradient(145deg, #8d949f, #5f6570); }
        .icon-dark { background: linear-gradient(145deg, #20242d, #0d1017); }

        .config-info {
            flex: 1;
            min-width: 0;
        }

        .config-info b {
            display: block;
            margin-bottom: 4px;
            font-size: 16px;
            font-weight: 900;
            letter-spacing: -0.01em;
        }

        .config-info p {
            max-width: 54ch;
            margin: 0;
            color: var(--settings-muted);
            font-size: 13px;
            font-weight: 760;
            line-height: 1.35;
        }

        .config-action,
        .ip-badge,
        .status-badge {
            flex: 0 0 auto;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 900;
            white-space: nowrap;
        }

        .config-action {
            min-height: 42px;
            padding: 11px 16px;
            border: none;
            border-radius: 14px;
            background: var(--settings-blue);
            color: #fff;
            cursor: pointer;
            box-shadow: 0 12px 22px rgba(61, 115, 255, 0.22);
            transition: transform 0.16s ease, box-shadow 0.16s ease, background-color 0.16s ease, opacity 0.16s ease;
        }

        .config-action:hover {
            transform: translateY(-1px);
            box-shadow: 0 16px 26px rgba(61, 115, 255, 0.28);
        }

        .config-action:active {
            transform: translateY(1px) scale(0.99);
        }

        .config-action.secondary {
            background: rgba(246, 247, 251, 0.1);
            color: var(--settings-ink);
            box-shadow: none;
        }

        body.dark-mode .config-action.secondary {
            background: rgba(255, 255, 255, 0.1);
        }

        .config-action.success {
            background: var(--settings-green);
            box-shadow: 0 12px 22px rgba(32, 177, 90, 0.2);
        }

        .config-action[disabled] {
            cursor: not-allowed;
            opacity: 0.55;
            transform: none;
            box-shadow: none;
        }

        .config-action:focus-visible,
        .config-input:focus-visible,
        .config-item.clickable:focus-visible {
            outline: 3px solid rgba(61, 115, 255, 0.28);
            outline-offset: 3px;
        }

        .ip-badge {
            max-width: 100%;
            padding: 9px 12px;
            overflow: hidden;
            background: rgba(61, 115, 255, 0.13);
            color: #9bb8ff;
            font-family: "SFMono-Regular", Consolas, monospace;
            text-overflow: ellipsis;
        }

        body.dark-mode .ip-badge {
            color: #9bbcff;
            background: rgba(61, 115, 255, 0.16);
        }

        .status-badge {
            padding: 8px 12px;
            background: rgba(111, 226, 143, 0.12);
            color: var(--settings-green);
        }

        body.dark-mode .status-badge {
            color: #69d890;
            background: rgba(32, 177, 90, 0.14);
        }

        .status-badge.pending {
            background: rgba(255, 193, 90, 0.13);
            color: var(--settings-amber);
        }

        .update-status {
            display: none;
            margin-top: 12px;
            padding: 14px 16px;
            border: 1px solid rgba(61, 115, 255, 0.18);
            border-radius: 17px;
            background: rgba(61, 115, 255, 0.1);
            color: #a9bdff;
            font-weight: 900;
            line-height: 1.4;
        }

        body.dark-mode .update-status {
            color: #a8c4ff;
            background: rgba(61, 115, 255, 0.13);
        }

        .update-status.visible {
            display: block;
        }

        .update-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: flex-end;
        }

        .user-form {
            display: grid;
            grid-template-columns: minmax(150px, 1fr) 150px 120px auto;
            gap: 10px;
            width: 100%;
            align-items: center;
        }

        .config-input {
            width: 100%;
            min-height: 48px;
            border: 1px solid var(--settings-line);
            background: rgba(246, 247, 251, 0.08);
            color: inherit;
            border-radius: 16px;
            padding: 12px 14px;
            font-family: inherit;
            font-size: 14px;
            font-weight: 800;
            outline: none;
            transition: border-color 0.16s ease, box-shadow 0.16s ease, background-color 0.16s ease;
        }

        body.dark-mode .config-input {
            background: rgba(255, 255, 255, 0.07);
            border-color: rgba(255, 255, 255, 0.11);
        }

        .config-input:focus {
            border-color: rgba(61, 115, 255, 0.48);
            box-shadow: 0 0 0 4px rgba(61, 115, 255, 0.12);
        }

        .users-list {
            display: grid;
            gap: 9px;
            width: 100%;
            margin-top: 12px;
        }

        .user-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 16px;
            background: rgba(61, 115, 255, 0.1);
            font-weight: 900;
        }

        body.dark-mode .user-row {
            background: rgba(61, 115, 255, 0.13);
        }

        .user-row span {
            color: var(--settings-muted);
            font-size: 11px;
            font-weight: 900;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .progress-container {
            display: none;
            width: 100%;
            height: 8px;
            margin-top: 13px;
            overflow: hidden;
            border-radius: 999px;
            background: rgba(20, 30, 45, 0.08);
        }

        body.dark-mode .progress-container {
            background: rgba(255, 255, 255, 0.12);
        }

        .progress-container.visible {
            display: block;
        }

        .progress-bar {
            width: 0%;
            height: 100%;
            border-radius: inherit;
            background: linear-gradient(90deg, var(--settings-blue) 0%, #33b1ff 100%);
            box-shadow: 0 0 14px rgba(61, 115, 255, 0.42);
            transition: width 0.3s ease;
        }

        /* Layout tipo panel de preferencias */
        body.settings-page .app-topbar {
            position: relative !important;
            top: auto !important;
        }

        .settings-shell {
            width: min(100% - 56px, 1320px);
            margin: clamp(20px, 2.4vh, 30px) auto 72px;
            display: grid;
            grid-template-columns: 280px minmax(0, 1fr);
            align-items: start;
            align-content: start;
            gap: 28px;
            position: relative;
            min-height: 0;
        }

        body.dark-mode .settings-shell {
            background: transparent;
        }

        .settings-sidebar {
            min-width: 0;
            padding: 14px;
            border: 1px solid var(--settings-line);
            border-radius: 24px;
            background: var(--settings-sidebar-surface);
            box-shadow: 0 16px 42px rgba(42, 53, 77, 0.08);
        }

        body.dark-mode .settings-sidebar {
            box-shadow: none;
        }

        .settings-account {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 4px 4px 18px;
        }

        .settings-account-avatar {
            width: 46px;
            height: 46px;
            display: grid;
            place-items: center;
            flex: 0 0 auto;
            border-radius: 16px;
            background: linear-gradient(145deg, #d7e1f1, #eff4fb);
            border: 1px solid var(--settings-line);
            color: var(--settings-ink);
            font-weight: 900;
            letter-spacing: -0.04em;
        }

        body.dark-mode .settings-account-avatar {
            background: rgba(255, 255, 255, 0.12);
            color: #fff;
        }

        .settings-account strong,
        .settings-account span {
            display: block;
        }

        .settings-account strong {
            font-size: 15px;
            font-weight: 900;
        }

        .settings-account span {
            margin-top: 2px;
            color: var(--settings-muted);
            font-size: 12px;
            font-weight: 800;
        }

        .settings-search {
            display: flex;
            align-items: center;
            gap: 8px;
            min-height: 42px;
            margin-bottom: 18px;
            padding: 0 12px;
            border: 1px solid var(--settings-line);
            border-radius: 15px;
            background: rgba(255, 255, 255, 0.56);
            color: var(--settings-muted);
        }

        body.dark-mode .settings-search {
            background: rgba(255, 255, 255, 0.08);
        }

        .settings-search svg {
            width: 17px;
            height: 17px;
            flex: 0 0 auto;
        }

        .settings-search input {
            width: 100%;
            border: none;
            outline: none;
            background: transparent;
            color: inherit;
            font: inherit;
            font-size: 14px;
            font-weight: 800;
        }

        .settings-menu {
            display: grid;
            gap: 5px;
        }

        .settings-nav-item {
            width: 100%;
            min-height: 44px;
            display: grid;
            grid-template-columns: 30px 1fr auto;
            align-items: center;
            gap: 10px;
            border: none;
            border-radius: 14px;
            padding: 7px 10px;
            background: transparent;
            color: var(--settings-ink);
            cursor: pointer;
            font: inherit;
            text-align: left;
            transition: background-color 0.16s ease, color 0.16s ease, transform 0.16s ease;
        }

        .settings-nav-item:hover {
            background: rgba(255, 255, 255, 0.55);
        }

        body.dark-mode .settings-nav-item:hover {
            background: rgba(246, 247, 251, 0.08);
        }

        .settings-nav-item.active {
            background: var(--settings-blue);
            color: #fff;
            box-shadow: 0 14px 26px rgba(61, 115, 255, 0.24);
        }

        .settings-nav-item svg {
            width: 18px;
            height: 18px;
            justify-self: center;
        }

        .settings-nav-item span {
            font-size: 14px;
            font-weight: 900;
        }

        .settings-nav-item small {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: rgba(61, 115, 255, 0.35);
        }

        .settings-nav-item.active small {
            background: rgba(255, 255, 255, 0.78);
        }

        .settings-content {
            min-width: 0;
            padding: 0;
        }

        .settings-panel {
            display: none;
        }

        .settings-panel.active {
            display: block;
            animation: settingsPanelIn 0.28s cubic-bezier(0.2, 0.8, 0.2, 1) both;
        }

        .settings-panel .config-section {
            display: block;
            margin-bottom: 16px;
            animation: none;
            padding: 22px;
        }

        .settings-panel .config-section:last-child {
            margin-bottom: 0;
        }

        .settings-panel .config-section h2 {
            margin-bottom: 14px;
            font-size: 14px;
            letter-spacing: 0.08em;
        }

        body.settings-page .config-section,
        body.settings-page .config-item,
        body.settings-page .settings-search,
        body.settings-page .config-input {
            border-color: var(--settings-line);
        }

        .theme-options {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 12px;
        }

        .theme-choice {
            display: grid;
            gap: 10px;
            padding: 14px;
            border: 1px solid var(--settings-line);
            border-radius: 20px;
            background: var(--settings-card-strong);
            color: var(--settings-ink);
            cursor: pointer;
            text-align: left;
            font: inherit;
            transition: transform 0.16s ease, border-color 0.16s ease, box-shadow 0.16s ease;
        }

        .theme-choice:hover {
            transform: translateY(-1px);
            border-color: rgba(61, 115, 255, 0.3);
        }

        .theme-choice.active {
            border-color: rgba(61, 115, 255, 0.72);
            box-shadow: 0 0 0 4px rgba(61, 115, 255, 0.12);
        }

        .theme-choice b {
            font-size: 14px;
            font-weight: 900;
        }

        .theme-choice span {
            color: var(--settings-muted);
            font-size: 12px;
            font-weight: 800;
            line-height: 1.35;
        }

        .theme-swatch {
            height: 74px;
            overflow: hidden;
            border-radius: 16px;
            border: 1px solid var(--settings-line);
            position: relative;
        }

        .theme-swatch::before,
        .theme-swatch::after {
            content: "";
            position: absolute;
            border-radius: 999px;
        }

        .theme-swatch::before {
            width: 54%;
            height: 14px;
            left: 12px;
            top: 12px;
            background: #3d73ff;
        }

        .theme-swatch::after {
            width: 62%;
            height: 28px;
            left: 12px;
            bottom: 12px;
            background: currentColor;
            opacity: 0.12;
        }

        .theme-swatch.light {
            background: linear-gradient(135deg, #f8fafc, #dfe7f3);
            color: #111827;
        }

        .theme-swatch.dark {
            background: linear-gradient(135deg, #11151c, #242833);
            color: #f8fafc;
        }

        .theme-swatch.auto {
            background: linear-gradient(90deg, #f8fafc 0 50%, #171b24 50% 100%);
            color: #3d73ff;
        }

        .appearance-layout {
            display: grid;
            grid-template-columns: minmax(0, 1fr) minmax(300px, 0.82fr);
            gap: 16px;
            align-items: stretch;
        }

        .theme-preview {
            min-height: 250px;
            border: 1px solid var(--settings-line);
            border-radius: 24px;
            padding: 18px;
            background: #edf2f9;
            color: #111827;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
        }

        .theme-preview.dark-preview {
            background: #12151c;
            color: #f6f7fb;
            box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
        }

        .preview-topbar,
        .preview-card,
        .preview-sidebar-item {
            border: 1px solid rgba(17, 24, 39, 0.1);
            background: rgba(255, 255, 255, 0.82);
        }

        .dark-preview .preview-topbar,
        .dark-preview .preview-card,
        .dark-preview .preview-sidebar-item {
            border-color: rgba(255, 255, 255, 0.08);
            background: rgba(32, 34, 42, 0.92);
        }

        .preview-topbar {
            height: 38px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 10px;
            font-size: 12px;
            font-weight: 900;
        }

        .preview-dots {
            display: flex;
            gap: 5px;
        }

        .preview-dots i {
            width: 8px;
            height: 8px;
            border-radius: 999px;
            background: #3d73ff;
        }

        .preview-body {
            display: grid;
            grid-template-columns: 96px 1fr;
            gap: 12px;
            margin-top: 14px;
        }

        .preview-sidebar {
            display: grid;
            gap: 8px;
            align-content: start;
        }

        .preview-sidebar-item {
            height: 30px;
            border-radius: 10px;
        }

        .preview-sidebar-item.active {
            background: #3d73ff;
            border-color: transparent;
        }

        .preview-card {
            min-height: 148px;
            border-radius: 18px;
            padding: 16px;
        }

        .preview-title {
            width: 54%;
            height: 14px;
            border-radius: 999px;
            background: currentColor;
        }

        .preview-line {
            width: 82%;
            height: 9px;
            margin-top: 12px;
            border-radius: 999px;
            background: currentColor;
            opacity: 0.24;
        }

        .preview-chip {
            width: 84px;
            height: 28px;
            margin-top: 28px;
            border-radius: 999px;
            background: rgba(61, 115, 255, 0.16);
        }

        @media (max-width: 980px) {
            .settings-shell {
                grid-template-columns: 1fr;
                width: min(100% - 28px, 760px);
                overflow: visible;
                gap: 18px;
            }

            .settings-sidebar {
                border-right: none;
                border-bottom: none;
            }

            .settings-menu {
                display: flex;
                gap: 8px;
                overflow-x: auto;
                padding-bottom: 2px;
            }

            .settings-nav-item {
                min-width: max-content;
            }

            .settings-content {
                max-height: none;
            }

        }

        @media (max-width: 720px) {
            .settings-shell {
                width: min(100% - 24px, 760px);
                margin-top: 18px;
            }

            .settings-sidebar,
            .settings-content {
                padding: 0;
            }

            .settings-account {
                padding-left: 0;
                padding-right: 0;
            }

            .config-item {
                align-items: stretch;
                flex-direction: column;
            }

            .config-hero-copy {
                min-height: auto;
            }

            .config-header h1 {
                font-size: clamp(42px, 17vw, 64px);
            }

            .config-quick-status {
                grid-template-columns: 1fr;
            }

            .version-pill {
                justify-self: stretch;
            }

            .update-actions,
            .user-form {
                width: 100%;
                grid-template-columns: 1fr;
            }

            .config-action,
            .ip-badge,
            .status-badge,
            .version-pill {
                width: 100%;
                text-align: center;
            }

            .theme-options,
            .appearance-layout {
                grid-template-columns: 1fr;
            }
        }

        /* Estilos del Modal Premium de Actualización */
        .update-modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(10, 14, 22, 0.55);
            backdrop-filter: blur(12px);
            display: none;
            place-items: center;
            z-index: 10000;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s ease, visibility 0.3s ease;
        }

        .update-modal-overlay.visible {
            display: grid;
            opacity: 1;
            visibility: visible;
        }

        .update-modal {
            background: var(--panel-claro, #ffffff);
            border: 1px solid rgba(20, 30, 45, 0.08);
            border-radius: 28px;
            width: min(100% - 32px, 480px);
            padding: 32px;
            text-align: center;
            box-shadow: 0 24px 64px rgba(10, 14, 22, 0.22);
            transform: scale(0.9);
            transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        body.dark-mode .update-modal {
            background: var(--panel-oscuro, #1e1e24);
            border-color: rgba(255, 255, 255, 0.09);
        }

        .update-modal-overlay.visible .update-modal {
            transform: scale(1);
        }

        .update-modal-icon {
            width: 72px;
            height: 72px;
            background: rgba(52, 199, 89, 0.12);
            color: #34c759;
            border-radius: 24px;
            display: grid;
            place-items: center;
            margin: 0 auto 20px;
            animation: pulse-green 2s infinite ease-in-out;
        }

        .update-modal-icon svg {
            width: 36px;
            height: 36px;
            stroke-width: 2.5px;
        }

        @keyframes pulse-green {
            0% { box-shadow: 0 0 0 0 rgba(52, 199, 89, 0.4); }
            70% { box-shadow: 0 0 0 16px rgba(52, 199, 89, 0); }
            100% { box-shadow: 0 0 0 0 rgba(52, 199, 89, 0); }
        }

        .update-modal h3 {
            font-size: 22px;
            margin: 0 0 8px;
            font-weight: 900;
        }

        .update-modal p {
            color: var(--texto-suave, rgba(28, 30, 33, 0.56));
            font-size: 14px;
            line-height: 1.45;
            margin: 0 0 24px;
            font-weight: 600;
        }

        .update-modal-changelog {
            background: rgba(20, 30, 45, 0.04);
            border-radius: 16px;
            padding: 16px;
            text-align: left;
            margin-bottom: 26px;
            max-height: 120px;
            overflow-y: auto;
            border: 1px solid rgba(20, 30, 45, 0.03);
        }

        body.dark-mode .update-modal-changelog {
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(255, 255, 255, 0.05);
        }

        .update-modal-changelog b {
            font-size: 13px;
            display: block;
            margin-bottom: 4px;
            color: var(--azul-gvi);
        }

        .update-modal-changelog p {
            font-size: 13px;
            margin: 0;
            color: inherit;
            opacity: 0.85;
            line-height: 1.4;
        }

        .update-modal-buttons {
            display: flex;
            gap: 12px;
            justify-content: center;
        }

        .update-modal-buttons button {
            flex: 1;
        }

        @media (prefers-reduced-motion: reduce) {
            .config-section {
                animation: none;
            }

            .config-action:hover,
            .config-item.clickable:hover {
                transform: none;
            }
        }
    </style>
</head>
<body class="settings-page">
    <%- include('partials/nav') %>

    <main class="settings-shell">
        <aside class="settings-sidebar" aria-label="Categorias de ajustes">
            <div class="settings-account">
                <div class="settings-account-avatar">GVI</div>
                <div>
                    <strong>Ajustes GVI</strong>
                    <span>Centro de configuracion</span>
                </div>
            </div>

            <label class="settings-search">
                <i data-lucide="search"></i>
                <input id="settingsSearch" type="search" placeholder="Buscar ajuste">
            </label>

            <nav class="settings-menu" id="settingsMenu">
                <button class="settings-nav-item active" type="button" data-settings-tab="general" data-title="General" data-description="Resumen del sistema, version instalada y acciones rapidas de mantenimiento." data-icon="settings">
                    <i data-lucide="settings"></i><span>General</span><small></small>
                </button>
                <button class="settings-nav-item" type="button" data-settings-tab="actualizacion" data-title="Actualizacion" data-description="Busca versiones nuevas, revisa el canal estable y controla la instalacion de GVI." data-icon="download-cloud">
                    <i data-lucide="download-cloud"></i><span>Actualizacion</span><small></small>
                </button>
                <button class="settings-nav-item" type="button" data-settings-tab="red" data-title="Red local" data-description="Datos para conectar cajas, celulares o equipos secundarios dentro de la misma red." data-icon="monitor">
                    <i data-lucide="monitor"></i><span>Red local</span><small></small>
                </button>
                <button class="settings-nav-item" type="button" data-settings-tab="aspecto" data-title="Aspecto" data-description="Elige tema automatico, claro u oscuro para GVI." data-icon="palette">
                    <i data-lucide="palette"></i><span>Aspecto</span><small></small>
                </button>
                <button class="settings-nav-item" type="button" data-settings-tab="usuarios" data-title="Usuarios" data-description="Administra perfiles de caja y administrador con PIN de acceso." data-icon="users">
                    <i data-lucide="users"></i><span>Usuarios</span><small></small>
                </button>
                <button class="settings-nav-item" type="button" data-settings-tab="datos" data-title="Datos y respaldo" data-description="Respalda la informacion del negocio y revisa el almacenamiento local." data-icon="database">
                    <i data-lucide="database"></i><span>Datos y respaldo</span><small></small>
                </button>
            </nav>
        </aside>

        <section class="settings-content">
            <div hidden>
                <span id="lblVersionTop">v...</span>
                <span id="heroUpdateState">Preparado</span>
                <span id="heroNetworkState">Conectando</span>
            </div>

            <div class="settings-panel active" data-settings-panel="general">
                <section class="config-section">
                    <h2>Sistema</h2>
                    <div class="config-list">
                        <div class="config-item">
                            <div class="config-icon icon-gray"><i data-lucide="info"></i></div>
                            <div class="config-info">
                                <b>Version del software</b>
                                <p id="appFullName">GVI - Gestor de Ventas Intuitivo</p>
                            </div>
                            <span class="status-badge" id="lblVersion">v...</span>
                        </div>
                        <div class="config-item clickable" onclick="window.location.reload()">
                            <div class="config-icon icon-dark"><i data-lucide="refresh-cw"></i></div>
                            <div class="config-info">
                                <b>Reiniciar vista</b>
                                <p>Refresca la pantalla actual sin cerrar el programa.</p>
                            </div>
                            <button class="config-action secondary" type="button">Reiniciar</button>
                        </div>
                    </div>
                </section>
            </div>

            <div class="settings-panel" data-settings-panel="actualizacion">
                <section class="config-section">
                    <h2>Actualizacion</h2>
                    <div class="config-list">
                        <div class="config-item">
                            <div class="config-icon icon-blue"><i data-lucide="download-cloud"></i></div>
                            <div class="config-info">
                                <b>Buscar actualizaciones</b>
                                <p id="updateDescription">GVI busca nuevas versiones desde GitHub Releases y avisa en notificaciones.</p>
                                <div class="progress-container" id="downloadProgressContainer">
                                    <div class="progress-bar" id="downloadProgressBar"></div>
                                </div>
                            </div>
                            <div class="update-actions">
                                <button class="config-action" id="btnCheckUpdate" type="button" onclick="buscarActualizacion()">Buscar</button>
                                <button class="config-action secondary" id="btnDownloadUpdate" type="button" onclick="descargarActualizacion()" hidden>Descargar</button>
                                <button class="config-action success" id="btnInstallUpdate" type="button" onclick="instalarActualizacion()" hidden>Actualizar ahora</button>
                            </div>
                        </div>
                        <div class="config-item">
                            <div class="config-icon icon-purple"><i data-lucide="git-branch"></i></div>
                            <div class="config-info">
                                <b>Canal estable</b>
                                <p id="updateProvider">Proveedor pendiente.</p>
                            </div>
                            <span class="status-badge pending" id="updateMode">Preparado</span>
                        </div>
                    </div>
                    <div class="update-status" id="updateStatus"></div>
                </section>
            </div>

            <div class="settings-panel" data-settings-panel="red">
                <section class="config-section">
                    <h2>Conectividad</h2>
                    <div class="config-list">
                        <div class="config-item">
                            <div class="config-icon icon-blue"><i data-lucide="monitor"></i></div>
                            <div class="config-info">
                                <b>Servidor local</b>
                                <p>Direccion para conectar otros dispositivos en la misma red.</p>
                            </div>
                            <div class="ip-badge" id="lblIpRed">...</div>
                        </div>
                        <div class="config-item">
                            <div class="config-icon icon-green"><i data-lucide="wifi"></i></div>
                            <div class="config-info">
                                <b>Estado de red</b>
                                <p>Usa la misma red Wi-Fi para celulares o equipos secundarios.</p>
                            </div>
                            <span class="status-badge">Activo</span>
                        </div>
                    </div>
                </section>
            </div>

            <div class="settings-panel" data-settings-panel="aspecto">
                <section class="config-section">
                    <h2>Aspecto</h2>
                    <div class="appearance-layout">
                        <div class="config-list">
                            <div class="config-item">
                                <div class="config-icon icon-blue"><i data-lucide="palette"></i></div>
                                <div class="config-info">
                                    <b>Tema de la aplicacion</b>
                                    <p>Automatico sigue el tema del PC. Tambien puedes dejar GVI siempre claro u oscuro.</p>
                                </div>
                                <span class="status-badge" id="themeCurrentLabel">Automatico</span>
                            </div>
                            <div class="theme-options" role="radiogroup" aria-label="Tema de GVI">
                                <button class="theme-choice" type="button" data-theme-choice="sistema" role="radio" aria-checked="false">
                                    <span class="theme-swatch auto"></span>
                                    <b>Automatico</b>
                                    <span>Usa el modo claro u oscuro del PC.</span>
                                </button>
                                <button class="theme-choice" type="button" data-theme-choice="claro" role="radio" aria-checked="false">
                                    <span class="theme-swatch light"></span>
                                    <b>Claro</b>
                                    <span>Interfaz limpia para lugares con mucha luz.</span>
                                </button>
                                <button class="theme-choice" type="button" data-theme-choice="oscuro" role="radio" aria-checked="false">
                                    <span class="theme-swatch dark"></span>
                                    <b>Oscuro</b>
                                    <span>Reduce brillo y mantiene contraste alto.</span>
                                </button>
                            </div>
                        </div>

                        <div class="theme-preview" id="themePreview" aria-label="Vista previa del tema">
                            <div class="preview-topbar">
                                <span>GVI</span>
                                <div class="preview-dots"><i></i><i></i><i></i></div>
                            </div>
                            <div class="preview-body">
                                <div class="preview-sidebar">
                                    <span class="preview-sidebar-item active"></span>
                                    <span class="preview-sidebar-item"></span>
                                    <span class="preview-sidebar-item"></span>
                                </div>
                                <div class="preview-card">
                                    <div class="preview-title"></div>
                                    <div class="preview-line"></div>
                                    <div class="preview-line"></div>
                                    <div class="preview-chip"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="settings-panel" data-settings-panel="usuarios">
                <section class="config-section">
                    <h2>Usuarios</h2>
                    <div class="config-list">
                        <div class="config-item">
                            <div class="config-icon icon-purple"><i data-lucide="users"></i></div>
                            <div class="config-info">
                                <b>Crear usuario</b>
                                <p>Agrega perfiles con rol y PIN para iniciar sesion.</p>
                            </div>
                        </div>
                        <div class="config-item">
                            <div class="user-form">
                                <input class="config-input" id="nuevoUsuarioNombre" placeholder="Nombre">
                                <select class="config-input" id="nuevoUsuarioRol">
                                    <option value="CAJA">Caja</option>
                                    <option value="ADMIN">Administrador</option>
                                </select>
                                <input class="config-input" id="nuevoUsuarioPin" maxlength="6" inputmode="numeric" placeholder="PIN">
                                <button class="config-action" type="button" onclick="crearUsuario()">Crear</button>
                            </div>
                        </div>
                        <div class="config-item">
                            <div class="config-info">
                                <b>Usuarios creados</b>
                                <div class="users-list" id="usuariosList"></div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="settings-panel" data-settings-panel="datos">
                <section class="config-section">
                    <h2>Datos y respaldo</h2>
                    <div class="config-list">
                        <a href="/api/backup" class="config-item clickable">
                            <div class="config-icon icon-green"><i data-lucide="archive"></i></div>
                            <div class="config-info">
                                <b>Copia de seguridad</b>
                                <p>Descargar inventario, ventas y datos del negocio en un archivo ZIP.</p>
                            </div>
                            <span class="config-action">Descargar</span>
                        </a>
                        <div class="config-item">
                            <div class="config-icon icon-orange"><i data-lucide="database"></i></div>
                            <div class="config-info">
                                <b>Base de datos local</b>
                                <p>Los datos se guardan en este equipo para uso como programa de escritorio.</p>
                            </div>
                            <span class="status-badge">Estable</span>
                        </div>
                    </div>
                </section>
            </div>
        </section>
    </main>

    <!-- Modal de actualizaciones -->
    <div class="update-modal-overlay" id="updateModalOverlay">
        <div class="update-modal">
            <div class="update-modal-icon">
                <i data-lucide="sparkles"></i>
            </div>
            <h3 id="lblModalTitle">Actualizacion lista</h3>
            <p>La nueva version ya se descargo. Al actualizar, GVI se cerrara, instalara todo en silencio y volvera a abrirse.</p>
            <div class="update-modal-changelog">
                <b>Novedades de la v<span id="lblModalVersion">2.1.0</span>:</b>
                <p id="lblModalChangelog">Cargando notas de la version...</p>
            </div>
            <div class="update-modal-buttons">
                <button class="config-action secondary" type="button" onclick="cerrarModalActualizacion()">Mas tarde</button>
                <button class="config-action success" type="button" onclick="instalarActualizacion()">Actualizar ahora</button>
            </div>
        </div>
    </div>

    <%- include('partials/scripts') %>
    <script>
        let modalMostrado = false;

        async function cargarInfoRed() {
            try {
                const res = await fetch('/api/info-red');
                const data = await res.json();
                document.getElementById('lblIpRed').innerText = `http://${data.ip}:3000`;
                document.getElementById('heroNetworkState').innerText = 'Activa';
            } catch (e) {
                document.getElementById('lblIpRed').innerText = 'Sin red';
                document.getElementById('heroNetworkState').innerText = 'Sin red';
            }
        }

        function cerrarModalActualizacion() {
            document.getElementById('updateModalOverlay').classList.remove('visible');
        }

        function activarPanelAjustes(button) {
            const tab = button?.dataset.settingsTab;
            if (!tab) return;

            document.querySelectorAll('.settings-nav-item').forEach(item => item.classList.toggle('active', item === button));
            document.querySelectorAll('.settings-panel').forEach(panel => {
                panel.classList.toggle('active', panel.dataset.settingsPanel === tab);
            });
        }

        function obtenerPreferenciaTema() {
            if (typeof gviThemePreference === 'function') return gviThemePreference();
            const stored = localStorage.getItem('temaGVI_preferencia');
            return stored === 'claro' || stored === 'oscuro' ? stored : 'sistema';
        }

        function etiquetaTema(preference) {
            if (preference === 'claro') return 'Claro';
            if (preference === 'oscuro') return 'Oscuro';
            return 'Automatico';
        }

        function sincronizarPanelTema() {
            const preference = obtenerPreferenciaTema();
            const isDark = typeof gviThemeIsDark === 'function' ? gviThemeIsDark() : document.body.classList.contains('dark-mode');
            document.querySelectorAll('.theme-choice').forEach(button => {
                const active = button.dataset.themeChoice === preference;
                button.classList.toggle('active', active);
                button.setAttribute('aria-checked', active ? 'true' : 'false');
            });

            const label = document.getElementById('themeCurrentLabel');
            if (label) label.innerText = etiquetaTema(preference);

            const preview = document.getElementById('themePreview');
            if (preview) preview.classList.toggle('dark-preview', isDark);
        }

        function configurarTemaAjustes() {
            document.querySelectorAll('.theme-choice').forEach(button => {
                button.addEventListener('click', () => {
                    const preference = button.dataset.themeChoice || 'sistema';
                    if (typeof gviSetThemePreference === 'function') {
                        gviSetThemePreference(preference);
                    } else {
                        localStorage.setItem('temaGVI_preferencia', preference);
                        document.body.classList.toggle('dark-mode', preference === 'oscuro');
                    }
                    if (typeof actualizarTemaNav === 'function') actualizarTemaNav();
                    sincronizarPanelTema();
                });
            });

            window.matchMedia?.('(prefers-color-scheme: dark)').addEventListener?.('change', sincronizarPanelTema);
            sincronizarPanelTema();
        }

        function configurarNavegacionAjustes() {
            document.querySelectorAll('.settings-nav-item').forEach(button => {
                button.addEventListener('click', () => activarPanelAjustes(button));
            });

            const search = document.getElementById('settingsSearch');
            search?.addEventListener('input', () => {
                const query = search.value.trim().toLowerCase();
                let firstVisible = null;
                document.querySelectorAll('.settings-nav-item').forEach(button => {
                    const hayCoincidencia = !query || button.innerText.toLowerCase().includes(query) || (button.dataset.description || '').toLowerCase().includes(query);
                    button.hidden = !hayCoincidencia;
                    if (hayCoincidencia && !firstVisible) firstVisible = button;
                });
                if (firstVisible && document.querySelector('.settings-nav-item.active')?.hidden) {
                    activarPanelAjustes(firstVisible);
                }
            });

            const user = JSON.parse(localStorage.getItem('gvi_user') || 'null');
            if (user?.nombre) {
                const accountName = document.querySelector('.settings-account strong');
                const accountMeta = document.querySelector('.settings-account span');
                if (accountName) accountName.innerText = user.nombre;
                if (accountMeta) accountMeta.innerText = user.rol || 'Perfil activo';
            }
        }

        function aplicarEstadoActualizacion(data) {
            const status = document.getElementById('updateStatus');
            const mode = document.getElementById('updateMode');
            const btnCheck = document.getElementById('btnCheckUpdate');
            const btnDownload = document.getElementById('btnDownloadUpdate');
            const btnInstall = document.getElementById('btnInstallUpdate');

            const progressContainer = document.getElementById('downloadProgressContainer');
            const progressBar = document.getElementById('downloadProgressBar');

            mode.innerText = data.configured ? (data.ready ? 'Lista' : data.available ? 'Disponible' : 'Activo') : 'Pendiente';
            document.getElementById('heroUpdateState').innerText = mode.innerText;
            mode.classList.toggle('pending', !data.configured || data.checking || data.downloading);

            btnCheck.disabled = !!data.checking || !!data.downloading;
            btnDownload.hidden = true;
            btnDownload.disabled = true;
            btnInstall.hidden = !data.ready;
            btnInstall.disabled = !!data.installing;

            // Manejo de la barra de progreso
            if (data.downloading) {
                progressContainer.classList.add('visible');
                progressBar.style.width = `${data.percent || 0}%`;
            } else if (data.ready) {
                progressContainer.classList.add('visible');
                progressBar.style.width = '100%';
            } else {
                progressContainer.classList.remove('visible');
                progressBar.style.width = '0%';
            }

            if (data.message) {
                status.classList.add('visible');
                status.innerText = data.message;
            }
        }

        async function cargarInfoApp() {
            try {
                const res = await fetch('/api/app/info');
                const data = await res.json();
                document.getElementById('lblVersionTop').innerText = `v${data.version}`;
                document.getElementById('lblVersion').innerText = `v${data.version}`;
                document.getElementById('appFullName').innerText = `${data.name} - ${data.fullName}`;
                document.getElementById('updateProvider').innerText = `${data.updateProvider} - canal ${data.updateChannel}`;
                aplicarEstadoActualizacion(data.updater || {});
            } catch (e) {
                document.getElementById('lblVersionTop').innerText = 'v?';
                document.getElementById('lblVersion').innerText = 'v?';
            }
        }

        async function cargarUsuarios() {
            const list = document.getElementById('usuariosList');
            try {
                const res = await fetch('/api/usuarios');
                const usuarios = await res.json();
                list.innerHTML = usuarios.map(u => `
                    <div class="user-row">
                        <b>${u.nombre}</b>
                        <span>${u.temporal ? 'Temporal - ' : ''}${u.rol}</span>
                    </div>
                `).join('') || '<div class="user-row"><b>Sin usuarios</b><span>Pendiente</span></div>';
            } catch (_) {
                list.innerHTML = '<div class="user-row"><b>Error al cargar</b><span>Usuarios</span></div>';
            }
        }

        async function crearUsuario() {
            const nombre = document.getElementById('nuevoUsuarioNombre').value.trim();
            const rol = document.getElementById('nuevoUsuarioRol').value;
            const pin = document.getElementById('nuevoUsuarioPin').value.trim();

            try {
                const res = await fetch('/api/usuarios', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ nombre, rol, pin })
                });
                const data = await res.json();
                if (!data.success) {
                    alert(data.message || 'No se pudo crear el usuario.');
                    return;
                }
                document.getElementById('nuevoUsuarioNombre').value = '';
                document.getElementById('nuevoUsuarioPin').value = '';
                cargarUsuarios();
            } catch (_) {
                alert('No se pudo crear el usuario.');
            }
        }

        async function consultarEstadoActualizacion() {
            try {
                const res = await fetch('/api/app/update/status');
                const data = await res.json();
                aplicarEstadoActualizacion(data);
            } catch (_) {}
        }

        async function buscarActualizacion() {
            const status = document.getElementById('updateStatus');
            status.classList.add('visible');
            status.innerText = 'Buscando configuracion de actualizaciones...';

            try {
                const res = await fetch('/api/app/update/check', { method: 'POST' });
                const data = await res.json();
                aplicarEstadoActualizacion(data);
            } catch (e) {
                const mode = document.getElementById('updateMode');
                mode.innerText = 'Error';
                mode.classList.add('pending');
                status.innerText = 'No se pudo consultar el estado de actualizacion.';
            }
        }

        async function descargarActualizacion() {
            const status = document.getElementById('updateStatus');
            status.classList.add('visible');
            status.innerText = 'Iniciando descarga...';

            try {
                const res = await fetch('/api/app/update/download', { method: 'POST' });
                const data = await res.json();
                aplicarEstadoActualizacion(data);
            } catch (e) {
                status.innerText = 'No se pudo iniciar la descarga.';
            }
        }

        async function instalarActualizacion() {
            const status = document.getElementById('updateStatus');
            status.classList.add('visible');
            status.innerText = 'Instalando actualizacion. GVI se reiniciara automaticamente...';
            document.getElementById('btnInstallUpdate').disabled = true;
            try {
                await fetch('/api/app/update/install', { method: 'POST' });
            } catch (e) {
                document.getElementById('btnInstallUpdate').disabled = false;
                status.innerText = 'No se pudo iniciar la instalacion.';
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            configurarNavegacionAjustes();
            configurarTemaAjustes();
            cargarInfoRed();
            cargarInfoApp();
            cargarUsuarios();
            setInterval(consultarEstadoActualizacion, 2500);
            lucide.createIcons();
        });
    </script>
</body>
</html>
