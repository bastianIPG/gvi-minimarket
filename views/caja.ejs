<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>GVI - Punto de Venta</title>
    <style>
        .caja-header { display: flex; justify-content: space-between; align-items: center; margin-top: 40px; margin-bottom: 20px; }
        .caja-header h1 { font-size: 32px; margin: 0; display: flex; align-items: center; gap: 10px; }
        
        .caja-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; align-items: start; }

        .panel-ticket { background: var(--panel-claro); border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); overflow: hidden; display: flex; flex-direction: column; min-height: 65vh; }
        body.dark-mode .panel-ticket { background: var(--panel-oscuro); }
        
        .buscador-caja { padding: 20px; background: rgba(0,0,0,0.02); border-bottom: 1px solid #eee; display: flex; gap: 15px; position: relative; }
        body.dark-mode .buscador-caja { background: rgba(255,255,255,0.02); border-bottom-color: #333; }
        .input-barras { flex: 1; padding: 15px; font-size: 18px; border-radius: 10px; border: 2px solid var(--azul-gvi); outline: none; background: transparent; color: inherit; font-family: monospace; }
        
        /* --- ESTILOS SUGERENCIAS --- */
        .sugerencias-busqueda {
            position: absolute;
            top: 100%; left: 20px; right: 20px;
            background: var(--panel-claro);
            border: 1px solid #ddd;
            border-radius: 0 0 10px 10px;
            z-index: 1000;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            max-height: 280px;
            overflow-y: auto;
            display: none;
        }
        body.dark-mode .sugerencias-busqueda { background: #252525; border-color: #444; }
        .sugerencia-item {
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            cursor: pointer;
            border-bottom: 1px solid #eee;
        }
        body.dark-mode .sugerencia-item { border-bottom-color: #333; }
        .sugerencia-item:hover { background: rgba(0,122,255,0.1); }
        .sugerencia-item b { color: var(--azul-gvi); }

        table { width: 100%; border-collapse: collapse; text-align: left; }
        th, td { padding: 15px 20px; border-bottom: 1px solid #eee; }
        body.dark-mode th, body.dark-mode td { border-bottom-color: #333; }
        th { background: rgba(0,0,0,0.02); font-weight: 600; color: #666; text-transform: uppercase; font-size: 12px; }
        
        .control-cant { display: flex; align-items: center; gap: 10px; }
        .btn-cant { background: #eee; border: none; width: 32px; height: 32px; border-radius: 8px; cursor: pointer; font-weight: bold; transition: background-color 0.14s ease, color 0.14s ease; }
        body.dark-mode .btn-cant { background: #444; color: white; }

        .panel-cobro { background: var(--panel-claro); border-radius: 15px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); position: sticky; top: 20px; }
        body.dark-mode .panel-cobro { background: var(--panel-oscuro); }
        
        .caja-total { font-size: 55px; font-weight: 900; color: var(--azul-gvi); margin: 10px 0 20px; text-align: center; }
        
        .btn-cobrar { width: 100%; background: #34c759; color: white; border: none; padding: 20px; font-size: 22px; font-weight: bold; border-radius: 12px; cursor: pointer; transition: background-color 0.16s ease, opacity 0.16s ease; }
        .btn-cobrar:disabled { background: #ccc; opacity: 0.5; cursor: not-allowed; }

        .metodos-pago-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin: 25px 0; }
        .btn-metodo { padding: 15px 10px; border-radius: 12px; border: 2px solid #eee; background: transparent; cursor: pointer; font-weight: 800; font-size: 14px; color: inherit; transition: border-color 0.14s ease, background-color 0.14s ease, color 0.14s ease; }
        body.dark-mode .btn-metodo { border-color: #333; }
        .btn-metodo.activo { border-color: var(--azul-gvi); background: rgba(0, 122, 255, 0.1); color: var(--azul-gvi); }
        .btn-metodo.fiado-color { border-color: #ff9500; color: #ff9500; }
        .btn-metodo.fiado-color.activo { background: rgba(255, 149, 0, 0.1); }

        .badge-peso { display: inline-block; background: rgba(255,149,0,0.15); color: #ff9500; font-size: 11px; font-weight: 800; padding: 2px 8px; border-radius: 20px; margin-left: 6px; vertical-align: middle; }

        .badge-precio-carrito {
            display: inline-flex;
            align-items: center;
            margin-left: 6px;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 900;
            vertical-align: middle;
        }

        .badge-precio-oferta { background: rgba(255,59,48,0.1); color: #ff3b30; }
        .badge-precio-mayor { background: rgba(0,122,255,0.1); color: var(--azul-gvi); }

        .precio-editable {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 800;
        }

        .btn-editar-precio {
            width: 28px;
            height: 28px;
            border: none;
            border-radius: 8px;
            background: rgba(0, 122, 255, 0.1);
            color: var(--azul-gvi);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            transition: background-color 0.14s ease, color 0.14s ease;
        }

        .btn-editar-precio:hover {
            background: var(--azul-gvi);
            color: white;
        }

        .modal-precio-panel {
            width: min(430px, calc(100vw - 32px));
            padding: 0;
            overflow: hidden;
            border-radius: 22px;
        }

        .modal-precio-header {
            padding: 22px 24px 18px;
            background: linear-gradient(135deg, rgba(0,122,255,0.12), rgba(52,199,89,0.08));
            border-bottom: 1px solid rgba(0,0,0,0.06);
            display: flex;
            align-items: center;
            gap: 14px;
        }

        body.dark-mode .modal-precio-header { border-bottom-color: #333; }

        .modal-precio-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: var(--azul-gvi);
            color: white;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            box-shadow: 0 6px 14px rgba(0,122,255,0.24);
        }

        .modal-precio-icon svg { width: 24px; height: 24px; }

        .modal-precio-title h3 {
            margin: 0;
            font-size: 22px;
            line-height: 1.1;
        }

        .modal-precio-title span {
            display: block;
            margin-top: 5px;
            font-size: 12px;
            font-weight: 800;
            opacity: 0.55;
            text-transform: uppercase;
        }

        .modal-precio-body { padding: 22px 24px 24px; }

        .producto-precio-card {
            background: rgba(0,122,255,0.06);
            border: 1px solid rgba(0,122,255,0.12);
            border-radius: 16px;
            padding: 14px 16px;
            margin-bottom: 18px;
        }

        body.dark-mode .producto-precio-card {
            background: rgba(0,122,255,0.1);
            border-color: rgba(255,255,255,0.08);
        }

        .producto-precio-card span {
            display: block;
            font-size: 11px;
            font-weight: 900;
            opacity: 0.55;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .producto-precio-card b {
            display: block;
            font-size: 16px;
            line-height: 1.25;
        }

        .precio-field {
            margin-bottom: 14px;
        }

        .precio-field label {
            display: block;
            margin-bottom: 7px;
            font-size: 12px;
            font-weight: 900;
            opacity: 0.65;
            text-transform: uppercase;
        }

        .precio-input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .precio-input-wrap i,
        .precio-input-wrap svg {
            position: absolute;
            left: 14px;
            width: 19px;
            height: 19px;
            color: var(--azul-gvi);
            opacity: 0.75;
        }

        .precio-input-wrap .form-input {
            padding-left: 44px !important;
            min-height: 54px;
            border-radius: 14px;
        }

        #editarPrecioPin {
            letter-spacing: 7px;
            text-align: center;
        }

        #editarPrecioValor {
            color: var(--azul-gvi);
            font-size: 25px;
            font-weight: 900;
            text-align: center;
        }

        .modal-precio-actions {
            display: grid;
            grid-template-columns: 0.9fr 1.2fr;
            gap: 10px;
            margin-top: 8px;
        }

        .modal-cobro-panel,
        .modal-manual-panel {
            width: min(620px, calc(100vw - 32px));
            padding: 0;
            overflow: hidden;
            border-radius: 26px;
            text-align: left;
            border: 1px solid rgba(255,255,255,0.7);
            box-shadow: 0 34px 90px rgba(25, 35, 58, 0.26);
        }

        body.dark-mode .modal-cobro-panel,
        body.dark-mode .modal-manual-panel {
            border-color: rgba(255,255,255,0.08);
            box-shadow: 0 34px 90px rgba(0,0,0,0.42);
        }

        .modal-cobro-header,
        .modal-manual-header {
            padding: 24px 28px 22px;
            background:
                radial-gradient(circle at 88% 0%, rgba(52,199,89,0.18), transparent 34%),
                linear-gradient(135deg, rgba(61,115,255,0.14), rgba(242,247,255,0.88));
            border-bottom: 1px solid rgba(0,0,0,0.06);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
        }

        body.dark-mode .modal-cobro-header,
        body.dark-mode .modal-manual-header {
            background:
                radial-gradient(circle at 88% 0%, rgba(52,199,89,0.16), transparent 34%),
                linear-gradient(135deg, rgba(61,115,255,0.14), rgba(255,255,255,0.04));
            border-bottom-color: rgba(255,255,255,0.08);
        }

        .modal-kicker {
            display: block;
            font-size: 12px;
            font-weight: 900;
            opacity: 0.58;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            margin-bottom: 6px;
        }

        .modal-cobro-header h3,
        .modal-manual-header h3 {
            margin: 0;
            font-size: clamp(26px, 4vw, 34px);
            line-height: 1;
            letter-spacing: -0.03em;
        }

        .modal-cobro-meta,
        .modal-manual-meta {
            margin: 9px 0 0;
            color: var(--texto-suave);
            font-size: 14px;
            font-weight: 750;
        }

        .modal-icon-soft {
            width: 58px;
            height: 58px;
            border-radius: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            color: var(--azul-gvi);
            background: rgba(255,255,255,0.72);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.9), 0 16px 34px rgba(61,115,255,0.18);
            flex: 0 0 auto;
        }

        body.dark-mode .modal-icon-soft {
            background: rgba(255,255,255,0.08);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 16px 34px rgba(0,0,0,0.2);
        }

        .modal-icon-soft svg {
            width: 28px;
            height: 28px;
        }

        .modal-cobro-total {
            font-size: clamp(48px, 8vw, 74px);
            line-height: 1;
            font-weight: 950;
            color: var(--azul-gvi);
            font-variant-numeric: tabular-nums;
            letter-spacing: -0.055em;
            text-align: right;
        }

        .modal-cobro-body,
        .modal-manual-body {
            padding: 24px 28px 28px;
        }

        .metodos-cobro {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin-bottom: 16px;
        }

        .metodos-cobro .btn-metodo {
            min-height: 74px;
            padding: 12px;
            border-radius: 18px;
            background: rgba(17,24,39,0.035);
            border: 1px solid rgba(17,24,39,0.08);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            color: var(--texto-oscuro);
            box-shadow: none;
            transition: transform 0.16s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.16s ease, background-color 0.16s ease, color 0.16s ease;
        }

        .metodos-cobro .btn-metodo svg {
            width: 22px;
            height: 22px;
        }

        .metodos-cobro .btn-metodo:hover {
            transform: translateY(-1px);
            border-color: rgba(61,115,255,0.24);
        }

        .metodos-cobro .btn-metodo.activo {
            background: rgba(61,115,255,0.1);
            border-color: rgba(61,115,255,0.58);
            color: var(--azul-gvi);
        }

        .metodos-cobro .btn-metodo.fiado-color {
            color: #f08a00;
            border-color: rgba(240,138,0,0.28);
        }

        .metodos-cobro .btn-metodo.fiado-color.activo {
            background: rgba(255,149,0,0.1);
            border-color: rgba(240,138,0,0.66);
        }

        body.dark-mode .metodos-cobro .btn-metodo {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.08);
            color: rgba(246,247,251,0.84);
        }

        .campo-pago-card {
            background: #f7f9fd;
            border: 1px solid rgba(17,24,39,0.07);
            border-radius: 22px;
            padding: 18px;
        }

        body.dark-mode .campo-pago-card {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.08);
        }

        .campo-pago-card label {
            display: block;
            margin-bottom: 10px;
            font-size: 12px;
            font-weight: 900;
            opacity: 0.62;
            text-transform: uppercase;
            letter-spacing: 0.07em;
        }

        .pago-input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .pago-input-wrap i,
        .pago-input-wrap svg {
            position: absolute;
            left: 15px;
            width: 21px;
            height: 21px;
            color: var(--azul-gvi);
            opacity: 0.8;
        }

        .pago-input-wrap .form-input {
            min-height: 68px;
            padding: 0 20px 0 52px !important;
            border-radius: 18px;
            border: 2px solid rgba(61,115,255,0.2);
            background: #fff;
            font-size: clamp(24px, 4vw, 34px);
            font-weight: 950;
            text-align: center;
            color: var(--texto-oscuro);
            font-variant-numeric: tabular-nums;
        }

        body.dark-mode .pago-input-wrap .form-input {
            background: rgba(255,255,255,0.06);
            color: rgba(246,247,251,0.96);
        }

        .vuelto-card {
            margin-top: 14px;
            padding: 14px 16px;
            border-radius: 18px;
            background: rgba(52,199,89,0.12);
            color: #2eb84e;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-weight: 900;
            font-size: 24px;
            font-variant-numeric: tabular-nums;
        }

        .vuelto-card span:first-child {
            font-size: 12px;
            text-transform: uppercase;
            opacity: 0.75;
            letter-spacing: 0.07em;
        }

        .fiado-card {
            background: rgba(255,149,0,0.08);
            border: 1px solid rgba(255,149,0,0.18);
            border-radius: 22px;
            padding: 18px;
        }

        .fiado-card .form-input {
            min-height: 62px;
            border-radius: 17px;
            border: 2px solid rgba(255,149,0,0.34);
            font-size: 21px;
            font-weight: 900;
            text-align: center;
            text-transform: uppercase;
        }

        .aviso-cliente-nuevo {
            display: none;
            margin-top: 12px;
            padding: 10px 12px;
            border-radius: 14px;
            color: #b86b00;
            background: rgba(255,149,0,0.12);
            font-size: 13px;
            font-weight: 850;
            text-align: center;
        }

        .acciones-cobro {
            display: grid;
            grid-template-columns: 0.85fr 1fr 1.25fr;
            gap: 12px;
            margin-top: 18px;
        }

        .acciones-cobro button {
            min-height: 64px;
            border-radius: 18px !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            font-size: 16px;
            font-weight: 950;
        }

        .acciones-cobro button svg {
            width: 20px;
            height: 20px;
        }

        .modal-manual-panel {
            --modal-width: 500px;
            border-radius: 22px;
        }

        .manual-form-grid {
            display: grid;
            gap: 14px;
        }

        .manual-field label {
            display: block;
            margin-bottom: 8px;
            font-size: 12px;
            font-weight: 900;
            opacity: 0.68;
            text-transform: uppercase;
            letter-spacing: 0.07em;
        }

        .manual-field-hint {
            display: block;
            margin-top: 2px;
            text-transform: none;
            letter-spacing: 0;
            font-size: 12px;
            opacity: 0.72;
        }

        .manual-input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .manual-input-wrap svg,
        .manual-input-wrap i {
            position: absolute;
            left: 16px;
            width: 22px;
            height: 22px;
            color: var(--azul-gvi);
            opacity: 0.78;
        }

        .manual-input-wrap .form-input {
            width: 100%;
            box-sizing: border-box;
            min-height: 56px;
            border-radius: 16px;
            border: 2px solid rgba(17,24,39,0.1);
            padding-left: 50px;
            font-size: 20px;
            font-weight: 850;
            outline: none;
        }

        .manual-input-wrap .form-input:focus {
            border-color: rgba(61,115,255,0.56);
            box-shadow: 0 0 0 4px rgba(61,115,255,0.12);
        }

        .manual-input-wrap.price .form-input {
            font-size: clamp(28px, 5vw, 38px);
            font-weight: 950;
            color: var(--azul-gvi);
            font-variant-numeric: tabular-nums;
        }

        .manual-input-wrap.price::before {
            content: "$";
            position: absolute;
            left: 51px;
            z-index: 1;
            color: rgba(61,115,255,0.55);
            font-size: 28px;
            font-weight: 950;
            pointer-events: none;
        }

        .manual-input-wrap.price .form-input {
            padding-left: 76px;
        }

        .manual-presets {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-top: 12px;
        }

        .manual-presets button {
            min-height: 46px;
            border: 1px solid rgba(17,24,39,0.08);
            background: rgba(17,24,39,0.035);
            color: inherit;
            border-radius: 13px;
            font-weight: 900;
            cursor: pointer;
            transition: transform 0.14s ease, border-color 0.14s ease, background-color 0.14s ease;
        }

        .manual-presets button:hover {
            transform: translateY(-1px);
            border-color: rgba(61,115,255,0.28);
            background: rgba(61,115,255,0.08);
        }

        .acciones-manual {
            display: grid;
            grid-template-columns: 0.9fr 1.25fr;
            gap: 12px;
            margin-top: 18px;
        }

        .acciones-manual button {
            min-height: 58px;
            border-radius: 16px !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 9px;
            font-size: 17px;
            font-weight: 950;
        }

        #modalManual .modal-manual-header {
            padding: 22px 24px 18px;
            background: #f8faff;
            border-bottom-color: rgba(17,24,39,0.07);
        }

        body.dark-mode #modalManual .modal-manual-header {
            background: rgba(255,255,255,0.04);
        }

        #modalManual .modal-manual-header h3 {
            font-size: 30px;
        }

        #modalManual .modal-manual-body {
            padding: 20px 24px 24px;
        }

        #modalManual .modal-icon-soft {
            width: 46px;
            height: 46px;
            border-radius: 15px;
        }

        @media (max-width: 620px) {
            .modal-cobro-header,
            .modal-manual-header {
                align-items: flex-start;
                flex-direction: column;
            }
            .modal-cobro-total { text-align: left; }
            .metodos-cobro,
            .acciones-cobro,
            .acciones-manual { grid-template-columns: 1fr; }
            .manual-presets { grid-template-columns: repeat(2, 1fr); }
        }

        .btn-manual-rapido {
            background: var(--azul-gvi);
            color: white;
            border: none;
            padding: 0 20px;
            border-radius: 10px;
            font-weight: 800;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: background-color 0.16s ease, filter 0.16s ease;
        }
        .btn-manual-rapido:hover { filter: brightness(1.08); }
        .btn-manual-rapido i { width: 18px; height: 18px; }

        .contenedor.caja-shell {
            max-width: 1520px;
            margin-top: 28px;
        }

        body.dark-mode .caja-shell {
            --texto-suave: rgba(246, 247, 251, 0.66);
            --superficie-suave: rgba(255, 255, 255, 0.08);
        }

        .caja-header {
            margin: 26px 0 18px;
            align-items: flex-end;
        }

        .caja-header-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        .caja-title-kicker {
            margin: 0 0 6px;
            font-size: 12px;
            font-weight: 900;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--azul-gvi);
        }

        .caja-header h1 {
            font-size: clamp(32px, 3.2vw, 48px);
            letter-spacing: -0.04em;
            line-height: 1;
        }

        .caja-header p {
            margin: 8px 0 0;
            color: var(--texto-suave);
            font-weight: 700;
        }

        .estado-caja-chip {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            padding: 10px 14px;
            border-radius: 999px;
            background: rgba(40, 199, 111, 0.12);
            color: #159c52;
            font-size: 13px;
            font-weight: 900;
            border: 1px solid rgba(40, 199, 111, 0.18);
        }

        .estado-caja-chip i,
        .estado-caja-chip svg {
            width: 17px;
            height: 17px;
        }

        .caja-focus-toggle {
            border: 1px solid rgba(36,47,70,0.1);
            background: rgba(255,255,255,0.82);
            color: rgba(17,24,39,0.78);
            border-radius: 999px;
            min-height: 42px;
            padding: 0 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-weight: 950;
            cursor: pointer;
            box-shadow: 0 10px 24px rgba(42,53,77,0.08);
            transition: transform 0.18s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.18s ease, border-color 0.18s ease, color 0.18s ease;
        }

        .caja-focus-toggle:hover {
            transform: translateY(-1px);
            border-color: rgba(61,115,255,0.28);
            color: var(--azul-gvi);
            background: rgba(61,115,255,0.08);
        }

        .caja-focus-toggle i,
        .caja-focus-toggle svg {
            width: 17px;
            height: 17px;
        }

        body.dark-mode .caja-focus-toggle {
            background: rgba(255,255,255,0.07);
            border-color: rgba(255,255,255,0.09);
            color: rgba(246,247,251,0.78);
            box-shadow: 0 14px 28px rgba(0,0,0,0.18);
        }

        .caja-grid {
            grid-template-columns: minmax(0, 1.8fr) minmax(360px, 0.72fr);
            gap: 24px;
        }

        .panel-ticket,
        .panel-cobro {
            border: 1px solid rgba(36, 47, 70, 0.09);
            box-shadow: 0 24px 70px rgba(42, 53, 77, 0.1);
        }

        body.dark-mode .panel-ticket,
        body.dark-mode .panel-cobro {
            border-color: rgba(255,255,255,0.08);
            box-shadow: 0 24px 70px rgba(0,0,0,0.24);
        }

        .panel-ticket {
            min-height: calc(100dvh - 230px);
            border-radius: 22px;
        }

        .buscador-caja {
            padding: 18px;
            background: linear-gradient(180deg, rgba(255,255,255,0.82), rgba(248,250,255,0.92));
            gap: 12px;
        }

        body.dark-mode .buscador-caja {
            background: rgba(255,255,255,0.035);
        }

        .input-barras {
            min-height: 62px;
            border-radius: 16px;
            border-color: rgba(61, 115, 255, 0.38);
            background: rgba(255,255,255,0.86);
            font-family: 'Manrope', 'Segoe UI', system-ui, sans-serif;
            font-size: 22px;
            font-weight: 800;
            letter-spacing: -0.02em;
            box-shadow: inset 0 0 0 1px rgba(255,255,255,0.55);
        }

        body.dark-mode .input-barras {
            background: rgba(255,255,255,0.06);
        }

        .input-barras::placeholder {
            color: rgba(17, 24, 39, 0.42);
            font-weight: 800;
        }

        body.dark-mode .input-barras::placeholder {
            color: rgba(246,247,251,0.38);
        }

        .btn-manual-rapido {
            min-width: 142px;
            justify-content: center;
            border-radius: 16px;
            font-size: 16px;
            box-shadow: 0 12px 24px rgba(61,115,255,0.22);
        }

        .caja-quickbar {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 16px;
            align-items: center;
            padding: 14px 18px;
            border-bottom: 1px solid rgba(36,47,70,0.08);
            background: rgba(248,250,255,0.58);
        }

        body.dark-mode .caja-quickbar {
            background: rgba(255,255,255,0.025);
            border-bottom-color: rgba(255,255,255,0.08);
        }

        .caja-categorias {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .categoria-chip {
            border: 1px solid rgba(36,47,70,0.1);
            background: rgba(255,255,255,0.72);
            color: inherit;
            border-radius: 999px;
            padding: 9px 12px;
            font-weight: 900;
            font-size: 12px;
            cursor: pointer;
            transition: transform 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
        }

        .categoria-chip:hover {
            transform: translateY(-1px);
            border-color: rgba(61,115,255,0.35);
            background: rgba(61,115,255,0.08);
        }

        body.dark-mode .categoria-chip {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.08);
            color: rgba(246,247,251,0.88);
        }

        .venta-meta {
            display: flex;
            gap: 14px;
            color: var(--texto-suave);
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
        }

        .venta-meta b {
            color: var(--texto-claro);
            font-variant-numeric: tabular-nums;
        }

        body.dark-mode .venta-meta b {
            color: var(--texto-oscuro);
        }

        .carrito-scroll {
            flex: 1;
            overflow-y: auto;
            min-height: 330px;
        }

        .carrito-tabla th {
            padding: 14px 18px;
            font-size: 11px;
            letter-spacing: 0.04em;
            background: rgba(15,23,42,0.025);
        }

        body.dark-mode .carrito-tabla th {
            color: rgba(246,247,251,0.58);
            background: rgba(255,255,255,0.025);
        }

        .carrito-tabla td {
            padding: 14px 18px;
            vertical-align: middle;
        }

        .carrito-tabla b,
        .panel-cobro,
        .caja-total,
        .modal-cobro-total {
            font-variant-numeric: tabular-nums;
        }

        .empty-carrito {
            padding: 48px 22px !important;
            text-align: center;
        }

        .empty-carrito-box {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
            max-width: 360px;
            color: var(--texto-suave);
            font-weight: 800;
        }

        .empty-carrito-box i,
        .empty-carrito-box svg {
            width: 34px;
            height: 34px;
            color: var(--azul-gvi);
        }

        .productos-rapidos {
            border-top: 1px solid rgba(36,47,70,0.08);
            background: rgba(248,250,255,0.54);
            padding: 16px 18px 18px;
        }

        body.dark-mode .productos-rapidos {
            background: rgba(255,255,255,0.022);
            border-top-color: rgba(255,255,255,0.08);
        }

        .productos-rapidos-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .productos-rapidos-header h2 {
            margin: 0;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--texto-suave);
        }

        .productos-rapidos-header span {
            font-size: 12px;
            color: var(--texto-suave);
            font-weight: 800;
        }

        body.dark-mode .productos-rapidos-header h2,
        body.dark-mode .productos-rapidos-header span {
            color: rgba(246,247,251,0.58);
        }

        .productos-rapidos-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 10px;
        }

        .producto-rapido {
            min-height: 86px;
            padding: 12px;
            border: 1px solid rgba(36,47,70,0.1);
            border-radius: 16px;
            background: rgba(255,255,255,0.78);
            color: inherit;
            text-align: left;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            gap: 10px;
            transition: transform 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
        }

        .producto-rapido:hover {
            transform: translateY(-2px);
            border-color: rgba(61,115,255,0.34);
            box-shadow: 0 14px 24px rgba(42,53,77,0.1);
        }

        body.dark-mode .producto-rapido {
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.08);
        }

        .producto-rapido strong {
            font-size: 13px;
            line-height: 1.18;
        }

        .producto-rapido span {
            color: var(--azul-gvi);
            font-size: 16px;
            font-weight: 950;
            font-variant-numeric: tabular-nums;
        }

        .panel-cobro {
            border-radius: 24px;
            padding: 20px;
            top: 118px;
        }

        .cobro-status {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 18px;
            color: var(--texto-suave);
            font-size: 12px;
            font-weight: 900;
        }

        .cobro-status span {
            display: inline-flex;
            align-items: center;
            gap: 7px;
        }

        .cobro-status i,
        .cobro-status svg {
            width: 16px;
            height: 16px;
        }

        .cobro-total-card {
            border-radius: 22px;
            padding: 22px 18px;
            background: linear-gradient(180deg, rgba(61,115,255,0.1), rgba(61,115,255,0.045));
            text-align: center;
            border: 1px solid rgba(61,115,255,0.12);
        }

        .cobro-label {
            font-size: 12px;
            font-weight: 950;
            letter-spacing: 0.07em;
            color: var(--texto-suave);
            text-transform: uppercase;
        }

        .caja-total {
            font-size: clamp(52px, 5.8vw, 76px);
            line-height: 0.95;
            letter-spacing: -0.06em;
            margin: 12px 0 4px;
        }

        .cobro-subtotal {
            color: var(--texto-suave);
            font-size: 13px;
            font-weight: 800;
        }

        .cobro-actions {
            display: grid;
            gap: 10px;
            margin-top: 14px;
        }

        .btn-cobrar {
            min-height: 74px;
            border-radius: 18px;
            font-size: 24px;
            letter-spacing: -0.02em;
            background: var(--verde-gvi);
            box-shadow: 0 18px 30px rgba(40,199,111,0.25);
        }

        .btn-cobrar:not(:disabled):hover {
            filter: brightness(1.04);
            transform: translateY(-1px);
        }

        .acciones-venta-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
        }

        .btn-venta-secundaria {
            min-height: 48px;
            border-radius: 14px;
            border: 1px solid rgba(36,47,70,0.1);
            background: rgba(15,23,42,0.045);
            color: inherit;
            font-weight: 900;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        body.dark-mode .btn-venta-secundaria {
            background: rgba(255,255,255,0.06);
            border-color: rgba(255,255,255,0.08);
        }

        .btn-venta-secundaria.danger {
            color: var(--rojo-gvi);
        }

        .atajos-caja {
            margin-top: 16px;
            padding: 14px;
            border-radius: 18px;
            background: rgba(15,23,42,0.035);
            color: var(--texto-suave);
            font-size: 12px;
            font-weight: 800;
        }

        body.dark-mode .atajos-caja {
            background: rgba(255,255,255,0.045);
            color: rgba(246,247,251,0.62);
        }

        .atajos-caja strong {
            display: block;
            margin-bottom: 8px;
            color: inherit;
        }

        .atajos-caja div {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            padding: 5px 0;
        }

        .atajos-caja kbd {
            border-radius: 8px;
            padding: 3px 8px;
            background: rgba(255,255,255,0.72);
            color: var(--texto-claro);
            font-family: inherit;
            font-weight: 950;
            font-size: 11px;
        }

        body.dark-mode .atajos-caja kbd {
            background: rgba(255,255,255,0.1);
            color: var(--texto-oscuro);
        }

        body.caja-focus-mode .app-topbar {
            position: fixed;
            left: 50%;
            top: 0;
            margin-top: 0;
            opacity: 0;
            pointer-events: none;
            transform: translate3d(-50%, -118%, 0);
            transition: opacity 0.22s ease, transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
        }

        body.caja-focus-mode .caja-shell {
            width: min(100% - 34px, 1660px);
            max-width: 1660px;
            margin-top: 14px;
            transition: width 0.28s cubic-bezier(0.16, 1, 0.3, 1), margin 0.28s cubic-bezier(0.16, 1, 0.3, 1);
        }

        body.caja-focus-mode .caja-header {
            margin: 10px 0 14px;
        }

        body.caja-focus-mode .caja-header p,
        body.caja-focus-mode .caja-title-kicker {
            display: none;
        }

        body.caja-focus-mode .caja-header h1 {
            font-size: clamp(26px, 2.4vw, 36px);
        }

        body.caja-focus-mode .panel-ticket {
            min-height: calc(100dvh - 96px);
        }

        body.caja-focus-mode .panel-cobro {
            top: 16px;
        }

        body.caja-focus-mode .caja-focus-toggle {
            background: rgba(61,115,255,0.12);
            border-color: rgba(61,115,255,0.24);
            color: var(--azul-gvi);
        }

        body.caja-focus-mode .estado-caja-chip {
            display: none;
        }

        @media (max-width: 1100px) {
            .caja-grid { grid-template-columns: 1fr; }
            .panel-cobro { position: static; }
            .productos-rapidos-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
        }

        @media (max-width: 720px) {
            .caja-header { align-items: flex-start; flex-direction: column; }
            .caja-header-actions { justify-content: flex-start; }
            .buscador-caja,
            .caja-quickbar { grid-template-columns: 1fr; }
            .buscador-caja { flex-direction: column; }
            .btn-manual-rapido { min-height: 54px; }
            .productos-rapidos-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
            .venta-meta { flex-wrap: wrap; }
        }

        @media print {
            @page { margin: 0; size: 80mm auto; }
            body * { display: none !important; }
            #areaImpresion { display: block !important; }
            #areaImpresion div { display: block !important; }
            #areaImpresion table { display: table !important; }
            #areaImpresion tbody { display: table-row-group !important; }
            #areaImpresion tr { display: table-row !important; }
            #areaImpresion td { display: table-cell !important; }
            #areaImpresion span { display: inline !important; }
            #areaImpresion {
                position: absolute;
                left: 0;
                top: 0;
                width: 68mm;
                padding: 3mm 4mm;
                color: #000 !important;
                background: #fff !important;
                font-family: "Courier New", monospace !important;
                font-weight: 800 !important;
                box-sizing: border-box;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>
    <script>
        try {
            if (localStorage.getItem('gvi_caja_modo_foco') === '1') {
                document.body.classList.add('caja-focus-mode');
            }
        } catch (_) {}
    </script>
    <%- include('partials/nav') %>

    <div class="contenedor caja-shell">
        <div class="caja-header">
            <div>
                <div class="caja-title-kicker">Caja principal</div>
                <h1>Punto de venta</h1>
                <p>Escanea, busca o vende manualmente sin salir del flujo de caja.</p>
            </div>
            <div class="caja-header-actions">
                <button class="caja-focus-toggle" id="btnModoFocoCaja" type="button" onclick="toggleModoFocoCaja()" title="Ocultar barra y enfocar venta (F10)">
                    <i data-lucide="maximize-2"></i>
                    <span>Modo venta</span>
                </button>
                <div class="estado-caja-chip"><i data-lucide="scan-line"></i> Lista para vender</div>
            </div>
        </div>

        <div class="caja-grid">
            <div class="panel-ticket">
                <div class="buscador-caja">
                    <div style="position: relative; flex: 1; display: flex; align-items: center;">
                        <i data-lucide="search" style="position: absolute; left: 15px; opacity: 0.4;"></i>
                        <input type="text" id="inputCodigoCaja" class="input-barras" placeholder="Escanear o buscar producto..." autocomplete="off" autofocus style="padding-left: 45px;">
                        <div id="listaSugerencias" class="sugerencias-busqueda"></div>
                    </div>
                    <button class="btn-manual-rapido" onclick="abrirModalManual()" title="Venta Manual">
                        <i data-lucide="plus-square"></i> Manual
                    </button>
                </div>

                <div class="caja-quickbar">
                    <div class="caja-categorias">
                        <button class="categoria-chip" onclick="filtrarRapidos('')">Frecuentes</button>
                        <button class="categoria-chip" onclick="filtrarRapidos('bebida')">Bebidas</button>
                        <button class="categoria-chip" onclick="filtrarRapidos('pan')">Pan</button>
                        <button class="categoria-chip" onclick="filtrarRapidos('leche')">Lacteos</button>
                        <button class="categoria-chip" onclick="filtrarRapidos('cigar')">Cigarros</button>
                        <button class="categoria-chip" onclick="filtrarRapidos('snack')">Snacks</button>
                    </div>
                    <div class="venta-meta">
                        <span>Items <b id="ventaItems">0</b></span>
                        <span>Unidades <b id="ventaUnidades">0</b></span>
                    </div>
                </div>
                
                <div class="carrito-scroll">
                    <table class="carrito-tabla">
                        <thead>
                            <tr><th>Producto</th><th>Cant.</th><th>Precio</th><th>Subtotal</th><th></th></tr>
                        </thead>
                        <tbody id="listaCarrito">
                            <tr>
                                <td colspan="5" class="empty-carrito">
                                    <div class="empty-carrito-box">
                                        <i data-lucide="scan-barcode"></i>
                                        <strong>Escanea un producto para comenzar</strong>
                                        <span>Tambien puedes usar venta manual o tocar un producto rapido.</span>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <section class="productos-rapidos">
                    <div class="productos-rapidos-header">
                        <h2>Productos rapidos</h2>
                        <span id="rapidosHint">Toca para agregar al carrito</span>
                    </div>
                    <div class="productos-rapidos-grid" id="productosRapidos">
                        <button class="producto-rapido" type="button" disabled>
                            <strong>Cargando catalogo...</strong>
                            <span>$0</span>
                        </button>
                    </div>
                </section>
            </div>

            <div class="panel-cobro">
                <div class="cobro-status">
                    <span><i data-lucide="receipt-text"></i> Venta actual</span>
                    <span id="cobroEstado">Sin productos</span>
                </div>
                <div class="cobro-total-card">
                    <div class="cobro-label">Total a pagar</div>
                    <div class="caja-total" id="txtTotal">$0</div>
                    <div class="cobro-subtotal" id="txtResumenCobro">Agrega productos para habilitar el cobro</div>
                </div>
                <div class="cobro-actions">
                    <button class="btn-cobrar" id="btnCobrar" onclick="abrirModalFinalizar()" disabled>
                        <i data-lucide="banknote"></i> Cobrar
                    </button>
                    <div class="acciones-venta-grid">
                        <button class="btn-venta-secundaria" type="button" onclick="abrirModalManual()">
                            <i data-lucide="plus"></i> Varios
                        </button>
                        <button class="btn-venta-secundaria danger" type="button" onclick="cancelarVentaActual()">
                            <i data-lucide="trash-2"></i> Cancelar
                        </button>
                    </div>
                </div>
                <div class="atajos-caja">
                    <strong>Atajos de caja</strong>
                    <div><span>Buscar producto</span><kbd>Escaner</kbd></div>
                    <div><span>Venta manual</span><kbd>Manual</kbd></div>
                    <div><span>Cobrar</span><kbd>Enter</kbd></div>
                    <div><span>Ocultar barra</span><kbd>F10</kbd></div>
                </div>
            </div>
        </div>
    </div>

    <div id="modalFinalizar" class="modal-fondo">
        <div class="panel modal-cobro-panel">
            <div class="modal-cobro-header">
                <div>
                    <span class="modal-kicker">Cobro de caja</span>
                    <h3>Finalizar venta</h3>
                    <p class="modal-cobro-meta">Elige el método, confirma el pago y guarda la venta.</p>
                </div>
                <div class="modal-cobro-total" id="totalModal">$0</div>
            </div>
            <div class="modal-cobro-body">

            <div class="metodos-cobro">
                <button class="btn-metodo activo" id="btnEfec" onclick="setMetodo('Efectivo')">
                    <i data-lucide="banknote"></i>
                    <span>Efectivo</span>
                </button>
                <button class="btn-metodo" id="btnTarj" onclick="setMetodo('Tarjeta')">
                    <i data-lucide="credit-card"></i>
                    <span>Tarjeta</span>
                </button>
                <button class="btn-metodo fiado-color" id="btnFiado" onclick="setMetodo('Fiado')">
                    <i data-lucide="notebook"></i>
                    <span>Fiado</span>
                </button>
            </div>

            <div id="seccionEfectivo" class="campo-pago-card">
                <label for="inputPagoModal">Monto recibido</label>
                <div class="pago-input-wrap">
                    <i data-lucide="circle-dollar-sign"></i>
                    <input type="text" id="inputPagoModal" class="form-input" placeholder="$0" inputmode="numeric"
                           oninput="formatearVuelto(this)">
                </div>
                <div id="estadoPagoModal" class="vuelto-card">
                    <span id="estadoPagoTexto">Vuelto:</span> <span id="vueltoModal">$0</span>
                </div>
            </div>

            <div id="seccionFiado" class="fiado-card" style="display: none;">
                <label for="nombreClienteFiado">Buscar o registrar cliente</label>
                <input type="text" id="nombreClienteFiado" class="form-input" placeholder="Escribe el nombre del cliente..." 
                       list="listaClientesRegistrados" autocomplete="off"
                       oninput="verificarClienteExistente(this)">
                
                <datalist id="listaClientesRegistrados"></datalist>

                <div id="avisoNuevoCliente" class="aviso-cliente-nuevo">
                    Cliente nuevo: se creará una cuenta nueva.
                </div>
            </div>

            <div class="acciones-cobro">
                <button class="btn-cancelar" onclick="cerrarModalFinalizar()">
                    <i data-lucide="x"></i>
                    <span>Cancelar</span>
                </button>
                <button class="btn-cancelar" id="btnSoloGuardar" onclick="procesarVentaReal(false)">
                    <i data-lucide="save"></i>
                    <span id="btnSoloGuardarTexto">Solo guardar</span>
                </button>
                <button class="btn-success" id="btnGuardarImprimir" onclick="procesarVentaReal(true)">
                    <i data-lucide="printer"></i>
                    <span>Guardar e imprimir</span>
                </button>
            </div>
            </div>
        </div>
    </div>

    <div id="modalPeso" class="modal-fondo">
        <!-- ... (Contenido del modal peso se mantiene igual) ... -->
        <div class="panel" style="width: 420px; padding: 35px; text-align: center;">
            <div style="font-size: 50px; margin-bottom: 5px;">⚖️</div>
            <h3 id="modalPesoNombre" style="margin: 0 0 5px; font-size: 20px;"></h3>
            <p style="opacity: 0.5; margin: 0 0 15px; font-size: 14px;">Precio: $<span id="modalPesoPrecioKilo">0</span> por kilo</p>
            
            <div style="display: flex; background: rgba(0,0,0,0.05); border-radius: 10px; padding: 4px; margin-bottom: 20px;">
                <button id="btnCajaGramos" onclick="setModoPesoCaja('gramos')" style="flex:1; border:none; padding:10px; border-radius:8px; font-weight:800; cursor:pointer; background:white; color:var(--azul-gvi);">POR GRAMOS</button>
                <button id="btnCajaDinero" onclick="setModoPesoCaja('dinero')" style="flex:1; border:none; padding:10px; border-radius:8px; font-weight:800; cursor:pointer; background:transparent; color:#666;">POR DINERO ($)</button>
            </div>

            <div id="divCajaGramos">
                <input type="number" id="inputPesoGramos" class="input-barras"
                       placeholder="Gramos (ej: 500)" min="1" step="1"
                       oninput="calcularPrecioEnVivo('gramos')"
                       style="text-align: center; font-size: 28px; margin-bottom: 15px; width: 100%; box-sizing: border-box;">
            </div>

            <div id="divCajaDinero" style="display:none;">
                <input type="number" id="inputPesoMonto" class="input-barras"
                       placeholder="Monto $ (ej: 1000)" min="1" step="1"
                       oninput="calcularPrecioEnVivo('dinero')"
                       style="text-align: center; font-size: 28px; margin-bottom: 15px; width: 100%; box-sizing: border-box; border-color: #34c759;">
            </div>

            <div style="margin: 15px 0; padding: 15px; background: rgba(0,122,255,0.05); border-radius: 12px;">
                <div style="font-size: 13px; opacity: 0.6; font-weight: 700; text-transform: uppercase;" id="lblResultadoCaja">Total a Cobrar</div>
                <div style="font-size: 32px; font-weight: 900; color: var(--azul-gvi); min-height: 40px;" id="precioCalculadoPeso"></div>
            </div>
            <div style="display: flex; gap: 10px; margin-top: 25px;">
                <button class="btn-cancelar" style="flex: 1;" onclick="cerrarModalPeso()">Cancelar</button>
                <button class="btn-accion" style="flex: 1.7;" onclick="confirmarPeso()">⚖️ Agregar al Carrito</button>
            </div>
        </div>
    </div>

    <!-- MODAL VENTA MANUAL -->
    <div id="modalManual" class="modal-fondo">
        <div class="panel modal-manual-panel">
            <div class="modal-manual-header">
                <div>
                    <span class="modal-kicker">Venta rápida</span>
                    <h3>Producto manual</h3>
                    <p class="modal-manual-meta">Agrega un cobro directo cuando el producto no está creado.</p>
                </div>
                <div class="modal-icon-soft"><i data-lucide="plus"></i></div>
            </div>
            <div class="modal-manual-body">
                <div class="manual-form-grid">
                    <div class="manual-field">
                        <label for="manualNombre">Concepto <span class="manual-field-hint">visible en el ticket</span></label>
                        <div class="manual-input-wrap">
                            <i data-lucide="tag"></i>
                            <input type="text" id="manualNombre" class="form-input" placeholder="Varios" value="Varios">
                        </div>
                    </div>
                    <div class="manual-field">
                        <label for="manualPrecio">Precio</label>
                        <div class="manual-input-wrap price">
                            <i data-lucide="circle-dollar-sign"></i>
                            <input type="text" id="manualPrecio" class="form-input" placeholder="0" inputmode="numeric" autocomplete="off">
                        </div>
                        <div class="manual-presets" aria-label="Montos rápidos">
                            <button type="button" onclick="setManualPrecio(500)">$500</button>
                            <button type="button" onclick="setManualPrecio(1000)">$1.000</button>
                            <button type="button" onclick="setManualPrecio(2000)">$2.000</button>
                        </div>
                    </div>
                </div>

                <div class="acciones-manual">
                    <button class="btn-cancelar" onclick="cerrarModalManual()">
                        <i data-lucide="x"></i>
                        <span>Cancelar</span>
                    </button>
                    <button class="btn-accion" onclick="agregarManualAlCarrito()">
                        <i data-lucide="shopping-cart"></i>
                        <span>Añadir a la venta</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL EDITAR PRECIO -->
    <div id="modalEditarPrecio" class="modal-fondo">
        <div class="panel modal-precio-panel">
            <div class="modal-precio-header">
                <div class="modal-precio-icon"><i data-lucide="shield-check"></i></div>
                <div class="modal-precio-title">
                    <h3>Editar Precio</h3>
                    <span>Autorizacion administrador</span>
                </div>
            </div>

            <div class="modal-precio-body">
                <div class="producto-precio-card">
                    <span>Producto seleccionado</span>
                    <b id="editarPrecioProducto"></b>
                </div>

                <div class="precio-field">
                    <label>PIN Administrador</label>
                    <div class="precio-input-wrap">
                        <i data-lucide="lock-keyhole"></i>
                        <input type="password" id="editarPrecioPin" class="form-input" maxlength="4" inputmode="numeric" placeholder="••••">
                    </div>
                </div>

                <div class="precio-field">
                    <label>Nuevo Precio</label>
                    <div class="precio-input-wrap">
                        <i data-lucide="badge-dollar-sign"></i>
                        <input type="text" id="editarPrecioValor" class="form-input" inputmode="numeric" placeholder="$0" oninput="formatearPrecioEditor(this)">
                    </div>
                </div>

                <div id="editarPrecioError" style="min-height: 18px; color: #ff3b30; font-size: 12px; font-weight: 800; margin-bottom: 14px;"></div>

                <div class="modal-precio-actions">
                    <button class="btn-cancelar" onclick="cerrarModalEditarPrecio()">Cancelar</button>
                    <button class="btn-accion" onclick="confirmarEditarPrecio()">Guardar Precio</button>
                </div>
            </div>
        </div>
    </div>

    <div id="areaImpresion" style="display: none;"></div>

    <%- include('partials/scripts') %>

    <script>
        let catalogo = [];
        let carrito = [];
        let totalCaja = 0;
        let metodoPagoActual = 'Efectivo';
        let clientesFiadores = [];
        let timerBusqueda;
        let productoEsperaPeso = null;
        let indicePrecioEditando = null;
        let filtroRapidoActual = '';
        const modoFocoCajaKey = 'gvi_caja_modo_foco';

        // --- LÓGICA VENTA MANUAL ---
        function abrirModalManual() {
            document.getElementById('modalManual').style.display = 'flex';
            document.getElementById('manualPrecio').value = '';
            document.getElementById('manualNombre').value = 'Varios';
            if (typeof lucide !== 'undefined') lucide.createIcons();
            setTimeout(() => document.getElementById('manualPrecio').focus(), 150);
        }
        function cerrarModalManual() { document.getElementById('modalManual').style.display = 'none'; inputCaja.focus(); }

        function setManualPrecio(monto) {
            const input = document.getElementById('manualPrecio');
            input.value = monto;
            input.focus();
        }

        function agregarManualAlCarrito() {
            const nombre = document.getElementById('manualNombre').value.trim() || 'Varios';
            const precio = Number(document.getElementById('manualPrecio').value.replace(/\D/g, ''));
            if (!precio || precio <= 0) return alert("Ingresa un precio válido.");

            carrito.unshift({
                codigo: 'MANUAL',
                nombre: nombre.toUpperCase(),
                precio: precio,
                cantidad: 1,
                stock: 999999, // Sin limite de stock para manual
                vendidoPorPeso: false
            });
            actualizarVista();
            cerrarModalManual();
        }

        const inputCaja = document.getElementById('inputCodigoCaja');
        const listaSug = document.getElementById('listaSugerencias');
        let timerRefocoSku = null;

        function setModoFocoCaja(activo) {
            document.body.classList.toggle('caja-focus-mode', !!activo);
            localStorage.setItem(modoFocoCajaKey, activo ? '1' : '0');

            const btn = document.getElementById('btnModoFocoCaja');
            if (btn) {
                btn.innerHTML = activo
                    ? '<i data-lucide="minimize-2"></i><span>Modo normal</span>'
                    : '<i data-lucide="maximize-2"></i><span>Modo venta</span>';
                btn.setAttribute('aria-pressed', activo ? 'true' : 'false');
                btn.title = activo ? 'Mostrar barra (F10)' : 'Ocultar barra y enfocar venta (F10)';
            }

            document.getElementById('notificationsPopover')?.classList.remove('open');
            document.getElementById('profilePopover')?.classList.remove('open');
            requestAnimationFrame(() => {
                if (typeof lucide !== 'undefined') lucide.createIcons();
                inputCaja?.focus();
            });
        }

        function toggleModoFocoCaja() {
            setModoFocoCaja(!document.body.classList.contains('caja-focus-mode'));
        }

        function restaurarModoFocoCaja() {
            setModoFocoCaja(localStorage.getItem(modoFocoCajaKey) === '1');
        }

        function hayModalCajaAbierto() {
            return ['modalFinalizar', 'modalPeso', 'modalManual', 'modalEditarPrecio'].some(id => {
                const modal = document.getElementById(id);
                return modal && modal.style.display !== 'none' && getComputedStyle(modal).display !== 'none';
            });
        }

        function esCampoDeEscritura(el) {
            if (!el) return false;
            const tag = el.tagName;
            return el.isContentEditable || tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'F10') {
                e.preventDefault();
                toggleModoFocoCaja();
                return;
            }

            if (e.key === 'Escape' && document.body.classList.contains('caja-focus-mode') && !hayModalCajaAbierto()) {
                e.preventDefault();
                setModoFocoCaja(false);
            }
        });

        function programarRefocoSku() {
            clearTimeout(timerRefocoSku);
            timerRefocoSku = setTimeout(() => {
                if (hayModalCajaAbierto()) return;
                if (esCampoDeEscritura(document.activeElement) && document.activeElement !== inputCaja) return;
                inputCaja.focus();
                inputCaja.select();
            }, 3000);
        }

        async function cargarCatalogo() {
            const res = await fetch('/api/productos');
            catalogo = await res.json();
            renderProductosRapidos();
        }

        function filtrarRapidos(filtro) {
            filtroRapidoActual = filtro || '';
            renderProductosRapidos();
            inputCaja.focus();
        }

        function productoCoincideFiltro(producto, filtro) {
            if (!filtro) return true;
            const texto = `${producto.nombre || ''} ${producto.codigo || ''}`.toLowerCase();
            if (filtro === 'bebida') return /bebida|coca|fanta|sprite|jugo|agua|nectar|energetica|red bull|bilz|pap/.test(texto);
            if (filtro === 'pan') return /pan|hallulla|marraqueta|amasado|molde/.test(texto);
            if (filtro === 'leche') return /leche|yogur|yoghurt|lacteo|queso|mantequilla|crema/.test(texto);
            if (filtro === 'cigar') return /cigar|tabaco|kent|marlboro|pall mall|belmont|lucky/.test(texto);
            if (filtro === 'snack') return /snack|papas|ramitas|sufle|galleta|chocolate|dulce|mani/.test(texto);
            return texto.includes(filtro);
        }

        function renderProductosRapidos() {
            const cont = document.getElementById('productosRapidos');
            if (!cont) return;

            const productos = catalogo
                .filter(p => Number(p.stock) > 0 && productoCoincideFiltro(p, filtroRapidoActual))
                .sort((a, b) => {
                    const ofertaA = a.ofertaActiva ? 1 : 0;
                    const ofertaB = b.ofertaActiva ? 1 : 0;
                    return ofertaB - ofertaA || String(a.nombre || '').localeCompare(String(b.nombre || ''), 'es');
                })
                .slice(0, 12);

            if (!productos.length) {
                cont.innerHTML = `
                    <button class="producto-rapido" type="button" disabled>
                        <strong>Sin productos para mostrar</strong>
                        <span>Busca arriba</span>
                    </button>`;
                return;
            }

            cont.innerHTML = productos.map(p => {
                const precio = calcularPrecioAplicable(p, 1).precio;
                const precioLabel = p.vendidoPorPeso ? `$${precio.toLocaleString('es-CL')}/kg` : `$${precio.toLocaleString('es-CL')}`;
                return `
                    <button class="producto-rapido" type="button" onclick="seleccionarSugerencia('${p.codigo}')">
                        <strong>${p.nombre}</strong>
                        <span>${precioLabel}</span>
                    </button>`;
            }).join('');

            if (typeof lucide !== 'undefined') lucide.createIcons();
        }

        // --- CARGAR LISTA DE CLIENTES QUE YA DEBEN ---
        async function cargarSugerenciasFiados() {
            try {
                const res = await fetch('/api/fiados');
                const fiados = await res.json();
                // Filtramos solo los nombres únicos que estén PENDIENTES
                clientesFiadores = [...new Set(fiados.filter(f => f.estado === "PENDIENTE").map(f => f.cliente))];
                
                const datalist = document.getElementById('listaClientesRegistrados');
                datalist.innerHTML = clientesFiadores.map(nombre => `<option value="${nombre}">`).join('');
            } catch (e) { console.error("Error al cargar deudores"); }
        }

        function verificarClienteExistente(input) {
            const nombre = input.value.trim().toUpperCase();
            const aviso = document.getElementById('avisoNuevoCliente');
            if (nombre.length > 0 && !clientesFiadores.includes(nombre)) {
                aviso.style.display = 'block';
            } else {
                aviso.style.display = 'none';
            }
        }

        // --- BUSCADOR INTELIGENTE ---
        inputCaja.addEventListener('input', function() {
            const busqueda = this.value.trim().toLowerCase();
            clearTimeout(timerBusqueda);
            if (busqueda.length < 1) { listaSug.style.display = 'none'; return; }
            const matchExacto = catalogo.find(p => p.codigo.toLowerCase() === busqueda);
            if (matchExacto) {
                timerBusqueda = setTimeout(() => {
                    agregarAlCarrito(matchExacto);
                    inputCaja.value = "";
                    listaSug.style.display = 'none';
                }, 150);
                return;
            }
            const empiezaCon = [];
            const contiene = [];
            catalogo.forEach(p => {
                const nombre = p.nombre.toLowerCase();
                const codigo = p.codigo.toLowerCase();
                if (nombre.startsWith(busqueda) || codigo.startsWith(busqueda)) empiezaCon.push(p);
                else if (nombre.includes(busqueda) || codigo.includes(busqueda)) contiene.push(p);
            });
            const filtrados = [...empiezaCon, ...contiene].slice(0, 12);
            if (filtrados.length > 0) {
                listaSug.innerHTML = filtrados.map(p => {
                    const stockLabel = p.vendidoPorPeso ? `${p.stock} kg` : `${p.stock} un.`;
                    const precioSugerido = calcularPrecioAplicable(p, 1);
                    const precioLabel = p.vendidoPorPeso ? `$${precioSugerido.precio.toLocaleString('es-CL')}/kg` : `$${precioSugerido.precio.toLocaleString('es-CL')}`;
                    const badge = p.vendidoPorPeso ? ' <span style="color:#ff9500;font-size:11px;">⚖️</span>' : '';
                    return `
                    <div class="sugerencia-item" onclick="seleccionarSugerencia('${p.codigo}')">
                        <span>${p.nombre}${badge} <small style="opacity:0.5">(${stockLabel})</small></span>
                        <b>${precioLabel}</b>
                    </div>`;
                }).join('');
                listaSug.style.display = 'block';
            } else { listaSug.style.display = 'none'; }
        });

        function seleccionarSugerencia(codigo) {
            const p = catalogo.find(x => x.codigo === codigo);
            if (p) { agregarAlCarrito(p); inputCaja.value = ""; listaSug.style.display = 'none'; inputCaja.focus(); }
        }

        function calcularPrecioAplicable(producto, cantidad) {
            const precioNormal = Number(producto.precioNormal ?? producto.precio ?? 0);
            const opciones = [{ precio: precioNormal, tipo: 'NORMAL' }];

            if (producto.ofertaActiva && Number(producto.precioOferta) > 0) {
                opciones.push({ precio: Number(producto.precioOferta), tipo: 'OFERTA' });
            }

            if (producto.mayorActivo && Number(producto.cantidadMayor) > 0 && Number(producto.precioMayor) > 0 && cantidad >= Number(producto.cantidadMayor)) {
                opciones.push({ precio: Number(producto.precioMayor), tipo: 'MAYOR' });
            }

            return opciones.reduce((mejor, actual) => actual.precio < mejor.precio ? actual : mejor);
        }

        function aplicarPrecioItem(item) {
            const resultado = calcularPrecioAplicable(item, Number(item.cantidad || 0));
            item.precio = resultado.precio;
            item.tipoPrecio = resultado.tipo;
        }

        function agregarAlCarrito(p) {
            if (p.stock <= 0) return alert("Sin stock");
            if (p.vendidoPorPeso) {
                abrirModalPeso(p);
                return;
            }
            const item = carrito.find(x => x.codigo === p.codigo);
            if (item) {
                if (item.cantidad < p.stock) {
                    item.cantidad++;
                    aplicarPrecioItem(item);
                } else {
                    alert("Limite stock");
                }
            } else {
                const nuevo = {...p, precioNormal: Number(p.precio), cantidad: 1, tipoPrecio: 'NORMAL'};
                aplicarPrecioItem(nuevo);
                carrito.unshift(nuevo);
            }
            actualizarVista();
        }

        function abrirModalPeso(p) {
            productoEsperaPeso = p;
            document.getElementById('modalPesoNombre').innerText = p.nombre;
            document.getElementById('modalPesoPrecioKilo').innerText = p.precio.toLocaleString('es-CL');
            document.getElementById('inputPesoGramos').value = '';
            document.getElementById('inputPesoMonto').value = '';
            document.getElementById('precioCalculadoPeso').innerText = '';
            setModoPesoCaja('gramos');
            document.getElementById('modalPeso').style.display = 'flex';
            setTimeout(() => document.getElementById('inputPesoGramos').focus(), 150);
        }

        let modoPesoCaja = 'gramos';
        function setModoPesoCaja(m) {
            modoPesoCaja = m;
            const btnG = document.getElementById('btnCajaGramos');
            const btnD = document.getElementById('btnCajaDinero');
            const divG = document.getElementById('divCajaGramos');
            const divD = document.getElementById('divCajaDinero');
            const lbl = document.getElementById('lblResultadoCaja');

            if (m === 'gramos') {
                btnG.style.background = 'white'; btnG.style.color = 'var(--azul-gvi)';
                btnD.style.background = 'transparent'; btnD.style.color = '#666';
                divG.style.display = 'block'; divD.style.display = 'none';
                lbl.innerText = 'Total a Cobrar';
                document.getElementById('inputPesoGramos').focus();
            } else {
                btnD.style.background = 'white'; btnD.style.color = '#34c759';
                btnG.style.background = 'transparent'; btnG.style.color = '#666';
                divD.style.display = 'block'; divG.style.display = 'none';
                lbl.innerText = 'Gramos Correspondientes';
                document.getElementById('inputPesoMonto').focus();
            }
            calcularPrecioEnVivo();
        }

        function cerrarModalPeso() {
            document.getElementById('modalPeso').style.display = 'none';
            productoEsperaPeso = null;
            inputCaja.focus();
        }

        function calcularPrecioEnVivo() {
            if (!productoEsperaPeso) return;
            const resEl = document.getElementById('precioCalculadoPeso');
            const pKilo = Number(productoEsperaPeso.precio);

            if (modoPesoCaja === 'gramos') {
                const g = Number(document.getElementById('inputPesoGramos').value);
                if (!g || g <= 0) { resEl.innerText = ''; return; }
                const kg = g / 1000;
                const precioAplicado = calcularPrecioAplicable(productoEsperaPeso, kg);
                const total = Math.round(precioAplicado.precio * kg);
                resEl.innerText = `$${total.toLocaleString('es-CL')}${precioAplicado.tipo !== 'NORMAL' ? ` (${precioAplicado.tipo})` : ''}`;
            } else {
                const monto = Number(document.getElementById('inputPesoMonto').value);
                if (!monto || monto <= 0) { resEl.innerText = ''; return; }
                const g = Math.round((monto / pKilo) * 1000);
                resEl.innerText = `${g}g`;
            }
        }

        function confirmarPeso() {
            let gramos = 0;
            if (modoPesoCaja === 'gramos') {
                gramos = Number(document.getElementById('inputPesoGramos').value);
            } else {
                const monto = Number(document.getElementById('inputPesoMonto').value);
                if (monto > 0) gramos = Math.round((monto / productoEsperaPeso.precio) * 1000);
            }

            if (!gramos || gramos <= 0) return alert('⚠️ Ingresa un valor válido.');
            const pesoKg = gramos / 1000;
            if (pesoKg > productoEsperaPeso.stock) return alert(`⚠️ Stock insuficiente. Solo hay ${productoEsperaPeso.stock} kg disponibles.`);

            const nuevoPeso = {
                ...productoEsperaPeso,
                precioNormal: Number(productoEsperaPeso.precio),
                cantidad: pesoKg,
                pesoGramos: gramos,
                vendidoPorPeso: true
            };
            aplicarPrecioItem(nuevoPeso);
            carrito.unshift(nuevoPeso);
            actualizarVista();
            cerrarModalPeso();
        }

        function actualizarVista() {
            const tbody = document.getElementById('listaCarrito');
            tbody.innerHTML = "";
            totalCaja = 0;
            let unidadesCaja = 0;
            carrito.forEach((item, index) => {
                if (item.codigo !== 'MANUAL') aplicarPrecioItem(item);
                const subtotal = item.precio * item.cantidad;
                totalCaja += subtotal;
                unidadesCaja += Number(item.cantidad || 0);
                const precioBadge = item.tipoPrecio === 'OFERTA'
                    ? '<span class="badge-precio-carrito badge-precio-oferta">OFERTA</span>'
                    : (item.tipoPrecio === 'MAYOR' ? '<span class="badge-precio-carrito badge-precio-mayor">MAYOR</span>' : '');

                let cantidadCell, precioCell;
                if (item.vendidoPorPeso) {
                    cantidadCell = `<td>⚖️ ${item.pesoGramos}g</td>`;
                    precioCell = `<td><span class="precio-editable">$${item.precio.toLocaleString('es-CL')}/kg <button class="btn-editar-precio" onclick="editarPrecioCarrito(${index})" title="Editar precio">✎</button></span></td>`;
                } else {
                    cantidadCell = `<td><div class="control-cant"><button class="btn-cant" onclick="cambiarCant(${index},-1)">-</button><b>${item.cantidad}</b><button class="btn-cant" onclick="cambiarCant(${index},1)">+</button></div></td>`;
                    precioCell = `<td><span class="precio-editable">$${item.precio.toLocaleString('es-CL')} <button class="btn-editar-precio" onclick="editarPrecioCarrito(${index})" title="Editar precio">✎</button></span></td>`;
                }

                tbody.innerHTML += `<tr>
                    <td><b>${item.nombre}</b>${item.vendidoPorPeso ? '<span class="badge-peso">⚖️ PESO</span>' : ''}${precioBadge}<br><small>${item.codigo}</small></td>
                    ${cantidadCell}
                    ${precioCell}
                    <td><b>$${subtotal.toLocaleString('es-CL')}</b></td>
                    <td><button onclick="carrito.splice(${index},1); actualizarVista()" style="border:none; background:transparent; cursor:pointer;">❌</button></td>
                </tr>`;
            });
            if (carrito.length === 0) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="5" class="empty-carrito">
                            <div class="empty-carrito-box">
                                <i data-lucide="scan-barcode"></i>
                                <strong>Escanea un producto para comenzar</strong>
                                <span>Tambien puedes usar venta manual o tocar un producto rapido.</span>
                            </div>
                        </td>
                    </tr>`;
            }
            document.getElementById('txtTotal').innerText = "$" + totalCaja.toLocaleString('es-CL');
            document.getElementById('btnCobrar').disabled = carrito.length === 0;
            document.getElementById('ventaItems').innerText = carrito.length;
            document.getElementById('ventaUnidades').innerText = Number(unidadesCaja.toFixed(3)).toLocaleString('es-CL');
            document.getElementById('cobroEstado').innerText = carrito.length ? `${carrito.length} producto${carrito.length === 1 ? '' : 's'}` : 'Sin productos';
            document.getElementById('txtResumenCobro').innerText = carrito.length
                ? `${Number(unidadesCaja.toFixed(3)).toLocaleString('es-CL')} unidad${unidadesCaja === 1 ? '' : 'es'} en esta venta`
                : 'Agrega productos para habilitar el cobro';
            if (typeof lucide !== 'undefined') lucide.createIcons();
        }

        function cancelarVentaActual() {
            if (carrito.length === 0) {
                inputCaja.focus();
                return;
            }
            if (!confirm('Cancelar la venta actual y vaciar el carrito?')) return;
            carrito = [];
            actualizarVista();
            inputCaja.focus();
        }

        function formatearPrecioEditor(input) {
            const valor = input.value.replace(/\D/g, '');
            input.value = valor === '' ? '' : '$' + Number(valor).toLocaleString('es-CL');
        }

        function editarPrecioCarrito(index) {
            const item = carrito[index];
            if (!item) return;

            indicePrecioEditando = index;
            document.getElementById('editarPrecioProducto').innerText = `${item.nombre} · Precio actual: $${Number(item.precio).toLocaleString('es-CL')}${item.vendidoPorPeso ? '/kg' : ''}`;
            document.getElementById('editarPrecioPin').value = '';
            document.getElementById('editarPrecioValor').value = '$' + Number(item.precio).toLocaleString('es-CL');
            document.getElementById('editarPrecioError').innerText = '';
            document.getElementById('modalEditarPrecio').style.display = 'flex';
            setTimeout(() => document.getElementById('editarPrecioPin').focus(), 120);
        }

        function cerrarModalEditarPrecio() {
            document.getElementById('modalEditarPrecio').style.display = 'none';
            indicePrecioEditando = null;
            inputCaja.focus();
        }

        async function confirmarEditarPrecio() {
            const item = carrito[indicePrecioEditando];
            if (!item) return cerrarModalEditarPrecio();

            const pin = document.getElementById('editarPrecioPin').value.trim();
            const nuevoPrecio = Number(document.getElementById('editarPrecioValor').value.replace(/\D/g, ''));
            const errorEl = document.getElementById('editarPrecioError');

            if (!pin) {
                errorEl.innerText = 'Ingresa el PIN de administrador.';
                document.getElementById('editarPrecioPin').focus();
                return;
            }

            if (!nuevoPrecio || nuevoPrecio <= 0) {
                errorEl.innerText = 'Ingresa un precio valido.';
                document.getElementById('editarPrecioValor').focus();
                return;
            }

            try {
                const auth = await fetch('/api/verify-admin', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ pin })
                });
                const authData = await auth.json();
                if (!authData.success) {
                    errorEl.innerText = 'PIN de administrador incorrecto.';
                    document.getElementById('editarPrecioPin').select();
                    return;
                }
            } catch (e) {
                errorEl.innerText = 'No se pudo verificar el PIN.';
                return;
            }

            if (item.codigo !== 'MANUAL') {
                const productoBase = catalogo.find(p => p.codigo === item.codigo) || item;
                try {
                    const productoActualizado = {
                        ...productoBase,
                        precio: nuevoPrecio,
                        precioNormal: nuevoPrecio,
                        ofertaActiva: false,
                        precioOferta: 0,
                        mayorActivo: false,
                        cantidadMayor: 0,
                        precioMayor: 0
                    };
                    const res = await fetch(`/api/productos/${encodeURIComponent(item.codigo)}`, {
                        method: 'PUT',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify(productoActualizado)
                    });
                    if (!res.ok) {
                        errorEl.innerText = 'No se pudo actualizar el precio en bodega.';
                        return;
                    }
                    await cargarCatalogo();
                } catch (e) {
                    errorEl.innerText = 'Error de red actualizando el precio.';
                    return;
                }
            }

            item.precio = nuevoPrecio;
            item.precioNormal = nuevoPrecio;
            item.ofertaActiva = false;
            item.precioOferta = 0;
            item.mayorActivo = false;
            item.cantidadMayor = 0;
            item.precioMayor = 0;
            item.tipoPrecio = 'NORMAL';
            actualizarVista();
            cerrarModalEditarPrecio();
        }

        function cambiarCant(i, n) {
            const item = carrito[i];
            const nuevo = item.cantidad + n;
            if (nuevo <= 0) carrito.splice(i, 1);
            else if (nuevo <= item.stock) {
                item.cantidad = nuevo;
                if (item.codigo !== 'MANUAL') aplicarPrecioItem(item);
            }
            actualizarVista();
        }

        // --- CIERRE DE VENTA ---
        function abrirModalFinalizar() {
            document.getElementById('modalFinalizar').style.display = 'flex';
            document.getElementById('totalModal').innerText = "$" + totalCaja.toLocaleString('es-CL');
            document.getElementById('inputPagoModal').value = "";
            document.getElementById('vueltoModal').innerText = "$0";
            document.getElementById('estadoPagoTexto').innerText = "Vuelto:";
            document.getElementById('estadoPagoModal').style.color = "#34c759";
            document.getElementById('nombreClienteFiado').value = "";
            document.getElementById('avisoNuevoCliente').style.display = 'none';
            setMetodo('Efectivo');
            if (typeof lucide !== 'undefined') lucide.createIcons();
            setTimeout(() => document.getElementById('inputPagoModal').focus(), 150);
        }

        function cerrarModalFinalizar() { document.getElementById('modalFinalizar').style.display = 'none'; }

        function setMetodo(m) {
            metodoPagoActual = m;
            document.getElementById('btnEfec').classList.toggle('activo', m === 'Efectivo');
            document.getElementById('btnTarj').classList.toggle('activo', m === 'Tarjeta');
            document.getElementById('btnFiado').classList.toggle('activo', m === 'Fiado');
            
            document.getElementById('seccionEfectivo').style.display = (m === 'Efectivo') ? 'block' : 'none';
            document.getElementById('seccionFiado').style.display = (m === 'Fiado') ? 'block' : 'none';
            
            // Si es FIADO, ocultamos el botón de imprimir y cargamos nombres
            document.getElementById('btnGuardarImprimir').style.display = (m === 'Fiado') ? 'none' : '';
            const textoSoloGuardar = document.getElementById('btnSoloGuardarTexto');
            if (textoSoloGuardar) textoSoloGuardar.innerText = (m === 'Fiado') ? 'Anotar fiado' : 'Solo guardar';
            if (typeof lucide !== 'undefined') lucide.createIcons();

            if(m === 'Fiado') {
                cargarSugerenciasFiados();
                setTimeout(() => document.getElementById('nombreClienteFiado').focus(), 150);
            }
            if(m === 'Efectivo') setTimeout(() => document.getElementById('inputPagoModal').focus(), 150);
        }

        function formatearVuelto(input) {
            let valor = input.value.replace(/\D/g, "");
            input.value = valor === "" ? "" : "$" + Number(valor).toLocaleString('es-CL');
            let pago = Number(valor);
            let vuelto = pago - totalCaja;
            const estado = document.getElementById('estadoPagoModal');
            const texto = document.getElementById('estadoPagoTexto');
            if (!pago || pago >= totalCaja) {
                texto.innerText = "Vuelto:";
                estado.style.color = "#34c759";
                document.getElementById('vueltoModal').innerText = "$" + Math.max(0, vuelto).toLocaleString('es-CL');
            } else {
                texto.innerText = "Faltan:";
                estado.style.color = "#ff3b30";
                document.getElementById('vueltoModal').innerText = "$" + Math.abs(vuelto).toLocaleString('es-CL');
            }
        }

        async function procesarVentaReal(imprimir) {
            if(metodoPagoActual === 'Fiado') {
                const cliente = document.getElementById('nombreClienteFiado').value.trim().toUpperCase();
                if(!cliente) return alert("❌ Debes ingresar el nombre del cliente.");

                try {
                    const res = await fetch('/api/fiados', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({ cliente, items: carrito, total: totalCaja })
                    });
                    const r = await res.json();
                    if(r.success) {
                        alert(`📓 Cuenta de ${cliente} actualizada.`);
                        finalizarTodo();
                    }
                } catch (e) { alert("Error de red"); }
                return;
            }

            let pago = metodoPagoActual === 'Efectivo' ? Number(document.getElementById('inputPagoModal').value.replace(/\D/g, "")) : totalCaja;
            if (metodoPagoActual === 'Efectivo' && pago < totalCaja) return alert("Pago insuficiente");

            const datos = { items: carrito, total: totalCaja, metodoPago: metodoPagoActual, pagoCon: pago, vuelto: pago - totalCaja };

            try {
                const res = await fetch('/api/vender', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify(datos)
                });
                const r = await res.json();
                if (r.success) {
                    if (imprimir) generarTicketPrint(r.ventaId, datos);
                    finalizarTodo();
                }
            } catch (e) { alert("Error de red"); }
        }

        function finalizarTodo() {
            carrito = []; actualizarVista(); cargarCatalogo(); cerrarModalFinalizar(); inputCaja.focus();
        }

        function generarTicketPrint(id, datos) {
            const fecha = new Date().toLocaleString();
            document.getElementById('areaImpresion').innerHTML = `
                <div style="font-family:'Courier New', monospace; width:100%; color:#000; font-weight:800; line-height:1.22;">
                    <div style="text-align:center; font-size:18px; font-weight:900;">GVI MINIMARKET</div>
                    <div style="text-align:center; font-size:12px; font-weight:900; margin-top:3px;">#${id}</div>
                    <div style="text-align:center; font-size:11px; font-weight:900; margin-top:2px;">${fecha}</div>
                    <div style="border-top:2px solid #000; margin:8px 0;"></div>
                    <div style="font-size:12px; font-weight:900;">Metodo: ${datos.metodoPago}</div>
                    <div style="border-top:2px solid #000; margin:8px 0;"></div>
                    <table style="width:100%; border-collapse:collapse; table-layout:fixed; font-size:12px; font-weight:900;">
                        ${datos.items.map(i => {
                            const cant = i.vendidoPorPeso ? `${i.pesoGramos}g` : `${i.cantidad}`;
                            return `<tr>
                                <td style="width:68%; padding:5px 0; white-space:nowrap; overflow:hidden; font-weight:900;">${cant} x ${String(i.nombre || '').substring(0,18)}</td>
                                <td style="width:32%; padding:5px 0; text-align:right; white-space:nowrap; font-weight:900;">$${(Number(i.precio || 0)*Number(i.cantidad || 0)).toLocaleString('es-CL')}</td>
                            </tr>`;
                        }).join('')}
                    </table>
                    <div style="border-top:2px solid #000; margin:8px 0;"></div>
                    <table style="width:100%; border-collapse:collapse; table-layout:fixed; font-size:14px; font-weight:900;">
                        <tr>
                            <td style="font-weight:900;">Total:</td>
                            <td style="text-align:right; white-space:nowrap; font-weight:900;">$${Number(datos.total || 0).toLocaleString('es-CL')}</td>
                        </tr>
                        ${datos.metodoPago === 'Efectivo' ? `<tr>
                            <td style="font-size:12px; font-weight:900; padding-top:3px;">Vuelto:</td>
                            <td style="font-size:12px; text-align:right; white-space:nowrap; font-weight:900; padding-top:3px;">$${Number(datos.vuelto || 0).toLocaleString('es-CL')}</td>
                        </tr>` : ''}
                    </table>
                    <div style="border-top:2px solid #000; margin:8px 0;"></div>
                    <div style="text-align:center; font-size:12px; font-weight:900;">Muchas gracias por su compra</div>
                </div>`;
            window.print();
        }

        document.addEventListener('click', (e) => {
            if (!listaSug.contains(e.target) && e.target !== inputCaja) {
                listaSug.style.display = 'none';
                programarRefocoSku();
            }
        });
 
        document.getElementById('inputPesoGramos').addEventListener('keydown', (e) => {
            if (e.key === 'Enter') confirmarPeso();
            if (e.key === 'Escape') cerrarModalPeso();
        });

        ['editarPrecioPin', 'editarPrecioValor'].forEach(id => {
            document.getElementById(id).addEventListener('keydown', (e) => {
                if (e.key === 'Enter') confirmarEditarPrecio();
                if (e.key === 'Escape') cerrarModalEditarPrecio();
            });
        });

        document.addEventListener('DOMContentLoaded', () => {
            restaurarModoFocoCaja();
            cargarCatalogo();
        });
    </script>
</body>
</html>
