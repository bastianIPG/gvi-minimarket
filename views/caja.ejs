<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>GVI - Punto de Venta</title>
    <style>
        .caja-header { display: flex; justify-content: space-between; align-items: center; margin-top: 40px; margin-bottom: 20px; }
        .caja-header h1 { font-size: 32px; margin: 0; display: flex; align-items: center; gap: 10px; }
        
        .caja-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; align-items: start; }

        .panel-ticket { background: var(--panel-claro); border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); overflow: hidden; display: flex; flex-direction: column; min-height: 65vh; }
        body.dark-mode .panel-ticket { background: var(--panel-oscuro); }
        
        .buscador-caja { padding: 20px; background: rgba(0,0,0,0.02); border-bottom: 1px solid #eee; display: flex; gap: 15px; position: relative; }
        body.dark-mode .buscador-caja { background: rgba(255,255,255,0.02); border-bottom-color: #333; }
        .input-barras { flex: 1; padding: 15px; font-size: 18px; border-radius: 10px; border: 2px solid var(--azul-gvi); outline: none; background: transparent; color: inherit; font-family: monospace; }
        
        /* --- ESTILOS SUGERENCIAS --- */
        .sugerencias-busqueda {
            position: absolute;
            top: 100%; left: 20px; right: 20px;
            background: var(--panel-claro);
            border: 1px solid #ddd;
            border-radius: 0 0 10px 10px;
            z-index: 1000;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            max-height: 280px;
            overflow-y: auto;
            display: none;
        }
        body.dark-mode .sugerencias-busqueda { background: #252525; border-color: #444; }
        .sugerencia-item {
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            cursor: pointer;
            border-bottom: 1px solid #eee;
        }
        body.dark-mode .sugerencia-item { border-bottom-color: #333; }
        .sugerencia-item:hover { background: rgba(0,122,255,0.1); }
        .sugerencia-item b { color: var(--azul-gvi); }

        table { width: 100%; border-collapse: collapse; text-align: left; }
        th, td { padding: 15px 20px; border-bottom: 1px solid #eee; }
        body.dark-mode th, body.dark-mode td { border-bottom-color: #333; }
        th { background: rgba(0,0,0,0.02); font-weight: 600; color: #666; text-transform: uppercase; font-size: 12px; }
        
        .control-cant { display: flex; align-items: center; gap: 10px; }
        .btn-cant { background: #eee; border: none; width: 32px; height: 32px; border-radius: 8px; cursor: pointer; font-weight: bold; transition: background-color 0.14s ease, color 0.14s ease; }
        body.dark-mode .btn-cant { background: #444; color: white; }

        .panel-cobro { background: var(--panel-claro); border-radius: 15px; padding: 30px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); position: sticky; top: 20px; }
        body.dark-mode .panel-cobro { background: var(--panel-oscuro); }
        
        .caja-total { font-size: 55px; font-weight: 900; color: var(--azul-gvi); margin: 10px 0 20px; text-align: center; }
        
        .btn-cobrar { width: 100%; background: #34c759; color: white; border: none; padding: 20px; font-size: 22px; font-weight: bold; border-radius: 12px; cursor: pointer; transition: background-color 0.16s ease, opacity 0.16s ease; }
        .btn-cobrar:disabled { background: #ccc; opacity: 0.5; cursor: not-allowed; }

        .metodos-pago-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin: 25px 0; }
        .btn-metodo { padding: 15px 10px; border-radius: 12px; border: 2px solid #eee; background: transparent; cursor: pointer; font-weight: 800; font-size: 14px; color: inherit; transition: border-color 0.14s ease, background-color 0.14s ease, color 0.14s ease; }
        body.dark-mode .btn-metodo { border-color: #333; }
        .btn-metodo.activo { border-color: var(--azul-gvi); background: rgba(0, 122, 255, 0.1); color: var(--azul-gvi); }
        .btn-metodo.fiado-color { border-color: #ff9500; color: #ff9500; }
        .btn-metodo.fiado-color.activo { background: rgba(255, 149, 0, 0.1); }

        .badge-peso { display: inline-block; background: rgba(255,149,0,0.15); color: #ff9500; font-size: 11px; font-weight: 800; padding: 2px 8px; border-radius: 20px; margin-left: 6px; vertical-align: middle; }

        .badge-precio-carrito {
            display: inline-flex;
            align-items: center;
            margin-left: 6px;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 900;
            vertical-align: middle;
        }

        .badge-precio-oferta { background: rgba(255,59,48,0.1); color: #ff3b30; }
        .badge-precio-mayor { background: rgba(0,122,255,0.1); color: var(--azul-gvi); }

        .precio-editable {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 800;
        }

        .btn-editar-precio {
            width: 28px;
            height: 28px;
            border: none;
            border-radius: 8px;
            background: rgba(0, 122, 255, 0.1);
            color: var(--azul-gvi);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 900;
            transition: background-color 0.14s ease, color 0.14s ease;
        }

        .btn-editar-precio:hover {
            background: var(--azul-gvi);
            color: white;
        }

        .modal-precio-panel {
            width: min(430px, calc(100vw - 32px));
            padding: 0;
            overflow: hidden;
            border-radius: 22px;
        }

        .modal-precio-header {
            padding: 22px 24px 18px;
            background: linear-gradient(135deg, rgba(0,122,255,0.12), rgba(52,199,89,0.08));
            border-bottom: 1px solid rgba(0,0,0,0.06);
            display: flex;
            align-items: center;
            gap: 14px;
        }

        body.dark-mode .modal-precio-header { border-bottom-color: #333; }

        .modal-precio-icon {
            width: 44px;
            height: 44px;
            border-radius: 14px;
            background: var(--azul-gvi);
            color: white;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
            box-shadow: 0 6px 14px rgba(0,122,255,0.24);
        }

        .modal-precio-icon svg { width: 24px; height: 24px; }

        .modal-precio-title h3 {
            margin: 0;
            font-size: 22px;
            line-height: 1.1;
        }

        .modal-precio-title span {
            display: block;
            margin-top: 5px;
            font-size: 12px;
            font-weight: 800;
            opacity: 0.55;
            text-transform: uppercase;
        }

        .modal-precio-body { padding: 22px 24px 24px; }

        .producto-precio-card {
            background: rgba(0,122,255,0.06);
            border: 1px solid rgba(0,122,255,0.12);
            border-radius: 16px;
            padding: 14px 16px;
            margin-bottom: 18px;
        }

        body.dark-mode .producto-precio-card {
            background: rgba(0,122,255,0.1);
            border-color: rgba(255,255,255,0.08);
        }

        .producto-precio-card span {
            display: block;
            font-size: 11px;
            font-weight: 900;
            opacity: 0.55;
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .producto-precio-card b {
            display: block;
            font-size: 16px;
            line-height: 1.25;
        }

        .precio-field {
            margin-bottom: 14px;
        }

        .precio-field label {
            display: block;
            margin-bottom: 7px;
            font-size: 12px;
            font-weight: 900;
            opacity: 0.65;
            text-transform: uppercase;
        }

        .precio-input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .precio-input-wrap i,
        .precio-input-wrap svg {
            position: absolute;
            left: 14px;
            width: 19px;
            height: 19px;
            color: var(--azul-gvi);
            opacity: 0.75;
        }

        .precio-input-wrap .form-input {
            padding-left: 44px !important;
            min-height: 54px;
            border-radius: 14px;
        }

        #editarPrecioPin {
            letter-spacing: 7px;
            text-align: center;
        }

        #editarPrecioValor {
            color: var(--azul-gvi);
            font-size: 25px;
            font-weight: 900;
            text-align: center;
        }

        .modal-precio-actions {
            display: grid;
            grid-template-columns: 0.9fr 1.2fr;
            gap: 10px;
            margin-top: 8px;
        }

        .modal-cobro-panel {
            width: min(560px, calc(100vw - 32px));
            padding: 0;
            overflow: hidden;
            border-radius: 22px;
            text-align: left;
        }

        .modal-cobro-header {
            padding: 24px 26px 20px;
            background: linear-gradient(135deg, rgba(0,122,255,0.12), rgba(52,199,89,0.1));
            border-bottom: 1px solid rgba(0,0,0,0.06);
            text-align: center;
        }

        body.dark-mode .modal-cobro-header { border-bottom-color: #333; }

        .modal-cobro-header span {
            display: block;
            font-size: 12px;
            font-weight: 900;
            opacity: 0.58;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .modal-cobro-total {
            margin-top: 6px;
            font-size: clamp(42px, 7vw, 58px);
            line-height: 1;
            font-weight: 950;
            color: var(--azul-gvi);
        }

        .modal-cobro-body {
            padding: 22px 26px 26px;
        }

        .metodos-cobro {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
            margin-bottom: 18px;
        }

        .metodos-cobro .btn-metodo {
            min-height: 58px;
            padding: 10px 8px;
            border-radius: 16px;
            background: rgba(0,0,0,0.025);
            border-width: 2px;
        }

        body.dark-mode .metodos-cobro .btn-metodo { background: rgba(255,255,255,0.04); }

        .campo-pago-card {
            background: rgba(0,0,0,0.025);
            border: 1px solid rgba(0,0,0,0.06);
            border-radius: 18px;
            padding: 16px;
        }

        body.dark-mode .campo-pago-card {
            background: rgba(255,255,255,0.04);
            border-color: rgba(255,255,255,0.08);
        }

        .campo-pago-card label {
            display: block;
            margin-bottom: 8px;
            font-size: 12px;
            font-weight: 900;
            opacity: 0.62;
            text-transform: uppercase;
        }

        .pago-input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .pago-input-wrap i,
        .pago-input-wrap svg {
            position: absolute;
            left: 15px;
            width: 21px;
            height: 21px;
            color: var(--azul-gvi);
            opacity: 0.8;
        }

        .pago-input-wrap .form-input {
            min-height: 58px;
            padding-left: 48px !important;
            border-radius: 15px;
            font-size: 24px;
            font-weight: 900;
            text-align: center;
        }

        .vuelto-card {
            margin-top: 12px;
            padding: 12px 14px;
            border-radius: 14px;
            background: rgba(52,199,89,0.1);
            color: #2eb84e;
            display: flex;
            align-items: center;
            justify-content: space-between;
            font-weight: 900;
            font-size: 20px;
        }

        .vuelto-card span:first-child {
            font-size: 12px;
            text-transform: uppercase;
            opacity: 0.75;
        }

        .fiado-card {
            background: rgba(255,149,0,0.08);
            border: 1px solid rgba(255,149,0,0.18);
            border-radius: 18px;
            padding: 16px;
        }

        .acciones-cobro {
            display: grid;
            grid-template-columns: 0.85fr 1fr 1.25fr;
            gap: 10px;
            margin-top: 18px;
        }

        .acciones-cobro button {
            min-height: 58px;
            border-radius: 14px !important;
        }

        #modalFinalizar #seccionEfectivo > input {
            width: 100%;
            min-height: 58px;
            border-radius: 15px !important;
            border: 2px solid rgba(0,122,255,0.22) !important;
            background: var(--panel-claro);
            font-size: 24px !important;
            font-weight: 900 !important;
            text-align: center !important;
            color: inherit;
        }

        body.dark-mode #modalFinalizar #seccionEfectivo > input { background: rgba(255,255,255,0.05); }

        #modalFinalizar #seccionEfectivo > input::placeholder {
            color: rgba(28,30,33,0.42);
            font-size: 20px;
            font-weight: 800;
        }

        #modalFinalizar #seccionEfectivo > div {
            margin-top: 12px !important;
            padding: 12px 14px;
            border-radius: 14px;
            background: rgba(52,199,89,0.1);
            color: #2eb84e;
            font-size: 20px !important;
            font-weight: 900 !important;
            text-align: center;
        }

        #modalFinalizar #seccionFiado {
            background: rgba(255,149,0,0.08);
            border: 1px solid rgba(255,149,0,0.18);
            border-radius: 18px;
            padding: 16px;
        }

        .btn-manual-rapido {
            background: var(--azul-gvi);
            color: white;
            border: none;
            padding: 0 20px;
            border-radius: 10px;
            font-weight: 800;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: background-color 0.16s ease, filter 0.16s ease;
        }
        .btn-manual-rapido:hover { filter: brightness(1.08); }
        .btn-manual-rapido i { width: 18px; height: 18px; }

        @media print {
            @page { margin: 0; size: 80mm auto; }
            body * { display: none !important; }
            #areaImpresion { display: block !important; }
            #areaImpresion div { display: block !important; }
            #areaImpresion table { display: table !important; }
            #areaImpresion tbody { display: table-row-group !important; }
            #areaImpresion tr { display: table-row !important; }
            #areaImpresion td { display: table-cell !important; }
            #areaImpresion span { display: inline !important; }
            #areaImpresion {
                position: absolute;
                left: 0;
                top: 0;
                width: 68mm;
                padding: 3mm 4mm;
                color: #000 !important;
                background: #fff !important;
                font-family: "Courier New", monospace !important;
                font-weight: 800 !important;
                box-sizing: border-box;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/nav') %>

    <div class="contenedor">
        <div class="caja-header">
            <h1><span>🛒</span> Punto de Venta</h1>
        </div>

        <div class="caja-grid">
            <div class="panel-ticket">
                <div class="buscador-caja">
                    <div style="position: relative; flex: 1; display: flex; align-items: center;">
                        <i data-lucide="search" style="position: absolute; left: 15px; opacity: 0.4;"></i>
                        <input type="text" id="inputCodigoCaja" class="input-barras" placeholder="Escanear o buscar producto..." autocomplete="off" autofocus style="padding-left: 45px;">
                        <div id="listaSugerencias" class="sugerencias-busqueda"></div>
                    </div>
                    <button class="btn-manual-rapido" onclick="abrirModalManual()" title="Venta Manual">
                        <i data-lucide="plus-square"></i> Manual
                    </button>
                </div>
                
                <div style="flex: 1; overflow-y: auto;">
                    <table>
                        <thead>
                            <tr><th>Producto</th><th>Cant.</th><th>Precio</th><th>Subtotal</th><th></th></tr>
                        </thead>
                        <tbody id="listaCarrito">
                            <tr><td colspan="5" style="text-align: center; padding: 40px; opacity: 0.5;">Esperando productos...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="panel-cobro">
                <div style="font-size: 14px; font-weight: 800; opacity: 0.5; text-transform: uppercase; text-align: center;">Total a Pagar</div>
                <div class="caja-total" id="txtTotal">$0</div>
                <button class="btn-cobrar" id="btnCobrar" onclick="abrirModalFinalizar()" disabled>💵 COBRAR</button>
            </div>
        </div>
    </div>

    <div id="modalFinalizar" class="modal-fondo">
        <div class="panel modal-cobro-panel">
            <div class="modal-cobro-header">
                <span>Resumen de venta</span>
                <div class="modal-cobro-total" id="totalModal">$0</div>
            </div>
            <div class="modal-cobro-body">

            <div class="metodos-cobro">
                <button class="btn-metodo activo" id="btnEfec" onclick="setMetodo('Efectivo')">💵 EFECTIVO</button>
                <button class="btn-metodo" id="btnTarj" onclick="setMetodo('Tarjeta')">💳 TARJETA</button>
                <button class="btn-metodo fiado-color" id="btnFiado" onclick="setMetodo('Fiado')">📓 FIADO</button>
            </div>

            <div id="seccionEfectivo" class="campo-pago-card">
                <input type="text" id="inputPagoModal" class="form-input" placeholder="¿Cuánto entrega el cliente?" 
                       oninput="formatearVuelto(this)" style="font-size: 24px; text-align: center; font-weight: bold;">
                <div id="estadoPagoModal" style="margin-top: 15px; font-size: 22px; font-weight: 800; color: #34c759;">
                    <span id="estadoPagoTexto">Vuelto:</span> <span id="vueltoModal">$0</span>
                </div>
            </div>

            <div id="seccionFiado" style="display: none; text-align: left;">
                <label style="font-size: 11px; font-weight: 800; opacity: 0.6; display: block; margin-bottom: 5px;">BUSCAR O REGISTRAR CLIENTE</label>
                <input type="text" id="nombreClienteFiado" class="form-input" placeholder="Escribe el nombre del cliente..." 
                       list="listaClientesRegistrados" autocomplete="off"
                       style="font-size: 18px; text-align: center; border-color: #ff9500; text-transform: uppercase;"
                       oninput="verificarClienteExistente(this)">
                
                <datalist id="listaClientesRegistrados"></datalist>

                <div id="avisoNuevoCliente" style="display:none; margin-top:10px; color:#ff9500; font-size:12px; font-weight:bold; text-align:center;">
                    ⚠️ Cliente nuevo: se creará una cuenta nueva.
                </div>
            </div>

            <div class="acciones-cobro">
                <button class="btn-cancelar" style="flex: 1;" onclick="cerrarModalFinalizar()">Cancelar</button>
                <button class="btn-cancelar" id="btnSoloGuardar" style="flex: 1.5;" onclick="procesarVentaReal(false)">Solo Guardar</button>
                <button class="btn-success" id="btnGuardarImprimir" style="flex: 2;" onclick="procesarVentaReal(true)">✅ Guardar e Imprimir</button>
            </div>
            </div>
        </div>
    </div>

    <div id="modalPeso" class="modal-fondo">
        <!-- ... (Contenido del modal peso se mantiene igual) ... -->
        <div class="panel" style="width: 420px; padding: 35px; text-align: center;">
            <div style="font-size: 50px; margin-bottom: 5px;">⚖️</div>
            <h3 id="modalPesoNombre" style="margin: 0 0 5px; font-size: 20px;"></h3>
            <p style="opacity: 0.5; margin: 0 0 15px; font-size: 14px;">Precio: $<span id="modalPesoPrecioKilo">0</span> por kilo</p>
            
            <div style="display: flex; background: rgba(0,0,0,0.05); border-radius: 10px; padding: 4px; margin-bottom: 20px;">
                <button id="btnCajaGramos" onclick="setModoPesoCaja('gramos')" style="flex:1; border:none; padding:10px; border-radius:8px; font-weight:800; cursor:pointer; background:white; color:var(--azul-gvi);">POR GRAMOS</button>
                <button id="btnCajaDinero" onclick="setModoPesoCaja('dinero')" style="flex:1; border:none; padding:10px; border-radius:8px; font-weight:800; cursor:pointer; background:transparent; color:#666;">POR DINERO ($)</button>
            </div>

            <div id="divCajaGramos">
                <input type="number" id="inputPesoGramos" class="input-barras"
                       placeholder="Gramos (ej: 500)" min="1" step="1"
                       oninput="calcularPrecioEnVivo('gramos')"
                       style="text-align: center; font-size: 28px; margin-bottom: 15px; width: 100%; box-sizing: border-box;">
            </div>

            <div id="divCajaDinero" style="display:none;">
                <input type="number" id="inputPesoMonto" class="input-barras"
                       placeholder="Monto $ (ej: 1000)" min="1" step="1"
                       oninput="calcularPrecioEnVivo('dinero')"
                       style="text-align: center; font-size: 28px; margin-bottom: 15px; width: 100%; box-sizing: border-box; border-color: #34c759;">
            </div>

            <div style="margin: 15px 0; padding: 15px; background: rgba(0,122,255,0.05); border-radius: 12px;">
                <div style="font-size: 13px; opacity: 0.6; font-weight: 700; text-transform: uppercase;" id="lblResultadoCaja">Total a Cobrar</div>
                <div style="font-size: 32px; font-weight: 900; color: var(--azul-gvi); min-height: 40px;" id="precioCalculadoPeso"></div>
            </div>
            <div style="display: flex; gap: 10px; margin-top: 25px;">
                <button class="btn-cancelar" style="flex: 1;" onclick="cerrarModalPeso()">Cancelar</button>
                <button class="btn-accion" style="flex: 1.7;" onclick="confirmarPeso()">⚖️ Agregar al Carrito</button>
            </div>
        </div>
    </div>

    <!-- MODAL VENTA MANUAL -->
    <div id="modalManual" class="modal-fondo">
        <div class="panel" style="width: 400px; padding: 35px;">
            <h3 style="margin-top: 0; display: flex; align-items: center; gap: 10px;">
                <i data-lucide="plus-square" style="color: var(--azul-gvi);"></i> Producto Manual
            </h3>
            <p style="opacity: 0.5; font-size: 13px; margin-bottom: 20px;">Agrega un monto directo a la venta.</p>
            
            <div style="margin-bottom: 15px;">
                <label class="form-label" style="text-align: left; display: block;">Nombre / Concepto</label>
                <input type="text" id="manualNombre" class="form-input" placeholder="Varios" value="Varios">
            </div>
            <div style="margin-bottom: 25px;">
                <label class="form-label" style="text-align: left; display: block;">Precio ($)</label>
                <input type="number" id="manualPrecio" class="form-input" placeholder="0" style="font-size: 24px; font-weight: bold; color: var(--azul-gvi);">
            </div>

            <div style="display: flex; gap: 10px;">
                <button class="btn-cancelar" style="flex: 1;" onclick="cerrarModalManual()">Cancelar</button>
                <button class="btn-accion" style="flex: 1.5;" onclick="agregarManualAlCarrito()">Añadir a la Venta</button>
            </div>
        </div>
    </div>

    <!-- MODAL EDITAR PRECIO -->
    <div id="modalEditarPrecio" class="modal-fondo">
        <div class="panel modal-precio-panel">
            <div class="modal-precio-header">
                <div class="modal-precio-icon"><i data-lucide="shield-check"></i></div>
                <div class="modal-precio-title">
                    <h3>Editar Precio</h3>
                    <span>Autorizacion administrador</span>
                </div>
            </div>

            <div class="modal-precio-body">
                <div class="producto-precio-card">
                    <span>Producto seleccionado</span>
                    <b id="editarPrecioProducto"></b>
                </div>

                <div class="precio-field">
                    <label>PIN Administrador</label>
                    <div class="precio-input-wrap">
                        <i data-lucide="lock-keyhole"></i>
                        <input type="password" id="editarPrecioPin" class="form-input" maxlength="4" inputmode="numeric" placeholder="••••">
                    </div>
                </div>

                <div class="precio-field">
                    <label>Nuevo Precio</label>
                    <div class="precio-input-wrap">
                        <i data-lucide="badge-dollar-sign"></i>
                        <input type="text" id="editarPrecioValor" class="form-input" inputmode="numeric" placeholder="$0" oninput="formatearPrecioEditor(this)">
                    </div>
                </div>

                <div id="editarPrecioError" style="min-height: 18px; color: #ff3b30; font-size: 12px; font-weight: 800; margin-bottom: 14px;"></div>

                <div class="modal-precio-actions">
                    <button class="btn-cancelar" onclick="cerrarModalEditarPrecio()">Cancelar</button>
                    <button class="btn-accion" onclick="confirmarEditarPrecio()">Guardar Precio</button>
                </div>
            </div>
        </div>
    </div>

    <div id="areaImpresion" style="display: none;"></div>

    <%- include('partials/scripts') %>

    <script>
        let catalogo = [];
        let carrito = [];
        let totalCaja = 0;
        let metodoPagoActual = 'Efectivo';
        let clientesFiadores = [];
        let timerBusqueda;
        let productoEsperaPeso = null;
        let indicePrecioEditando = null;

        // --- LÓGICA VENTA MANUAL ---
        function abrirModalManual() {
            document.getElementById('modalManual').style.display = 'flex';
            document.getElementById('manualPrecio').value = '';
            document.getElementById('manualNombre').value = 'Varios';
            setTimeout(() => document.getElementById('manualPrecio').focus(), 150);
        }
        function cerrarModalManual() { document.getElementById('modalManual').style.display = 'none'; inputCaja.focus(); }

        function agregarManualAlCarrito() {
            const nombre = document.getElementById('manualNombre').value.trim() || 'Varios';
            const precio = Number(document.getElementById('manualPrecio').value);
            if (!precio || precio <= 0) return alert("Ingresa un precio válido.");

            carrito.unshift({
                codigo: 'MANUAL',
                nombre: nombre.toUpperCase(),
                precio: precio,
                cantidad: 1,
                stock: 999999, // Sin limite de stock para manual
                vendidoPorPeso: false
            });
            actualizarVista();
            cerrarModalManual();
        }

        const inputCaja = document.getElementById('inputCodigoCaja');
        const listaSug = document.getElementById('listaSugerencias');
        let timerRefocoSku = null;

        function hayModalCajaAbierto() {
            return ['modalFinalizar', 'modalPeso', 'modalManual', 'modalEditarPrecio'].some(id => {
                const modal = document.getElementById(id);
                return modal && modal.style.display !== 'none' && getComputedStyle(modal).display !== 'none';
            });
        }

        function esCampoDeEscritura(el) {
            if (!el) return false;
            const tag = el.tagName;
            return el.isContentEditable || tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT';
        }

        function programarRefocoSku() {
            clearTimeout(timerRefocoSku);
            timerRefocoSku = setTimeout(() => {
                if (hayModalCajaAbierto()) return;
                if (esCampoDeEscritura(document.activeElement) && document.activeElement !== inputCaja) return;
                inputCaja.focus();
                inputCaja.select();
            }, 3000);
        }

        async function cargarCatalogo() {
            const res = await fetch('/api/productos');
            catalogo = await res.json();
        }

        // --- CARGAR LISTA DE CLIENTES QUE YA DEBEN ---
        async function cargarSugerenciasFiados() {
            try {
                const res = await fetch('/api/fiados');
                const fiados = await res.json();
                // Filtramos solo los nombres únicos que estén PENDIENTES
                clientesFiadores = [...new Set(fiados.filter(f => f.estado === "PENDIENTE").map(f => f.cliente))];
                
                const datalist = document.getElementById('listaClientesRegistrados');
                datalist.innerHTML = clientesFiadores.map(nombre => `<option value="${nombre}">`).join('');
            } catch (e) { console.error("Error al cargar deudores"); }
        }

        function verificarClienteExistente(input) {
            const nombre = input.value.trim().toUpperCase();
            const aviso = document.getElementById('avisoNuevoCliente');
            if (nombre.length > 0 && !clientesFiadores.includes(nombre)) {
                aviso.style.display = 'block';
            } else {
                aviso.style.display = 'none';
            }
        }

        // --- BUSCADOR INTELIGENTE ---
        inputCaja.addEventListener('input', function() {
            const busqueda = this.value.trim().toLowerCase();
            clearTimeout(timerBusqueda);
            if (busqueda.length < 1) { listaSug.style.display = 'none'; return; }
            const matchExacto = catalogo.find(p => p.codigo.toLowerCase() === busqueda);
            if (matchExacto) {
                timerBusqueda = setTimeout(() => {
                    agregarAlCarrito(matchExacto);
                    inputCaja.value = "";
                    listaSug.style.display = 'none';
                }, 150);
                return;
            }
            const empiezaCon = [];
            const contiene = [];
            catalogo.forEach(p => {
                const nombre = p.nombre.toLowerCase();
                const codigo = p.codigo.toLowerCase();
                if (nombre.startsWith(busqueda) || codigo.startsWith(busqueda)) empiezaCon.push(p);
                else if (nombre.includes(busqueda) || codigo.includes(busqueda)) contiene.push(p);
            });
            const filtrados = [...empiezaCon, ...contiene].slice(0, 12);
            if (filtrados.length > 0) {
                listaSug.innerHTML = filtrados.map(p => {
                    const stockLabel = p.vendidoPorPeso ? `${p.stock} kg` : `${p.stock} un.`;
                    const precioSugerido = calcularPrecioAplicable(p, 1);
                    const precioLabel = p.vendidoPorPeso ? `$${precioSugerido.precio.toLocaleString('es-CL')}/kg` : `$${precioSugerido.precio.toLocaleString('es-CL')}`;
                    const badge = p.vendidoPorPeso ? ' <span style="color:#ff9500;font-size:11px;">⚖️</span>' : '';
                    return `
                    <div class="sugerencia-item" onclick="seleccionarSugerencia('${p.codigo}')">
                        <span>${p.nombre}${badge} <small style="opacity:0.5">(${stockLabel})</small></span>
                        <b>${precioLabel}</b>
                    </div>`;
                }).join('');
                listaSug.style.display = 'block';
            } else { listaSug.style.display = 'none'; }
        });

        function seleccionarSugerencia(codigo) {
            const p = catalogo.find(x => x.codigo === codigo);
            if (p) { agregarAlCarrito(p); inputCaja.value = ""; listaSug.style.display = 'none'; inputCaja.focus(); }
        }

        function calcularPrecioAplicable(producto, cantidad) {
            const precioNormal = Number(producto.precioNormal ?? producto.precio ?? 0);
            const opciones = [{ precio: precioNormal, tipo: 'NORMAL' }];

            if (producto.ofertaActiva && Number(producto.precioOferta) > 0) {
                opciones.push({ precio: Number(producto.precioOferta), tipo: 'OFERTA' });
            }

            if (producto.mayorActivo && Number(producto.cantidadMayor) > 0 && Number(producto.precioMayor) > 0 && cantidad >= Number(producto.cantidadMayor)) {
                opciones.push({ precio: Number(producto.precioMayor), tipo: 'MAYOR' });
            }

            return opciones.reduce((mejor, actual) => actual.precio < mejor.precio ? actual : mejor);
        }

        function aplicarPrecioItem(item) {
            const resultado = calcularPrecioAplicable(item, Number(item.cantidad || 0));
            item.precio = resultado.precio;
            item.tipoPrecio = resultado.tipo;
        }

        function agregarAlCarrito(p) {
            if (p.stock <= 0) return alert("Sin stock");
            if (p.vendidoPorPeso) {
                abrirModalPeso(p);
                return;
            }
            const item = carrito.find(x => x.codigo === p.codigo);
            if (item) {
                if (item.cantidad < p.stock) {
                    item.cantidad++;
                    aplicarPrecioItem(item);
                } else {
                    alert("Limite stock");
                }
            } else {
                const nuevo = {...p, precioNormal: Number(p.precio), cantidad: 1, tipoPrecio: 'NORMAL'};
                aplicarPrecioItem(nuevo);
                carrito.unshift(nuevo);
            }
            actualizarVista();
        }

        function abrirModalPeso(p) {
            productoEsperaPeso = p;
            document.getElementById('modalPesoNombre').innerText = p.nombre;
            document.getElementById('modalPesoPrecioKilo').innerText = p.precio.toLocaleString('es-CL');
            document.getElementById('inputPesoGramos').value = '';
            document.getElementById('inputPesoMonto').value = '';
            document.getElementById('precioCalculadoPeso').innerText = '';
            setModoPesoCaja('gramos');
            document.getElementById('modalPeso').style.display = 'flex';
            setTimeout(() => document.getElementById('inputPesoGramos').focus(), 150);
        }

        let modoPesoCaja = 'gramos';
        function setModoPesoCaja(m) {
            modoPesoCaja = m;
            const btnG = document.getElementById('btnCajaGramos');
            const btnD = document.getElementById('btnCajaDinero');
            const divG = document.getElementById('divCajaGramos');
            const divD = document.getElementById('divCajaDinero');
            const lbl = document.getElementById('lblResultadoCaja');

            if (m === 'gramos') {
                btnG.style.background = 'white'; btnG.style.color = 'var(--azul-gvi)';
                btnD.style.background = 'transparent'; btnD.style.color = '#666';
                divG.style.display = 'block'; divD.style.display = 'none';
                lbl.innerText = 'Total a Cobrar';
                document.getElementById('inputPesoGramos').focus();
            } else {
                btnD.style.background = 'white'; btnD.style.color = '#34c759';
                btnG.style.background = 'transparent'; btnG.style.color = '#666';
                divD.style.display = 'block'; divG.style.display = 'none';
                lbl.innerText = 'Gramos Correspondientes';
                document.getElementById('inputPesoMonto').focus();
            }
            calcularPrecioEnVivo();
        }

        function cerrarModalPeso() {
            document.getElementById('modalPeso').style.display = 'none';
            productoEsperaPeso = null;
            inputCaja.focus();
        }

        function calcularPrecioEnVivo() {
            if (!productoEsperaPeso) return;
            const resEl = document.getElementById('precioCalculadoPeso');
            const pKilo = Number(productoEsperaPeso.precio);

            if (modoPesoCaja === 'gramos') {
                const g = Number(document.getElementById('inputPesoGramos').value);
                if (!g || g <= 0) { resEl.innerText = ''; return; }
                const kg = g / 1000;
                const precioAplicado = calcularPrecioAplicable(productoEsperaPeso, kg);
                const total = Math.round(precioAplicado.precio * kg);
                resEl.innerText = `$${total.toLocaleString('es-CL')}${precioAplicado.tipo !== 'NORMAL' ? ` (${precioAplicado.tipo})` : ''}`;
            } else {
                const monto = Number(document.getElementById('inputPesoMonto').value);
                if (!monto || monto <= 0) { resEl.innerText = ''; return; }
                const g = Math.round((monto / pKilo) * 1000);
                resEl.innerText = `${g}g`;
            }
        }

        function confirmarPeso() {
            let gramos = 0;
            if (modoPesoCaja === 'gramos') {
                gramos = Number(document.getElementById('inputPesoGramos').value);
            } else {
                const monto = Number(document.getElementById('inputPesoMonto').value);
                if (monto > 0) gramos = Math.round((monto / productoEsperaPeso.precio) * 1000);
            }

            if (!gramos || gramos <= 0) return alert('⚠️ Ingresa un valor válido.');
            const pesoKg = gramos / 1000;
            if (pesoKg > productoEsperaPeso.stock) return alert(`⚠️ Stock insuficiente. Solo hay ${productoEsperaPeso.stock} kg disponibles.`);

            const nuevoPeso = {
                ...productoEsperaPeso,
                precioNormal: Number(productoEsperaPeso.precio),
                cantidad: pesoKg,
                pesoGramos: gramos,
                vendidoPorPeso: true
            };
            aplicarPrecioItem(nuevoPeso);
            carrito.unshift(nuevoPeso);
            actualizarVista();
            cerrarModalPeso();
        }

        function actualizarVista() {
            const tbody = document.getElementById('listaCarrito');
            tbody.innerHTML = "";
            totalCaja = 0;
            carrito.forEach((item, index) => {
                if (item.codigo !== 'MANUAL') aplicarPrecioItem(item);
                const subtotal = item.precio * item.cantidad;
                totalCaja += subtotal;
                const precioBadge = item.tipoPrecio === 'OFERTA'
                    ? '<span class="badge-precio-carrito badge-precio-oferta">OFERTA</span>'
                    : (item.tipoPrecio === 'MAYOR' ? '<span class="badge-precio-carrito badge-precio-mayor">MAYOR</span>' : '');

                let cantidadCell, precioCell;
                if (item.vendidoPorPeso) {
                    cantidadCell = `<td>⚖️ ${item.pesoGramos}g</td>`;
                    precioCell = `<td><span class="precio-editable">$${item.precio.toLocaleString('es-CL')}/kg <button class="btn-editar-precio" onclick="editarPrecioCarrito(${index})" title="Editar precio">✎</button></span></td>`;
                } else {
                    cantidadCell = `<td><div class="control-cant"><button class="btn-cant" onclick="cambiarCant(${index},-1)">-</button><b>${item.cantidad}</b><button class="btn-cant" onclick="cambiarCant(${index},1)">+</button></div></td>`;
                    precioCell = `<td><span class="precio-editable">$${item.precio.toLocaleString('es-CL')} <button class="btn-editar-precio" onclick="editarPrecioCarrito(${index})" title="Editar precio">✎</button></span></td>`;
                }

                tbody.innerHTML += `<tr>
                    <td><b>${item.nombre}</b>${item.vendidoPorPeso ? '<span class="badge-peso">⚖️ PESO</span>' : ''}${precioBadge}<br><small>${item.codigo}</small></td>
                    ${cantidadCell}
                    ${precioCell}
                    <td><b>$${subtotal.toLocaleString('es-CL')}</b></td>
                    <td><button onclick="carrito.splice(${index},1); actualizarVista()" style="border:none; background:transparent; cursor:pointer;">❌</button></td>
                </tr>`;
            });
            document.getElementById('txtTotal').innerText = "$" + totalCaja.toLocaleString('es-CL');
            document.getElementById('btnCobrar').disabled = carrito.length === 0;
        }

        function formatearPrecioEditor(input) {
            const valor = input.value.replace(/\D/g, '');
            input.value = valor === '' ? '' : '$' + Number(valor).toLocaleString('es-CL');
        }

        function editarPrecioCarrito(index) {
            const item = carrito[index];
            if (!item) return;

            indicePrecioEditando = index;
            document.getElementById('editarPrecioProducto').innerText = `${item.nombre} · Precio actual: $${Number(item.precio).toLocaleString('es-CL')}${item.vendidoPorPeso ? '/kg' : ''}`;
            document.getElementById('editarPrecioPin').value = '';
            document.getElementById('editarPrecioValor').value = '$' + Number(item.precio).toLocaleString('es-CL');
            document.getElementById('editarPrecioError').innerText = '';
            document.getElementById('modalEditarPrecio').style.display = 'flex';
            setTimeout(() => document.getElementById('editarPrecioPin').focus(), 120);
        }

        function cerrarModalEditarPrecio() {
            document.getElementById('modalEditarPrecio').style.display = 'none';
            indicePrecioEditando = null;
            inputCaja.focus();
        }

        async function confirmarEditarPrecio() {
            const item = carrito[indicePrecioEditando];
            if (!item) return cerrarModalEditarPrecio();

            const pin = document.getElementById('editarPrecioPin').value.trim();
            const nuevoPrecio = Number(document.getElementById('editarPrecioValor').value.replace(/\D/g, ''));
            const errorEl = document.getElementById('editarPrecioError');

            if (!pin) {
                errorEl.innerText = 'Ingresa el PIN de administrador.';
                document.getElementById('editarPrecioPin').focus();
                return;
            }

            if (!nuevoPrecio || nuevoPrecio <= 0) {
                errorEl.innerText = 'Ingresa un precio valido.';
                document.getElementById('editarPrecioValor').focus();
                return;
            }

            try {
                const auth = await fetch('/api/verify-admin', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ pin })
                });
                const authData = await auth.json();
                if (!authData.success) {
                    errorEl.innerText = 'PIN de administrador incorrecto.';
                    document.getElementById('editarPrecioPin').select();
                    return;
                }
            } catch (e) {
                errorEl.innerText = 'No se pudo verificar el PIN.';
                return;
            }

            if (item.codigo !== 'MANUAL') {
                const productoBase = catalogo.find(p => p.codigo === item.codigo) || item;
                try {
                    const productoActualizado = {
                        ...productoBase,
                        precio: nuevoPrecio,
                        precioNormal: nuevoPrecio,
                        ofertaActiva: false,
                        precioOferta: 0,
                        mayorActivo: false,
                        cantidadMayor: 0,
                        precioMayor: 0
                    };
                    const res = await fetch(`/api/productos/${encodeURIComponent(item.codigo)}`, {
                        method: 'PUT',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify(productoActualizado)
                    });
                    if (!res.ok) {
                        errorEl.innerText = 'No se pudo actualizar el precio en bodega.';
                        return;
                    }
                    await cargarCatalogo();
                } catch (e) {
                    errorEl.innerText = 'Error de red actualizando el precio.';
                    return;
                }
            }

            item.precio = nuevoPrecio;
            item.precioNormal = nuevoPrecio;
            item.ofertaActiva = false;
            item.precioOferta = 0;
            item.mayorActivo = false;
            item.cantidadMayor = 0;
            item.precioMayor = 0;
            item.tipoPrecio = 'NORMAL';
            actualizarVista();
            cerrarModalEditarPrecio();
        }

        function cambiarCant(i, n) {
            const item = carrito[i];
            const nuevo = item.cantidad + n;
            if (nuevo <= 0) carrito.splice(i, 1);
            else if (nuevo <= item.stock) {
                item.cantidad = nuevo;
                if (item.codigo !== 'MANUAL') aplicarPrecioItem(item);
            }
            actualizarVista();
        }

        // --- CIERRE DE VENTA ---
        function abrirModalFinalizar() {
            document.getElementById('modalFinalizar').style.display = 'flex';
            document.getElementById('totalModal').innerText = "$" + totalCaja.toLocaleString('es-CL');
            document.getElementById('inputPagoModal').value = "";
            document.getElementById('vueltoModal').innerText = "$0";
            document.getElementById('estadoPagoTexto').innerText = "Vuelto:";
            document.getElementById('estadoPagoModal').style.color = "#34c759";
            document.getElementById('nombreClienteFiado').value = "";
            document.getElementById('avisoNuevoCliente').style.display = 'none';
            setMetodo('Efectivo');
            setTimeout(() => document.getElementById('inputPagoModal').focus(), 150);
        }

        function cerrarModalFinalizar() { document.getElementById('modalFinalizar').style.display = 'none'; }

        function setMetodo(m) {
            metodoPagoActual = m;
            document.getElementById('btnEfec').classList.toggle('activo', m === 'Efectivo');
            document.getElementById('btnTarj').classList.toggle('activo', m === 'Tarjeta');
            document.getElementById('btnFiado').classList.toggle('activo', m === 'Fiado');
            
            document.getElementById('seccionEfectivo').style.display = (m === 'Efectivo') ? 'block' : 'none';
            document.getElementById('seccionFiado').style.display = (m === 'Fiado') ? 'block' : 'none';
            
            // Si es FIADO, ocultamos el botón de imprimir y cargamos nombres
            document.getElementById('btnGuardarImprimir').style.display = (m === 'Fiado') ? 'none' : 'block';
            document.getElementById('btnSoloGuardar').innerText = (m === 'Fiado') ? '📓 ANOTAR FIADO' : 'SOLO GUARDAR';

            if(m === 'Fiado') {
                cargarSugerenciasFiados();
                setTimeout(() => document.getElementById('nombreClienteFiado').focus(), 150);
            }
            if(m === 'Efectivo') setTimeout(() => document.getElementById('inputPagoModal').focus(), 150);
        }

        function formatearVuelto(input) {
            let valor = input.value.replace(/\D/g, "");
            input.value = valor === "" ? "" : "$" + Number(valor).toLocaleString('es-CL');
            let pago = Number(valor);
            let vuelto = pago - totalCaja;
            const estado = document.getElementById('estadoPagoModal');
            const texto = document.getElementById('estadoPagoTexto');
            if (!pago || pago >= totalCaja) {
                texto.innerText = "Vuelto:";
                estado.style.color = "#34c759";
                document.getElementById('vueltoModal').innerText = "$" + Math.max(0, vuelto).toLocaleString('es-CL');
            } else {
                texto.innerText = "Faltan:";
                estado.style.color = "#ff3b30";
                document.getElementById('vueltoModal').innerText = "$" + Math.abs(vuelto).toLocaleString('es-CL');
            }
        }

        async function procesarVentaReal(imprimir) {
            if(metodoPagoActual === 'Fiado') {
                const cliente = document.getElementById('nombreClienteFiado').value.trim().toUpperCase();
                if(!cliente) return alert("❌ Debes ingresar el nombre del cliente.");

                try {
                    const res = await fetch('/api/fiados', {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({ cliente, items: carrito, total: totalCaja })
                    });
                    const r = await res.json();
                    if(r.success) {
                        alert(`📓 Cuenta de ${cliente} actualizada.`);
                        finalizarTodo();
                    }
                } catch (e) { alert("Error de red"); }
                return;
            }

            let pago = metodoPagoActual === 'Efectivo' ? Number(document.getElementById('inputPagoModal').value.replace(/\D/g, "")) : totalCaja;
            if (metodoPagoActual === 'Efectivo' && pago < totalCaja) return alert("Pago insuficiente");

            const datos = { items: carrito, total: totalCaja, metodoPago: metodoPagoActual, pagoCon: pago, vuelto: pago - totalCaja };

            try {
                const res = await fetch('/api/vender', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify(datos)
                });
                const r = await res.json();
                if (r.success) {
                    if (imprimir) generarTicketPrint(r.ventaId, datos);
                    finalizarTodo();
                }
            } catch (e) { alert("Error de red"); }
        }

        function finalizarTodo() {
            carrito = []; actualizarVista(); cargarCatalogo(); cerrarModalFinalizar(); inputCaja.focus();
        }

        function generarTicketPrint(id, datos) {
            const fecha = new Date().toLocaleString();
            document.getElementById('areaImpresion').innerHTML = `
                <div style="font-family:'Courier New', monospace; width:100%; color:#000; font-weight:800; line-height:1.22;">
                    <div style="text-align:center; font-size:18px; font-weight:900;">GVI MINIMARKET</div>
                    <div style="text-align:center; font-size:12px; font-weight:900; margin-top:3px;">#${id}</div>
                    <div style="text-align:center; font-size:11px; font-weight:900; margin-top:2px;">${fecha}</div>
                    <div style="border-top:2px solid #000; margin:8px 0;"></div>
                    <div style="font-size:12px; font-weight:900;">Metodo: ${datos.metodoPago}</div>
                    <div style="border-top:2px solid #000; margin:8px 0;"></div>
                    <table style="width:100%; border-collapse:collapse; table-layout:fixed; font-size:12px; font-weight:900;">
                        ${datos.items.map(i => {
                            const cant = i.vendidoPorPeso ? `${i.pesoGramos}g` : `${i.cantidad}`;
                            return `<tr>
                                <td style="width:68%; padding:5px 0; white-space:nowrap; overflow:hidden; font-weight:900;">${cant} x ${String(i.nombre || '').substring(0,18)}</td>
                                <td style="width:32%; padding:5px 0; text-align:right; white-space:nowrap; font-weight:900;">$${(Number(i.precio || 0)*Number(i.cantidad || 0)).toLocaleString('es-CL')}</td>
                            </tr>`;
                        }).join('')}
                    </table>
                    <div style="border-top:2px solid #000; margin:8px 0;"></div>
                    <table style="width:100%; border-collapse:collapse; table-layout:fixed; font-size:14px; font-weight:900;">
                        <tr>
                            <td style="font-weight:900;">Total:</td>
                            <td style="text-align:right; white-space:nowrap; font-weight:900;">$${Number(datos.total || 0).toLocaleString('es-CL')}</td>
                        </tr>
                        ${datos.metodoPago === 'Efectivo' ? `<tr>
                            <td style="font-size:12px; font-weight:900; padding-top:3px;">Vuelto:</td>
                            <td style="font-size:12px; text-align:right; white-space:nowrap; font-weight:900; padding-top:3px;">$${Number(datos.vuelto || 0).toLocaleString('es-CL')}</td>
                        </tr>` : ''}
                    </table>
                    <div style="border-top:2px solid #000; margin:8px 0;"></div>
                    <div style="text-align:center; font-size:12px; font-weight:900;">Muchas gracias por su compra</div>
                </div>`;
            window.print();
        }

        document.addEventListener('click', (e) => {
            if (!listaSug.contains(e.target) && e.target !== inputCaja) {
                listaSug.style.display = 'none';
                programarRefocoSku();
            }
        });
 
        document.getElementById('inputPesoGramos').addEventListener('keydown', (e) => {
            if (e.key === 'Enter') confirmarPeso();
            if (e.key === 'Escape') cerrarModalPeso();
        });

        ['editarPrecioPin', 'editarPrecioValor'].forEach(id => {
            document.getElementById(id).addEventListener('keydown', (e) => {
                if (e.key === 'Enter') confirmarEditarPrecio();
                if (e.key === 'Escape') cerrarModalEditarPrecio();
            });
        });

        document.addEventListener('DOMContentLoaded', cargarCatalogo);
    </script>
</body>
</html>
