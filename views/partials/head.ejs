<!-- AUTENTICACIÓN Y ROLES GLOBALES -->
<script>
    const userStr = localStorage.getItem('gvi_user');
    const isLoginPage = window.location.pathname === '/login';
    
    if (!userStr && !isLoginPage) {
        window.location.href = '/login';
    } else if (userStr && !isLoginPage) {
        const user = JSON.parse(userStr);
        // Protección de rutas sensibles
        const protectedRoutes = ['/finanzas', '/auditoria', '/configuracion'];
        if (user.rol !== 'ADMIN' && protectedRoutes.includes(window.location.pathname)) {
            alert('Acceso Denegado: No tienes permisos de administrador para ver esta sección.');
            window.location.href = '/';
        }
    }

    if (localStorage.getItem('gvi_theme') === 'light') {
        document.addEventListener('DOMContentLoaded', () => {
            document.body.classList.remove('dark-mode');
        });
    }

    window.gviClosingApp = false;
</script>
