<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="/css/global.css">
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest"></script>

<!-- AUTENTICACIÓN Y ROLES GLOBALES -->
<script>
    const userStr = localStorage.getItem('gvi_user');
    const isLoginPage = window.location.pathname === '/login';
    
    if (!userStr && !isLoginPage) {
        window.location.href = '/login';
    } else if (userStr && !isLoginPage) {
        const user = JSON.parse(userStr);
        // Protección de rutas sensibles
        const protectedRoutes = ['/finanzas', '/auditoria', '/configuracion'];
        if (user.rol !== 'ADMIN' && protectedRoutes.includes(window.location.pathname)) {
            alert('Acceso Denegado: No tienes permisos de administrador para ver esta sección.');
            window.location.href = '/';
        }
    }

    (function () {
        const media = window.matchMedia ? window.matchMedia('(prefers-color-scheme: dark)') : null;

        window.gviThemePreference = function () {
            const stored = localStorage.getItem('temaGVI_preferencia');
            return stored === 'claro' || stored === 'oscuro' ? stored : 'sistema';
        };

        window.gviThemeIsDark = function () {
            const preference = window.gviThemePreference();
            return preference === 'oscuro' || (preference === 'sistema' && !!media?.matches);
        };

        window.gviApplyTheme = function () {
            const isDark = window.gviThemeIsDark();
            document.documentElement.classList.toggle('dark-mode', isDark);
            document.documentElement.dataset.themePreference = window.gviThemePreference();
            if (document.body) {
                document.body.classList.toggle('dark-mode', isDark);
                document.body.dataset.themePreference = window.gviThemePreference();
            }
            return isDark;
        };

        window.gviSetThemePreference = function (preference) {
            localStorage.setItem('temaGVI_preferencia', preference);
            localStorage.setItem('temaGVI', preference);
            return window.gviApplyTheme();
        };

        window.gviApplyTheme();
        document.addEventListener('DOMContentLoaded', window.gviApplyTheme);
        media?.addEventListener?.('change', () => {
            if (window.gviThemePreference() === 'sistema') window.gviApplyTheme();
        });
    })();

    window.gviClosingApp = false;
</script>
