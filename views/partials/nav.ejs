<script>
    const esInicio = window.location.pathname === '/';
</script>

<nav class="app-topbar" id="appTopbar">
    <div class="app-topbar-left">
        <button class="topbar-icon-btn" onclick="window.history.back()" title="Volver">
            <i data-lucide="arrow-left"></i>
        </button>
        <div class="topbar-brand" title="GVI">
            <span class="brand-mark">GVI</span>
        </div>
    </div>

    <div class="topbar-links">
        <span class="topbar-active-indicator" id="topbarActiveIndicator"></span>
        <a href="/" class="topbar-link" data-label="Inicio"><i data-lucide="home"></i><span>Inicio</span></a>
        <a href="/caja" class="topbar-link" data-label="Venta"><i data-lucide="shopping-cart"></i><span>Venta</span></a>
        <a href="/cobrar" class="topbar-link" data-label="Cobrar"><i data-lucide="credit-card"></i><span>Cobrar</span></a>
        <a href="/bodega" class="topbar-link" data-label="Bodega"><i data-lucide="package"></i><span>Bodega</span></a>
        <a href="/productos" class="topbar-link" data-label="Productos"><i data-lucide="scan-barcode"></i><span>Productos</span></a>
        <a href="/finanzas" class="topbar-link admin-only" data-label="Finanzas"><i data-lucide="bar-chart-3"></i><span>Finanzas</span></a>
        <a href="/configuracion" class="topbar-link admin-only" data-label="Ajustes"><i data-lucide="settings"></i><span>Ajustes</span></a>
        <div class="topbar-clock-chip" id="topbarClockChip">
            <strong id="topbarClock">00:00</strong>
            <span id="topbarDate">--</span>
        </div>
        <a href="#" onclick="togglePerfil(event)" class="topbar-link user-switch" data-label="Perfil"><i data-lucide="user"></i><span id="topbarUserName">Usuario</span></a>
        <button class="topbar-window-btn theme-toggle" onclick="toggleTemaNav()" title="Cambiar tema" data-label="Tema"><i data-lucide="moon" id="themeToggleIcon"></i></button>
        <button class="topbar-window-btn" onclick="minimizarAppNav()" title="Minimizar GVI" data-label="Minimizar"><i data-lucide="minus"></i></button>
        <button class="topbar-window-btn danger" onclick="cerrarProgramaNav()" title="Cerrar programa" data-label="Cerrar"><i data-lucide="power"></i></button>
    </div>
</nav>

<div class="profile-popover" id="profilePopover">
    <div class="profile-avatar" id="profileAvatar">U</div>
    <div class="profile-meta">
        <strong id="profileName">Usuario</strong>
        <span id="profileRole">Perfil activo</span>
    </div>
    <button type="button" class="profile-switch-btn" onclick="cambiarUsuario(event)">
        <i data-lucide="repeat-2"></i>
        Cambiar usuario
    </button>
    <button type="button" class="profile-logout-btn" onclick="cerrarSesion(event)">
        <i data-lucide="log-out"></i>
        Cerrar sesion
    </button>
</div>

<script>
    if (esInicio) document.getElementById('appTopbar')?.classList.add('compact');

    function cerrarSesion(e) {
        if (e) e.preventDefault();
        if (confirm('Cerrar sesion actual?')) {
            localStorage.removeItem('gvi_user');
            window.location.href = '/login';
        }
    }

    function prepararCambioRuta(destino) {
        const topbar = document.getElementById('appTopbar');
        const vaInicio = destino === '/';
        const origen = esInicio ? 'compact' : 'full';
        const destinoTipo = vaInicio ? 'compact' : 'full';
        sessionStorage.setItem('gvi_bar_motion', `${origen}-to-${destinoTipo}`);
        if (topbar) topbar.classList.add('route-shift');
        document.body.classList.add('content-leaving');
    }

    function navegarConMovimiento(destino) {
        prepararCambioRuta(destino);
        setTimeout(() => { window.location.href = destino; }, 190);
    }

    function togglePerfil(e) {
        if (e) e.preventDefault();
        const popover = document.getElementById('profilePopover');
        popover?.classList.toggle('open');
    }

    function actualizarTemaNav() {
        const icon = document.getElementById('themeToggleIcon');
        const esOscuro = document.body.classList.contains('dark-mode');
        if (icon) icon.setAttribute('data-lucide', esOscuro ? 'sun' : 'moon');
        if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    function toggleTemaNav() {
        if (typeof toggleTema === 'function') {
            toggleTema();
        } else {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('temaGVI', document.body.classList.contains('dark-mode') ? 'oscuro' : 'claro');
        }
        actualizarTemaNav();
    }

    function cambiarUsuario(e) {
        if (e) e.preventDefault();
        document.getElementById('profilePopover')?.classList.remove('open');
        localStorage.removeItem('gvi_user');
        window.location.href = '/login';
    }

    async function minimizarAppNav() {
        await fetch('/api/app/minimize', { method: 'POST' });
    }

    async function cerrarProgramaNav() {
        if (!confirm('Cerrar GVI por completo?')) return;
        localStorage.removeItem('gvi_user');
        await fetch('/api/app/quit', { method: 'POST' });
    }

    function actualizarRelojTopbar() {
        const ahora = new Date();
        const clock = document.getElementById('topbarClock');
        const date = document.getElementById('topbarDate');
        if (clock) {
            let horas = ahora.getHours();
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const periodo = horas >= 12 ? 'PM' : 'AM';
            horas = horas % 12 || 12;
            clock.innerText = `${String(horas).padStart(2, '0')}:${minutos} ${periodo}`;
        }
        if (date) {
            date.innerText = ahora.toLocaleDateString('es-CL', {
                weekday: 'short',
                day: '2-digit',
                month: 'short'
            });
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        try {
            if (localStorage.getItem('temaGVI') === 'oscuro') {
                document.body.classList.add('dark-mode');
            }
            actualizarTemaNav();

            const usrInfo = JSON.parse(localStorage.getItem('gvi_user'));
            if (usrInfo?.nombre) {
                const userName = document.getElementById('topbarUserName');
                if (userName) userName.innerText = usrInfo.nombre;
                const profileName = document.getElementById('profileName');
                const profileRole = document.getElementById('profileRole');
                const profileAvatar = document.getElementById('profileAvatar');
                if (profileName) profileName.innerText = usrInfo.nombre;
                if (profileRole) profileRole.innerText = usrInfo.rol || 'Perfil activo';
                if (profileAvatar) profileAvatar.innerText = usrInfo.nombre.trim().charAt(0).toUpperCase();
            }
            if (usrInfo && usrInfo.rol !== 'ADMIN') {
                document.querySelectorAll('.admin-only').forEach(el => el.style.display = 'none');
            }
        } catch (e) {}

        const path = window.location.pathname;
        const indicator = document.getElementById('topbarActiveIndicator');

        function moverIndicador(link, instant = false) {
            if (!indicator || !link) return;
            const parentRect = link.parentElement.getBoundingClientRect();
            const rect = link.getBoundingClientRect();
            if (instant) indicator.style.transition = 'none';
            indicator.style.width = `${rect.width}px`;
            indicator.style.height = `${rect.height}px`;
            indicator.style.transform = `translateX(${rect.left - parentRect.left + link.parentElement.scrollLeft}px)`;
            if (instant) {
                indicator.offsetHeight;
                indicator.style.transition = '';
            }
        }

        const activeLink = Array.from(document.querySelectorAll('.topbar-link')).find(link => link.getAttribute('href') === path);
        if (activeLink) {
            activeLink.classList.add('active');
            requestAnimationFrame(() => moverIndicador(activeLink, true));
        }

        document.querySelectorAll('.topbar-link').forEach(link => {
            const href = link.getAttribute('href');
            if (!href || href === '#' || href === path) return;
            link.addEventListener('click', (event) => {
                event.preventDefault();
                document.querySelectorAll('.topbar-link').forEach(item => item.classList.remove('active'));
                link.classList.add('active');
                moverIndicador(link);
                navegarConMovimiento(href);
            });
        });

        document.querySelectorAll('a[href^="/"]').forEach(link => {
            if (link.classList.contains('topbar-link')) return;
            link.addEventListener('click', (event) => {
                const href = link.getAttribute('href');
                if (!href || href === path) return;
                event.preventDefault();
                navegarConMovimiento(href);
            });
        });

        const motion = sessionStorage.getItem('gvi_bar_motion');
        sessionStorage.removeItem('gvi_bar_motion');
        const topbar = document.getElementById('appTopbar');
        if (topbar && motion === 'compact-to-full' && !esInicio) {
            topbar.classList.add('from-compact');
        }
        if (topbar && motion === 'full-to-compact' && esInicio) {
            topbar.classList.add('from-full');
        }

        document.addEventListener('click', (event) => {
            const popover = document.getElementById('profilePopover');
            const userButton = document.querySelector('.topbar-link.user-switch');
            if (!popover?.classList.contains('open')) return;
            if (popover.contains(event.target) || userButton?.contains(event.target)) return;
            popover.classList.remove('open');
        });

        window.addEventListener('resize', () => moverIndicador(document.querySelector('.topbar-link.active'), true));
        document.querySelector('.topbar-links')?.addEventListener('scroll', () => moverIndicador(document.querySelector('.topbar-link.active'), true));
        actualizarRelojTopbar();
        setInterval(actualizarRelojTopbar, 1000);

        if (typeof lucide !== 'undefined') lucide.createIcons();
    });
</script>

