        </div>
    </div>
</nav>

<div class="notifications-popover" id="notificationsPopover">
    <div class="notifications-header">
        <strong>Notificaciones</strong>
        <span>Centro GVI</span>
    </div>
    <div class="notification-item update" id="notificationUpdateItem">
        <i data-lucide="download-cloud" id="notificationUpdateIcon"></i>
        <div>
            <strong id="notificationUpdateTitle">Actualizaciones</strong>
            <span id="notificationUpdateText">GVI revisa nuevas versiones en segundo plano.</span>
            <div class="notification-progress" id="notificationUpdateProgress">
                <div id="notificationUpdateProgressBar"></div>
            </div>
            <button class="notification-action" id="notificationUpdateAction" type="button" onclick="instalarActualizacionNav(event)" hidden>Actualizar ahora</button>
        </div>
    </div>
    <div class="notification-item" id="notificationInstalledNotice" hidden>
        <i data-lucide="sparkles"></i>
        <div>
            <strong id="notificationInstalledTitle">GVI actualizado</strong>
            <span id="notificationInstalledText">La nueva version se instalo correctamente.</span>
            <button class="notification-action secondary" type="button" onclick="descartarAvisoActualizacion(event)">Entendido</button>
        </div>
    </div>
    <div class="notification-item urgent">
        <i data-lucide="triangle-alert"></i>
        <div>
            <strong>Stock por revisar</strong>
            <span>Productos con poco stock apareceran aqui.</span>
        </div>
    </div>
    <div class="notifications-empty" id="notificationsEmpty">Las alertas reales se conectaran a stock, caja y ventas.</div>
</div>

<div class="profile-popover" id="profilePopover">
    <div class="profile-avatar" id="profileAvatar">U</div>
    <div class="profile-meta">
        <strong id="profileName">Usuario</strong>
        <span id="profileRole">Perfil activo</span>
    </div>
    <button type="button" class="profile-switch-btn" onclick="cambiarUsuario(event)">
        <i data-lucide="repeat-2"></i>
        Cambiar usuario
    </button>
    <button type="button" class="profile-logout-btn" onclick="cerrarSesion(event)">
        <i data-lucide="log-out"></i>
        Cerrar sesion
    </button>
</div>

<div class="update-installed-toast" id="updateInstalledToast" hidden>
    <div>
        <strong id="updateInstalledToastTitle">GVI actualizado</strong>
        <span id="updateInstalledToastText">La nueva version se instalo correctamente.</span>
    </div>
    <button type="button" onclick="abrirNovedadesActualizacion(event)">Ver mejoras</button>
    <button type="button" class="toast-close" onclick="descartarAvisoActualizacion(event)" title="Cerrar"><i data-lucide="x"></i></button>
</div>

<script>
    if (esInicio) document.getElementById('appTopbar')?.classList.add('home-topbar');

    function cerrarSesion(e) {
        if (e) e.preventDefault();
        if (confirm('Cerrar sesion actual?')) {
            localStorage.removeItem('gvi_user');
            window.location.href = '/login';
        }
    }

    function prepararCambioRuta(destino) {
        document.body.classList.add('content-leaving', 'is-routing');
    }

    function navegarConMovimiento(destino) {
        prepararCambioRuta(destino);
        setTimeout(() => { window.location.href = destino; }, 90);
    }

    function togglePerfil(e) {
        if (e) e.preventDefault();
        const popover = document.getElementById('profilePopover');
        document.getElementById('notificationsPopover')?.classList.remove('open');
        popover?.classList.toggle('open');
    }

    function toggleNotificaciones(e) {
        if (e) e.preventDefault();
        const popover = document.getElementById('notificationsPopover');
        document.getElementById('profilePopover')?.classList.remove('open');
        popover?.classList.toggle('open');
        consultarActualizacionNav();
        consultarAvisoActualizacionNav();
    }

    function normalizarTextoActualizacion(texto) {
        return String(texto || '').replace(/<[^>]*>/g, '').trim();
    }

    async function instalarActualizacionNav(e) {
        if (e) e.preventDefault();
        const action = document.getElementById('notificationUpdateAction');
        if (action) {
            action.disabled = true;
            action.innerText = 'Actualizando...';
        }
        try {
            await fetch('/api/app/update/install', { method: 'POST' });
        } catch (_) {
            if (action) {
                action.disabled = false;
                action.innerText = 'Actualizar ahora';
            }
        }
    }

    async function descartarAvisoActualizacion(e) {
        if (e) e.preventDefault();
        document.getElementById('notificationInstalledNotice')?.setAttribute('hidden', '');
        document.getElementById('updateInstalledToast')?.setAttribute('hidden', '');
        await fetch('/api/app/update/notice/dismiss', { method: 'POST' }).catch(() => null);
    }

    function abrirNovedadesActualizacion(e) {
        if (e) e.preventDefault();
        document.getElementById('profilePopover')?.classList.remove('open');
        document.getElementById('notificationsPopover')?.classList.add('open');
    }

    function aplicarActualizacionNav(data) {
        const title = document.getElementById('notificationUpdateTitle');
        const text = document.getElementById('notificationUpdateText');
        const progress = document.getElementById('notificationUpdateProgress');
        const bar = document.getElementById('notificationUpdateProgressBar');
        const action = document.getElementById('notificationUpdateAction');
        const icon = document.getElementById('notificationUpdateIcon');
        if (!title || !text || !progress || !bar || !action) return;

        action.hidden = true;
        action.disabled = false;
        action.innerText = 'Actualizar ahora';
        progress.classList.remove('visible');
        bar.style.width = '0%';
        if (icon) icon.setAttribute('data-lucide', 'download-cloud');

        if (!data.configured) {
            title.innerText = 'Actualizaciones';
            text.innerText = data.message || 'Disponible solo en la version instalada.';
            return;
        }

        if (data.installing) {
            title.innerText = 'Actualizando GVI';
            text.innerText = 'Instalando en silencio. La app se reiniciara automaticamente.';
            if (icon) icon.setAttribute('data-lucide', 'loader-circle');
            return;
        }

        if (data.downloading) {
            title.innerText = `Descargando v${data.version || ''}`;
            text.innerText = data.message || 'Descarga en segundo plano.';
            progress.classList.add('visible');
            bar.style.width = `${data.percent || 0}%`;
            if (icon) icon.setAttribute('data-lucide', 'download');
            return;
        }

        if (data.ready) {
            title.innerText = `Version v${data.version} lista`;
            text.innerText = 'Presiona actualizar. GVI instalara todo sin preguntas y volvera a abrirse.';
            action.hidden = false;
            if (icon) icon.setAttribute('data-lucide', 'refresh-cw');
            return;
        }

        if (data.checking) {
            title.innerText = 'Buscando actualizaciones';
            text.innerText = 'Revisando GitHub Releases...';
            if (icon) icon.setAttribute('data-lucide', 'loader-circle');
            return;
        }

        title.innerText = 'Actualizaciones';
        text.innerText = data.message || 'GVI revisa nuevas versiones en segundo plano.';
    }

    async function consultarActualizacionNav() {
        try {
            const res = await fetch('/api/app/update/status');
            const data = await res.json();
            aplicarActualizacionNav(data);
            if (typeof lucide !== 'undefined') lucide.createIcons();
        } catch (_) {}
    }

    async function consultarAvisoActualizacionNav() {
        try {
            const res = await fetch('/api/app/update/notice');
            const data = await res.json();
            const notice = data.notice;
            const item = document.getElementById('notificationInstalledNotice');
            if (!item) return;
            if (!notice) {
                item.hidden = true;
                document.getElementById('updateInstalledToast')?.setAttribute('hidden', '');
                return;
            }
            item.hidden = false;
            const notes = normalizarTextoActualizacion(notice.releaseNotes) || 'Actualizacion aplicada correctamente.';
            document.getElementById('notificationInstalledTitle').innerText = `GVI v${notice.version} instalado`;
            document.getElementById('notificationInstalledText').innerText = notes;
            const toast = document.getElementById('updateInstalledToast');
            if (toast) {
                toast.hidden = false;
                document.getElementById('updateInstalledToastTitle').innerText = `GVI v${notice.version} instalado`;
                document.getElementById('updateInstalledToastText').innerText = notes.slice(0, 110);
            }
        } catch (_) {}
    }

    function actualizarTemaNav() {
        const icon = document.getElementById('themeToggleIcon');
        const esOscuro = document.body.classList.contains('dark-mode');
        if (icon) icon.setAttribute('data-lucide', esOscuro ? 'sun' : 'moon');
        if (typeof lucide !== 'undefined') lucide.createIcons();
    }

    function toggleTemaNav() {
        if (typeof toggleTema === 'function') {
            toggleTema();
        } else {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('temaGVI', document.body.classList.contains('dark-mode') ? 'oscuro' : 'claro');
        }
        actualizarTemaNav();
    }

    function cambiarUsuario(e) {
        if (e) e.preventDefault();
        document.getElementById('profilePopover')?.classList.remove('open');
        localStorage.removeItem('gvi_user');
        window.location.href = '/login';
    }

    async function minimizarAppNav() {
        await fetch('/api/app/minimize', { method: 'POST' });
    }

    async function cerrarProgramaNav() {
        if (!confirm('Cerrar GVI por completo?')) return;
        localStorage.removeItem('gvi_user');
        await fetch('/api/app/quit', { method: 'POST' });
    }

    function actualizarRelojTopbar() {
        const ahora = new Date();
        const clock = document.getElementById('topbarClock');
        const date = document.getElementById('topbarDate');
        if (clock) {
            let horas = ahora.getHours();
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const periodo = horas >= 12 ? 'PM' : 'AM';
            horas = horas % 12 || 12;
            clock.innerText = `${String(horas).padStart(2, '0')}:${minutos} ${periodo}`;
        }
        if (date) {
            date.innerText = ahora.toLocaleDateString('es-CL', {
                weekday: 'short',
                day: '2-digit',
                month: 'short'
            });
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        try {
            if (localStorage.getItem('temaGVI') === 'oscuro') {
                document.body.classList.add('dark-mode');
            }
            actualizarTemaNav();

            const usrInfo = JSON.parse(localStorage.getItem('gvi_user'));
            if (usrInfo?.nombre) {
                const userName = document.getElementById('topbarUserName');
                if (userName) userName.innerText = usrInfo.nombre;
                const profileName = document.getElementById('profileName');
                const profileRole = document.getElementById('profileRole');
                const profileAvatar = document.getElementById('profileAvatar');
                if (profileName) profileName.innerText = usrInfo.nombre;
                if (profileRole) profileRole.innerText = usrInfo.rol || 'Perfil activo';
                if (profileAvatar) profileAvatar.innerText = usrInfo.nombre.trim().charAt(0).toUpperCase();
            }
            if (usrInfo && usrInfo.rol !== 'ADMIN') {
                document.querySelectorAll('.admin-only').forEach(el => el.style.display = 'none');
            }
        } catch (e) {}

        const path = window.location.pathname;
        const indicator = document.getElementById('topbarActiveIndicator');

        function moverIndicador(link, instant = false) {
            if (!indicator || !link) return;
            const parentRect = link.parentElement.getBoundingClientRect();
            const rect = link.getBoundingClientRect();
            if (instant) indicator.style.transition = 'none';
            indicator.style.width = `${rect.width}px`;
            indicator.style.height = `${rect.height}px`;
            indicator.style.top = `${rect.top - parentRect.top}px`;
            indicator.style.transform = `translateX(${rect.left - parentRect.left + link.parentElement.scrollLeft}px)`;
            if (instant) {
                indicator.offsetHeight;
                indicator.style.transition = '';
            }
        }

        const activeLink = Array.from(document.querySelectorAll('.topbar-link')).find(link => link.getAttribute('href') === path);
        if (activeLink) {
            activeLink.classList.add('active');
            requestAnimationFrame(() => moverIndicador(activeLink, true));
        }

        document.querySelectorAll('.topbar-link').forEach(link => {
            const href = link.getAttribute('href');
            if (!href || href === '#' || href === path) return;
            link.addEventListener('click', (event) => {
                event.preventDefault();
                document.querySelectorAll('.topbar-link').forEach(item => item.classList.remove('active'));
                link.classList.add('active');
                moverIndicador(link);
                navegarConMovimiento(href);
            });
        });

        document.querySelectorAll('a[href^="/"]').forEach(link => {
            if (link.classList.contains('topbar-link')) return;
            link.addEventListener('click', (event) => {
                const href = link.getAttribute('href');
                if (!href || href === path) return;
                event.preventDefault();
                navegarConMovimiento(href);
            });
        });

        document.addEventListener('click', (event) => {
            const popover = document.getElementById('profilePopover');
            const notifications = document.getElementById('notificationsPopover');
            const userButton = document.querySelector('.topbar-link.user-switch');
            const notificationButton = document.querySelector('.notification-toggle');
            if (popover?.classList.contains('open') && !popover.contains(event.target) && !userButton?.contains(event.target)) {
                popover.classList.remove('open');
            }
            if (notifications?.classList.contains('open') && !notifications.contains(event.target) && !notificationButton?.contains(event.target)) {
                notifications.classList.remove('open');
            }
        });

        window.addEventListener('resize', () => moverIndicador(document.querySelector('.topbar-link.active'), true));
        document.querySelector('.topbar-nav-pill')?.addEventListener('scroll', () => moverIndicador(document.querySelector('.topbar-link.active'), true));
        actualizarRelojTopbar();
        setInterval(actualizarRelojTopbar, 1000);
        consultarActualizacionNav();
        consultarAvisoActualizacionNav();
        setInterval(consultarActualizacionNav, 3500);

        if (typeof lucide !== 'undefined') lucide.createIcons();
    });
</script>

