<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>GVI - Panel de Control</title>
    <style>
        body {
            background:
                radial-gradient(circle at 82% 24%, rgba(0, 122, 255, 0.08), transparent 28%),
                radial-gradient(circle at 14% 34%, rgba(0, 122, 255, 0.09), transparent 34%),
                linear-gradient(145deg, #f8fbff 0%, #f3f6fa 44%, #f6f7f9 100%);
        }

        body.dark-mode {
            background:
                radial-gradient(circle at 82% 24%, rgba(0, 122, 255, 0.13), transparent 28%),
                radial-gradient(circle at 14% 34%, rgba(94, 169, 255, 0.12), transparent 34%),
                linear-gradient(145deg, #10151d 0%, #14171d 46%, #111216 100%);
        }

        html,
        body {
            height: 100%;
            overflow: hidden;
        }

        .dashboard-container {
            height: 100svh;
            padding: clamp(104px, 11vh, 128px) clamp(18px, 4vw, 42px) clamp(28px, 5vh, 48px);
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .dashboard-hero {
            width: min(100%, 1120px);
            display: grid;
            grid-template-columns: minmax(280px, 1fr) auto;
            align-items: end;
            gap: 24px;
            margin-bottom: clamp(24px, 4vh, 34px);
        }

        .hero-copy { text-align: left; }

        .hero-kicker {
            margin: 0 0 8px;
            color: var(--azul-gvi);
            font-size: 12px;
            font-weight: 900;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .hero-title {
            margin: 0;
            color: var(--texto-claro);
            font-size: clamp(32px, 4.6vw, 58px);
            font-weight: 900;
            line-height: 0.98;
            letter-spacing: 0;
        }

        body.dark-mode .hero-title { color: #fff; }

        .hero-subtitle {
            margin: 12px 0 0;
            max-width: 530px;
            color: rgba(28, 30, 33, 0.56);
            font-size: 15px;
            font-weight: 600;
            line-height: 1.45;
        }

        body.dark-mode .hero-subtitle { color: rgba(228, 230, 235, 0.6); }

        .clock-panel {
            min-width: 320px;
            padding: 24px 28px;
            border-radius: 26px;
            background:
                linear-gradient(135deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.68)),
                radial-gradient(circle at 20% 20%, rgba(0, 122, 255, 0.12), transparent 40%);
            border: 1px solid rgba(0, 0, 0, 0.06);
            box-shadow: 0 24px 65px rgba(20, 30, 45, 0.12);
            backdrop-filter: blur(16px);
            text-align: center;
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        body.dark-mode .clock-panel {
            background:
                linear-gradient(135deg, rgba(33, 38, 48, 0.94), rgba(22, 24, 30, 0.78)),
                radial-gradient(circle at 20% 20%, rgba(94, 169, 255, 0.16), transparent 40%);
            border-color: rgba(255, 255, 255, 0.08);
            box-shadow: 0 24px 65px rgba(0, 0, 0, 0.28);
        }

        .clock-panel::before {
            content: "";
            position: absolute;
            inset: 0;
            border-radius: inherit;
            background: linear-gradient(120deg, rgba(0, 122, 255, 0.12), transparent 34%, rgba(52, 199, 89, 0.08));
            opacity: 0.9;
            pointer-events: none;
        }

        .clock-panel > * {
            position: relative;
            z-index: 1;
        }

        .reloj-gigante {
            margin: 0;
            color: #12161d;
            font-size: clamp(54px, 6.6vw, 86px);
            font-weight: 900;
            line-height: 1;
            letter-spacing: 0;
        }

        body.dark-mode .reloj-gigante { color: #fff; }

        .reloj-periodo {
            margin-left: 8px;
            font-size: clamp(16px, 2.5vw, 24px);
            opacity: 0.36;
            letter-spacing: 0;
        }

        .fecha-completa {
            margin-top: 7px;
            font-size: 15px;
            font-weight: 700;
            opacity: 0.58;
            text-transform: capitalize;
        }

        .grid-modulos-pro {
            width: min(100%, 1120px);
            display: grid;
            grid-template-columns: repeat(3, minmax(220px, 1fr));
            gap: clamp(14px, 2vw, 20px);
        }

        .card-menu-pro {
            min-height: 150px;
            padding: 22px;
            border-radius: 22px;
            color: inherit;
            text-decoration: none;
            background: var(--panel-claro);
            border: 1px solid rgba(0, 0, 0, 0.05);
            box-shadow: 0 14px 38px rgba(20, 30, 45, 0.045);
            display: grid;
            grid-template-columns: 54px 1fr;
            grid-template-rows: auto 1fr auto;
            align-items: center;
            align-content: center;
            justify-content: center;
            gap: 0 16px;
            position: relative;
            overflow: hidden;
            transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
        }

        body.dark-mode .card-menu-pro {
            background: var(--panel-oscuro);
            border-color: rgba(255, 255, 255, 0.08);
            box-shadow: 0 14px 38px rgba(0, 0, 0, 0.16);
        }

        .card-menu-pro:hover {
            transform: translateY(-3px);
            border-color: var(--azul-gvi);
            box-shadow: 0 18px 44px rgba(20, 30, 45, 0.09);
        }

        .card-icono-pro {
            grid-row: 1 / span 3;
            width: 54px;
            height: 54px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--azul-gvi);
            background: rgba(0, 122, 255, 0.1);
        }

        body.dark-mode .card-icono-pro {
            color: #5ea9ff;
            background: rgba(94, 169, 255, 0.12);
        }

        .card-icono-pro svg {
            width: 28px;
            height: 28px;
            stroke-width: 2px;
        }

        .card-menu-pro h3 {
            margin: 0 0 6px;
            font-size: clamp(18px, 2vw, 22px);
            font-weight: 800;
        }

        .card-menu-pro p {
            margin: 0;
            font-size: 13px;
            font-weight: 600;
            opacity: 0.56;
        }

        .badge-stats {
            width: fit-content;
            margin-top: 14px;
            padding: 5px 12px;
            border-radius: 20px;
            background: rgba(0, 122, 255, 0.08);
            color: var(--azul-gvi);
            font-size: 11px;
            font-weight: 900;
            letter-spacing: 0.04em;
            text-transform: uppercase;
        }

        .badge-alerta { background: rgba(255, 59, 48, 0.1); color: #ff3b30; }
        .badge-exito { background: rgba(52, 199, 89, 0.1); color: #34c759; }

        @media (max-width: 1000px) {
            .dashboard-hero { grid-template-columns: 1fr; }
            .hero-copy,
            .clock-panel { text-align: center; }
            .hero-subtitle { margin-left: auto; margin-right: auto; }
            .clock-panel { min-width: 0; }
            .grid-modulos-pro { grid-template-columns: repeat(2, minmax(220px, 1fr)); }
        }

        @media (max-width: 700px) {
            .dashboard-container { padding-top: 112px; }
            .grid-modulos-pro { grid-template-columns: 1fr; }
        }

        @media (max-height: 760px) and (min-width: 900px) {
            .dashboard-container { padding-top: 88px; }
            .dashboard-hero { margin-bottom: 16px; }
            .reloj-gigante { font-size: 60px; }
            .card-menu-pro {
                min-height: 126px;
                padding-top: 18px;
                padding-bottom: 18px;
            }
            .card-icono-pro { width: 48px; height: 48px; }
            .card-icono-pro svg { width: 26px; height: 26px; }
            .badge-stats { margin-top: 8px; }
        }
    </style>
</head>
<body>
    <%- include('partials/nav') %>

    <div class="dashboard-container">
        <header class="dashboard-hero">
            <div class="hero-copy">
                <p class="hero-kicker">GVI POS</p>
                <h1 class="hero-title">Centro de ventas</h1>
                <p class="hero-subtitle">Accede rapido a venta, caja, inventario y reportes desde un panel mas ordenado.</p>
            </div>
            <div class="clock-panel">
                <h2 class="reloj-gigante">
                    <span id="relojHome">00:00</span><span id="relojPeriodo" class="reloj-periodo">--</span>
                </h2>
                <div class="fecha-completa" id="fechaHome">...</div>
            </div>
        </header>

        <div class="grid-modulos-pro">
            <a href="/caja" class="card-menu-pro">
                <div class="card-icono-pro"><i data-lucide="shopping-cart"></i></div>
                <h3>Punto de Venta</h3>
                <p>Registrar ventas</p>
                <div class="badge-stats" id="statsVentas">Hoy: $0</div>
            </a>

            <a href="/cobrar" class="card-menu-pro">
                <div class="card-icono-pro"><i data-lucide="credit-card"></i></div>
                <h3>Cobrar</h3>
                <p>Pedidos en cola</p>
                <div class="badge-stats" id="statsPedidos">0 en cola</div>
            </a>

            <a href="/bodega" class="card-menu-pro">
                <div class="card-icono-pro"><i data-lucide="package"></i></div>
                <h3>Bodega</h3>
                <p>Inventario total</p>
                <div class="badge-stats" id="statsStock">Cargando...</div>
            </a>

            <a href="/productos" class="card-menu-pro">
                <div class="card-icono-pro"><i data-lucide="scan-barcode"></i></div>
                <h3>Productos</h3>
                <p>Ingreso rapido</p>
                <div class="badge-stats">Escanear o buscar</div>
            </a>

            <a href="/finanzas" class="card-menu-pro admin-only">
                <div class="card-icono-pro"><i data-lucide="bar-chart-3"></i></div>
                <h3>Finanzas</h3>
                <p>Reportes y caja</p>
                <div class="badge-stats badge-exito">Cierre listo</div>
            </a>

            <a href="/configuracion" class="card-menu-pro admin-only">
                <div class="card-icono-pro"><i data-lucide="settings"></i></div>
                <h3>Ajustes</h3>
                <p>Sistema y red</p>
                <div class="badge-stats">Configuracion</div>
            </a>
        </div>
    </div>

    <%- include('partials/scripts') %>

    <script>
        async function cargarStatsDashboard() {
            try {
                const resProd = await fetch('/api/productos');
                const productos = await resProd.json();
                const stockBajo = productos.filter(p => p.stock <= 5).length;

                const elStock = document.getElementById('statsStock');
                if (stockBajo > 0) {
                    elStock.innerText = `${stockBajo} Stock Bajo`;
                    elStock.classList.add('badge-alerta');
                } else {
                    elStock.innerText = 'Stock al dia';
                }

                const resVentas = await fetch('/api/ventas');
                const ventas = await resVentas.json();
                const hoy = new Date().toLocaleDateString('es-CL');
                const totalHoy = ventas
                    .filter(v => v.fecha === hoy)
                    .reduce((sum, v) => sum + v.total, 0);

                document.getElementById('statsVentas').innerText = `Hoy: $${totalHoy.toLocaleString('es-CL')}`;
            } catch (e) {
                console.error('Error cargando stats', e);
            }
        }

        function actualizarDashboard() {
            const ahora = new Date();
            let horas = ahora.getHours();
            const minutos = String(ahora.getMinutes()).padStart(2, '0');
            const periodo = horas >= 12 ? 'PM' : 'AM';
            horas = horas % 12 || 12;
            document.getElementById('relojHome').innerText = `${String(horas).padStart(2, '0')}:${minutos}`;
            document.getElementById('relojPeriodo').innerText = periodo;
            const opciones = { weekday: 'long', day: 'numeric', month: 'long' };
            document.getElementById('fechaHome').innerText = ahora.toLocaleDateString('es-CL', opciones);
        }

        function cargarDatosUsuario() {
            try {
                const usrInfo = JSON.parse(localStorage.getItem('gvi_user'));
                if (usrInfo && usrInfo.rol !== 'ADMIN') {
                    document.querySelectorAll('.admin-only').forEach(el => el.style.display = 'none');
                }
            } catch (e) {}
        }

        document.addEventListener('DOMContentLoaded', () => {
            actualizarDashboard();
            setInterval(actualizarDashboard, 1000);
            cargarStatsDashboard();
            setInterval(cargarStatsDashboard, 5000);
            cargarDatosUsuario();
            lucide.createIcons();
        });
    </script>
</body>
</html>
