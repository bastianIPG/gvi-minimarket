<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GVI - Login</title>
    <link rel="stylesheet" href="/css/global.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body {
            margin: 0; padding: 0;
            display: flex; justify-content: center; align-items: center;
            min-height: 100vh;
            min-height: 100svh;
            background:
                radial-gradient(circle at top left, rgba(0, 122, 255, 0.14), transparent 34%),
                linear-gradient(135deg, #eef3f8 0%, #f7f9fb 52%, #eef2f6 100%);
            font-family: 'Inter', sans-serif;
            overflow: hidden;
            transition: background 0.3s;
            box-sizing: border-box;
            padding: clamp(10px, 2.5vw, 24px);
        }
        *, *::before, *::after { box-sizing: inherit; }
        body.dark-mode {
            background:
                radial-gradient(circle at top left, rgba(0, 122, 255, 0.18), transparent 34%),
                linear-gradient(135deg, #0f1115 0%, #151922 54%, #101114 100%);
        }

        .login-container {
            background: var(--panel-claro, #ffffff);
            padding: clamp(20px, 4svh, 34px) clamp(18px, 3vw, 32px);
            border-radius: 24px;
            border: 1px solid rgba(15, 23, 42, 0.08);
            box-shadow: 0 24px 70px rgba(20, 30, 45, 0.12);
            text-align: center;
            width: min(100%, 420px);
            max-width: 100%;
            max-height: calc(100svh - 20px);
            animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
            position: relative;
            transition: 0.4s;
            display: flex;
            flex-direction: column;
        }
        body.dark-mode .login-container { background: rgba(30, 30, 30, 0.96); border-color: rgba(255,255,255,0.08); box-shadow: 0 20px 60px rgba(0,0,0,0.4); }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(60px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }

        .login-header h1 { margin: 0; font-size: clamp(26px, 5vw, 34px); font-weight: 800; color: var(--texto-claro, #333); letter-spacing: 0; }
        body.dark-mode .login-header h1 { color: #fff; }
        .login-header p { margin: 6px 0 clamp(18px, 3.5svh, 28px); color: #8e8e93; font-weight: 600; font-size: clamp(13px, 2vw, 15px); }

        .pin-display { display: flex; justify-content: center; gap: clamp(10px, 3vw, 18px); margin-bottom: clamp(20px, 4svh, 30px); }
        .pin-dot {
            width: clamp(20px, 6vw, 28px); height: clamp(20px, 6vw, 28px);
            border-radius: 12px;
            background: rgba(15, 23, 42, 0.08);
            border: 2px solid rgba(15, 23, 42, 0.08);
            box-shadow: inset 0 0 0 1px rgba(255,255,255,0.6);
            transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        body.dark-mode .pin-dot { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.1); box-shadow: none; }
        .pin-dot.filled {
            background: var(--dot-color, var(--azul-gvi, #007aff));
            border-color: rgba(255,255,255,0.9);
            border-radius: var(--dot-radius, 50%);
            transform: translateY(-3px) scale(1.22) rotate(var(--dot-rotate, 0deg));
            box-shadow:
                0 0 0 4px var(--dot-halo, rgba(0, 122, 255, 0.16)),
                0 12px 26px var(--dot-shadow, rgba(0, 122, 255, 0.38));
        }
        .pin-dot.pop { animation: pinPop 0.26s cubic-bezier(0.16, 1, 0.3, 1); }
        @keyframes pinPop {
            0% { transform: scale(0.72); }
            70% { transform: scale(1.22) rotate(var(--dot-rotate, 0deg)); }
            100% { transform: translateY(-2px) scale(1.12) rotate(var(--dot-rotate, 0deg)); }
        }
        .pin-dot.filled:nth-child(1) { --dot-color: #0a84ff; --dot-shadow: rgba(10, 132, 255, 0.48); --dot-halo: rgba(10, 132, 255, 0.18); --dot-radius: 50%; }
        .pin-dot.filled:nth-child(2) { --dot-color: #30d158; --dot-shadow: rgba(48, 209, 88, 0.46); --dot-halo: rgba(48, 209, 88, 0.18); --dot-radius: 9px; --dot-rotate: 45deg; }
        .pin-dot.filled:nth-child(3) { --dot-color: #ff9f0a; --dot-shadow: rgba(255, 159, 10, 0.48); --dot-halo: rgba(255, 159, 10, 0.18); --dot-radius: 7px; }
        .pin-dot.filled:nth-child(4) { --dot-color: #bf5af2; --dot-shadow: rgba(191, 90, 242, 0.5); --dot-halo: rgba(191, 90, 242, 0.2); --dot-radius: 50% 50% 8px 50%; --dot-rotate: -45deg; }

        .numpad { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: clamp(10px, 2svh, 16px) clamp(10px, 3vw, 18px); }
        
        .num-btn {
            background: rgba(0,0,0,0.03);
            border: none; border-radius: 50%;
            width: min(100%, clamp(54px, 10svh, 72px)); height: clamp(54px, 10svh, 72px);
            font-size: clamp(22px, 4.8svh, 28px); font-weight: 700;
            color: var(--texto-claro, #333);
            cursor: pointer;
            margin: 0 auto;
            transition: transform 0.2s, background 0.2s, color 0.2s, box-shadow 0.2s;
            display: flex; align-items: center; justify-content: center;
            touch-action: manipulation;
        }
        body.dark-mode .num-btn { background: rgba(255,255,255,0.05); color: white; }
        .num-btn.input-feedback {
            background: var(--feedback-color, #0a84ff) !important;
            color: white !important;
            transform: scale(1.08);
            box-shadow: 0 0 0 5px var(--feedback-halo, rgba(10, 132, 255, 0.18)), 0 12px 24px var(--feedback-shadow, rgba(10, 132, 255, 0.28));
        }
        
        /* Hover y Active (Feedback táctil visual) */
        @media (hover: hover) {
            .num-btn:hover { background: rgba(0,122,255,0.1); color: var(--azul-gvi); transform: scale(1.05); }
            body.dark-mode .num-btn:hover { background: rgba(255,255,255,0.15); color: white; }
        }
        .num-btn:active { transform: scale(0.9); background: var(--azul-gvi) !important; color: white !important; }
        
        .num-btn.delete { color: #ff3b30; background: transparent; }
        .num-btn.delete:active { background: rgba(255,59,48,0.2) !important; color: #ff3b30 !important; }

        .shake { animation: shakeError 0.5s cubic-bezier(.36,.07,.19,.97) both; }
        @keyframes shakeError {
            10%, 90% { transform: translate3d(-4px, 0, 0); }
            20%, 80% { transform: translate3d(8px, 0, 0); }
            30%, 50%, 70% { transform: translate3d(-12px, 0, 0); }
            40%, 60% { transform: translate3d(12px, 0, 0); }
        }

        .error-msg { 
            color: #ff3b30; font-size: 15px; font-weight: 600; 
            margin-top: 30px; height: 20px; opacity: 0; 
            transition: 0.3s; transform: translateY(-10px);
        }
        .error-msg.visible { opacity: 1; transform: translateY(0); }

        @media (max-height: 620px) {
            .login-container { padding-top: 22px; padding-bottom: 22px; }
            .login-header p { margin-bottom: 22px; }
            .pin-display { margin-bottom: 24px; }
            .numpad { gap: 12px; }
            .error-msg { margin-top: 18px; }
        }

        @media (max-height: 760px) {
            .login-container { border-radius: 20px; padding-top: 18px; padding-bottom: 18px; }
            .login-header p { margin-bottom: 16px; }
            .pin-display { margin-bottom: 18px; }
            .pin-dot { width: 20px; height: 20px; }
            .num-btn { width: 58px; height: 58px; font-size: 24px; }
            .error-msg { margin-top: 12px; height: 18px; font-size: 13px; }
        }

        @media (max-height: 640px) {
            .login-header h1 { font-size: 25px; }
            .login-header p { margin-bottom: 12px; }
            .pin-display { margin-bottom: 14px; }
            .numpad { gap: 8px 12px; }
            .num-btn { width: 50px; height: 50px; font-size: 22px; }
        }

        @media (max-width: 420px) {
            body { padding: 12px; }
            .login-container { padding-left: 18px; padding-right: 18px; }
            .numpad { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px 12px; }
        }
    </style>
</head>
<body class="dark-mode">
    <script>
        if (localStorage.getItem('gvi_theme') === 'light') document.body.classList.remove('dark-mode');
        // Si ya está logueado, redirigir directo
        if (localStorage.getItem('gvi_user')) window.location.href = '/';
    </script>

    <div class="login-container" id="loginBox">
        <div class="login-header">
            <h1>GVI POS</h1>
            <p>Ingresa tu PIN de acceso</p>
        </div>

        <div class="pin-display" id="pinDisplay">
            <div class="pin-dot"></div>
            <div class="pin-dot"></div>
            <div class="pin-dot"></div>
            <div class="pin-dot"></div>
        </div>

        <div class="numpad">
            <button class="num-btn" data-num="1" onclick="addNumber(1)">1</button>
            <button class="num-btn" data-num="2" onclick="addNumber(2)">2</button>
            <button class="num-btn" data-num="3" onclick="addNumber(3)">3</button>
            <button class="num-btn" data-num="4" onclick="addNumber(4)">4</button>
            <button class="num-btn" data-num="5" onclick="addNumber(5)">5</button>
            <button class="num-btn" data-num="6" onclick="addNumber(6)">6</button>
            <button class="num-btn" data-num="7" onclick="addNumber(7)">7</button>
            <button class="num-btn" data-num="8" onclick="addNumber(8)">8</button>
            <button class="num-btn" data-num="9" onclick="addNumber(9)">9</button>
            <div></div>
            <button class="num-btn" data-num="0" onclick="addNumber(0)">0</button>
            <button class="num-btn delete" onclick="deleteNumber()"><i data-lucide="delete"></i></button>
        </div>
        
        <div class="error-msg" id="errorMsg">PIN Incorrecto</div>
    </div>

    <script>
        lucide.createIcons();
        let currentPin = '';
        const dots = document.querySelectorAll('.pin-dot');
        const errorMsg = document.getElementById('errorMsg');
        const loginBox = document.getElementById('loginBox');
        let isProcessing = false;
        const feedbackColors = [
            { color: '#0a84ff', halo: 'rgba(10, 132, 255, 0.18)', shadow: 'rgba(10, 132, 255, 0.36)' },
            { color: '#30d158', halo: 'rgba(48, 209, 88, 0.18)', shadow: 'rgba(48, 209, 88, 0.34)' },
            { color: '#ff9f0a', halo: 'rgba(255, 159, 10, 0.18)', shadow: 'rgba(255, 159, 10, 0.34)' },
            { color: '#bf5af2', halo: 'rgba(191, 90, 242, 0.2)', shadow: 'rgba(191, 90, 242, 0.36)' }
        ];

        function updateDots() {
            dots.forEach((dot, index) => {
                const shouldFill = index < currentPin.length;
                dot.classList.toggle('filled', shouldFill);
                if (!shouldFill) dot.classList.remove('pop');
            });
        }

        function animateLatestDot() {
            const dot = dots[currentPin.length - 1];
            if (!dot) return;
            dot.classList.remove('pop');
            void dot.offsetWidth;
            dot.classList.add('pop');
        }

        function animatePressedNumber(num) {
            const btn = document.querySelector(`[data-num="${num}"]`);
            if (!btn) return;
            const color = feedbackColors[(currentPin.length - 1) % feedbackColors.length];
            btn.style.setProperty('--feedback-color', color.color);
            btn.style.setProperty('--feedback-halo', color.halo);
            btn.style.setProperty('--feedback-shadow', color.shadow);
            btn.classList.remove('input-feedback');
            void btn.offsetWidth;
            btn.classList.add('input-feedback');
            setTimeout(() => btn.classList.remove('input-feedback'), 520);
        }

        async function addNumber(num) {
            if (currentPin.length < 4 && !isProcessing) {
                currentPin += num;
                updateDots();
                animateLatestDot();
                animatePressedNumber(num);
                errorMsg.classList.remove('visible');
                
                if (currentPin.length === 4) {
                    await attemptLogin();
                }
            }
        }

        function deleteNumber() {
            if (currentPin.length > 0 && !isProcessing) {
                currentPin = currentPin.slice(0, -1);
                updateDots();
                errorMsg.classList.remove('visible');
            }
        }

        // Permitir usar el teclado físico (Numpad)
        document.addEventListener('keydown', (e) => {
            if (e.key >= '0' && e.key <= '9') addNumber(e.key);
            if (e.key === 'Backspace') deleteNumber();
        });

        async function attemptLogin() {
            isProcessing = true;
            try {
                const res = await fetch('/api/login', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ pin: currentPin })
                });
                const data = await res.json();
                
                if (data.success) {
                    localStorage.setItem('gvi_user', JSON.stringify(data.user));
                    
                    // Animación de éxito
                    dots.forEach(d => d.style.background = '#34c759'); // Verde
                    loginBox.style.transform = 'scale(0.95)';
                    loginBox.style.opacity = '0';
                    
                    setTimeout(() => window.location.href = '/', 400);
                } else {
                    // Animación de error
                    currentPin = '';
                    updateDots();
                    loginBox.classList.add('shake');
                    errorMsg.innerText = "PIN Incorrecto";
                    errorMsg.classList.add('visible');
                    
                    setTimeout(() => {
                        loginBox.classList.remove('shake');
                        isProcessing = false;
                    }, 500);
                }
            } catch (e) {
                errorMsg.innerText = "Error de conexión";
                errorMsg.classList.add('visible');
                currentPin = ''; updateDots();
                isProcessing = false;
            }
        }
    </script>
</body>
</html>
