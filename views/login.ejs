<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GVI - Login</title>
    <link rel="stylesheet" href="/css/global.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            min-height: 100svh;
            display: grid;
            place-items: center;
            padding: clamp(18px, 3vw, 30px);
            background:
                radial-gradient(circle at top left, rgba(0, 122, 255, 0.18), transparent 36%),
                linear-gradient(135deg, #0f1115 0%, #151922 54%, #101114 100%);
            color: white;
            font-family: 'Poppins', sans-serif;
            overflow: hidden;
            box-sizing: border-box;
        }

        *, *::before, *::after { box-sizing: inherit; }

        .shell {
            width: min(720px, 100%);
            display: grid;
            gap: 22px;
        }

        .brand {
            text-align: center;
        }

        .brand h1 {
            margin: 0;
            font-size: clamp(42px, 7vw, 72px);
            line-height: 0.95;
            font-weight: 900;
            letter-spacing: 0;
        }

        .brand p {
            margin: 8px 0 0;
            color: rgba(255,255,255,0.62);
            font-size: clamp(14px, 1.8vw, 18px);
            font-weight: 500;
        }

        .panel-login {
            background: transparent;
            border: none;
            box-shadow: none;
            border-radius: 0;
            padding: 0;
        }

        .app-close {
            position: fixed;
            top: 20px;
            right: 22px;
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: 1px solid rgba(255,255,255,0.1);
            background: rgba(255,255,255,0.06);
            color: rgba(255,255,255,0.78);
            display: grid;
            place-items: center;
            cursor: pointer;
            transition: background-color 0.16s ease, color 0.16s ease, border-color 0.16s ease;
            z-index: 20;
        }

        .app-close:hover {
            background: rgba(255,59,48,0.16);
            border-color: rgba(255,59,48,0.28);
            color: white;
        }

        .perfiles {
            display: flex;
            gap: 18px;
            align-items: center;
            justify-content: center;
            flex-wrap: wrap;
        }

        .perfil-card {
            border: 1px solid transparent;
            background: transparent;
            color: white;
            border-radius: 20px;
            padding: 10px 12px 12px;
            width: 132px;
            min-height: 144px;
            display: grid;
            place-items: center;
            align-content: center;
            gap: 9px;
            cursor: pointer;
            font-family: inherit;
            transition: background-color 0.16s ease, transform 0.16s ease, border-color 0.16s ease;
        }

        .perfil-card:hover {
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,255,255,0.12);
            transform: translateY(-2px);
        }

        .avatar {
            width: 82px;
            height: 82px;
            border-radius: 50%;
            background: linear-gradient(135deg, #007aff, #34c759);
            display: grid;
            place-items: center;
            font-size: 28px;
            font-weight: 900;
            box-shadow: 0 12px 28px rgba(0,122,255,0.28);
            border: 3px solid rgba(255,255,255,0.18);
        }

        .perfil-card b {
            font-size: 15px;
            line-height: 1.15;
            text-align: center;
        }

        .perfil-card span {
            font-size: 10px;
            color: rgba(255,255,255,0.58);
            font-weight: 800;
            text-transform: uppercase;
            text-align: center;
        }

        .pin-view {
            display: none;
            width: min(360px, 100%);
            margin: 0 auto;
            text-align: center;
            background: rgba(255,255,255,0.055);
            border: 1px solid rgba(255,255,255,0.09);
            border-radius: 22px;
            padding: 18px;
        }

        .pin-top {
            display: flex;
            align-items: center;
            gap: 12px;
            justify-content: center;
            margin-bottom: 12px;
        }

        .btn-back {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            border: none;
            background: rgba(255,255,255,0.1);
            color: white;
            display: inline-grid;
            place-items: center;
            cursor: pointer;
        }

        .pin-title h2 {
            margin: 0;
            font-size: 20px;
        }

        .pin-title p {
            margin: 4px 0 0;
            color: rgba(255,255,255,0.58);
            font-size: 13px;
        }

        .pin-display {
            display: flex;
            justify-content: center;
            gap: 14px;
            margin: 16px 0 18px;
        }

        .pin-dot {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: rgba(255,255,255,0.08);
            border: 2px solid rgba(255,255,255,0.16);
            transition: transform 0.18s ease, background-color 0.18s ease, border-radius 0.18s ease;
        }

        .pin-dot.filled:nth-child(1) { background: #1e90ff; box-shadow: 0 0 0 5px rgba(30,144,255,0.18); }
        .pin-dot.filled:nth-child(2) { background: #34c759; border-radius: 8px; transform: rotate(45deg) scale(1.08); }
        .pin-dot.filled:nth-child(3) { background: #ffb340; border-radius: 7px; }
        .pin-dot.filled:nth-child(4) { background: #d56bff; border-radius: 50% 50% 8px 50%; transform: rotate(-45deg) scale(1.08); }
        .pin-dot.filled:nth-child(5), .pin-dot.filled:nth-child(6) { background: #ff3b30; }

        .numpad {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 9px;
        }

        .num-btn {
            width: 58px;
            height: 58px;
            margin: 0 auto;
            border-radius: 50%;
            border: none;
            background: rgba(255,255,255,0.08);
            color: white;
            font-family: inherit;
            font-size: 21px;
            font-weight: 800;
            cursor: pointer;
        }

        .num-btn:active { background: #007aff; }
        .num-btn.delete { color: #ff7b72; background: transparent; }

        .setup-view {
            display: none;
            max-width: 620px;
            margin: 0 auto;
        }

        .setup-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 14px;
        }

        .field {
            display: grid;
            gap: 7px;
        }

        .field label {
            font-size: 12px;
            color: rgba(255,255,255,0.62);
            font-weight: 800;
            text-transform: uppercase;
        }

        .input {
            width: 100%;
            border: 1px solid rgba(255,255,255,0.12);
            background: rgba(255,255,255,0.08);
            color: white;
            border-radius: 14px;
            padding: 14px 16px;
            font-family: inherit;
            font-size: 15px;
            outline: none;
        }

        .input:focus { border-color: #007aff; box-shadow: 0 0 0 4px rgba(0,122,255,0.16); }

        .extra-users {
            display: grid;
            gap: 10px;
            margin: 18px 0;
        }

        .extra-row {
            display: grid;
            grid-template-columns: 1fr 130px 130px auto;
            gap: 10px;
        }

        .btn-primary, .btn-secondary {
            border: none;
            border-radius: 14px;
            padding: 14px 18px;
            font-family: inherit;
            font-weight: 900;
            cursor: pointer;
        }

        .btn-primary { background: #007aff; color: white; }
        .btn-secondary { background: rgba(255,255,255,0.1); color: white; }
        .error { min-height: 20px; margin-top: 14px; color: #ff7b72; font-weight: 700; text-align: center; }

        @media (max-width: 680px) {
            body { overflow: auto; }
            .setup-grid, .extra-row { grid-template-columns: 1fr; }
            .num-btn { width: 54px; height: 54px; }
            .perfil-card { width: 116px; min-height: 132px; }
            .avatar { width: 72px; height: 72px; }
        }
    </style>
</head>
<body>
    <script>
        localStorage.removeItem('gvi_user');
    </script>

    <button class="app-close" onclick="cerrarApp()" title="Cerrar GVI"><i data-lucide="x"></i></button>

    <main class="shell">
        <section class="brand">
            <h1>GVI</h1>
            <p>Gestor de Ventas Intuitivo</p>
        </section>

        <section class="panel-login">
            <div id="profilesView">
                <div class="perfiles" id="profilesList"></div>
            </div>

            <div class="pin-view" id="pinView">
                <div class="pin-top">
                    <button class="btn-back" onclick="volverPerfiles()"><i data-lucide="arrow-left"></i></button>
                    <div class="pin-title">
                        <h2 id="perfilNombre">Perfil</h2>
                        <p>Ingresa tu PIN</p>
                    </div>
                </div>
                <div class="pin-display" id="pinDisplay"></div>
                <div class="numpad">
                    <button class="num-btn" onclick="addNumber(1)">1</button>
                    <button class="num-btn" onclick="addNumber(2)">2</button>
                    <button class="num-btn" onclick="addNumber(3)">3</button>
                    <button class="num-btn" onclick="addNumber(4)">4</button>
                    <button class="num-btn" onclick="addNumber(5)">5</button>
                    <button class="num-btn" onclick="addNumber(6)">6</button>
                    <button class="num-btn" onclick="addNumber(7)">7</button>
                    <button class="num-btn" onclick="addNumber(8)">8</button>
                    <button class="num-btn" onclick="addNumber(9)">9</button>
                    <div></div>
                    <button class="num-btn" onclick="addNumber(0)">0</button>
                    <button class="num-btn delete" onclick="deleteNumber()"><i data-lucide="delete"></i></button>
                </div>
                <div class="error" id="pinError"></div>
            </div>

            <div class="setup-view" id="setupView">
                <div class="pin-title" style="text-align:center; margin-bottom:20px;">
                    <h2>Crear primer administrador</h2>
                    <p>Este perfil tendra control total del sistema.</p>
                </div>
                <div class="setup-grid">
                    <div class="field">
                        <label>Nombre administrador</label>
                        <input class="input" id="setupAdminNombre" value="Administrador">
                    </div>
                    <div class="field">
                        <label>PIN administrador</label>
                        <input class="input" id="setupAdminPin" maxlength="6" inputmode="numeric" placeholder="1234">
                    </div>
                </div>
                <div class="extra-users" id="extraUsers"></div>
                <div style="display:flex; gap:10px; justify-content:center; flex-wrap:wrap;">
                    <button class="btn-secondary" onclick="agregarUsuarioSetup()">Agregar otro rol</button>
                    <button class="btn-primary" onclick="guardarSetup()">Crear perfiles</button>
                </div>
                <div class="error" id="setupError"></div>
            </div>
        </section>
    </main>

    <script>
        let perfiles = [];
        let perfilSeleccionado = null;
        let currentPin = '';
        let procesando = false;

        function iniciales(nombre) {
            return String(nombre || 'G').trim().split(/\s+/).slice(0, 2).map(p => p[0]).join('').toUpperCase();
        }

        function renderDots() {
            const max = Math.max(4, currentPin.length || 4);
            document.getElementById('pinDisplay').innerHTML = Array.from({ length: max }, (_, i) =>
                `<div class="pin-dot ${i < currentPin.length ? 'filled' : ''}"></div>`
            ).join('');
        }

        async function cargarAuth() {
            const res = await fetch('/api/auth-state');
            const data = await res.json();
            perfiles = data.users || [];
            if (!data.hasUsers) {
                document.getElementById('profilesView').style.display = 'none';
                document.getElementById('setupView').style.display = 'block';
                lucide.createIcons();
                return;
            }
            renderPerfiles();
        }

        async function cerrarApp() {
            try {
                localStorage.removeItem('gvi_user');
                await fetch('/api/app/quit', { method: 'POST' });
            } catch (_) {
                window.close();
            }
        }

        function renderPerfiles() {
            document.getElementById('profilesView').style.display = 'block';
            document.getElementById('pinView').style.display = 'none';
            document.getElementById('setupView').style.display = 'none';
            document.getElementById('profilesList').innerHTML = perfiles.map(p => `
                <button class="perfil-card" onclick="seleccionarPerfil(${p.id})">
                    <div class="avatar">${iniciales(p.nombre)}</div>
                    <b>${p.nombre}</b>
                    <span>${p.temporal ? 'Perfil temporal · ' : ''}${p.rol}</span>
                </button>
            `).join('');
            lucide.createIcons();
        }

        function seleccionarPerfil(id) {
            perfilSeleccionado = perfiles.find(p => p.id === id);
            currentPin = '';
            document.getElementById('perfilNombre').innerText = perfilSeleccionado.nombre;
            document.getElementById('pinError').innerText = '';
            document.getElementById('profilesView').style.display = 'none';
            document.getElementById('pinView').style.display = 'block';
            renderDots();
            lucide.createIcons();
        }

        function volverPerfiles() {
            perfilSeleccionado = null;
            currentPin = '';
            renderPerfiles();
        }

        async function addNumber(num) {
            if (procesando || !perfilSeleccionado || currentPin.length >= 6) return;
            currentPin += String(num);
            renderDots();
            document.getElementById('pinError').innerText = '';
            if (currentPin.length >= 4) await intentarLogin();
        }

        function deleteNumber() {
            if (procesando) return;
            currentPin = currentPin.slice(0, -1);
            renderDots();
        }

        async function intentarLogin() {
            procesando = true;
            try {
                const res = await fetch('/api/login', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ nombre: perfilSeleccionado.nombre, pin: currentPin })
                });
                const data = await res.json();
                if (data.success) {
                    localStorage.setItem('gvi_user', JSON.stringify(data.user));
                    window.location.href = '/';
                    return;
                }
                document.getElementById('pinError').innerText = 'PIN incorrecto';
            } catch (_) {
                document.getElementById('pinError').innerText = 'Error de conexion';
            }
            currentPin = '';
            renderDots();
            procesando = false;
        }

        function agregarUsuarioSetup() {
            const id = Date.now();
            document.getElementById('extraUsers').insertAdjacentHTML('beforeend', `
                <div class="extra-row" data-row="${id}">
                    <input class="input extra-nombre" placeholder="Nombre perfil">
                    <select class="input extra-rol">
                        <option value="CAJA">Caja</option>
                        <option value="ADMIN">Administrador</option>
                    </select>
                    <input class="input extra-pin" maxlength="6" inputmode="numeric" placeholder="PIN">
                    <button class="btn-secondary" onclick="this.closest('.extra-row').remove()">Quitar</button>
                </div>
            `);
        }

        async function guardarSetup() {
            const admin = {
                nombre: document.getElementById('setupAdminNombre').value.trim(),
                pin: document.getElementById('setupAdminPin').value.trim()
            };
            const usuarios = Array.from(document.querySelectorAll('.extra-row')).map(row => ({
                nombre: row.querySelector('.extra-nombre').value.trim(),
                rol: row.querySelector('.extra-rol').value,
                pin: row.querySelector('.extra-pin').value.trim()
            })).filter(u => u.nombre || u.pin);

            try {
                const res = await fetch('/api/setup-users', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ admin, usuarios })
                });
                const data = await res.json();
                if (!data.success) {
                    document.getElementById('setupError').innerText = data.message || 'No se pudieron crear los perfiles';
                    return;
                }
                await cargarAuth();
            } catch (_) {
                document.getElementById('setupError').innerText = 'Error de conexion';
            }
        }

        document.addEventListener('keydown', (e) => {
            if (e.key >= '0' && e.key <= '9') addNumber(e.key);
            if (e.key === 'Backspace') deleteNumber();
            if (e.key === 'Escape' && perfilSeleccionado) volverPerfiles();
        });

        document.addEventListener('DOMContentLoaded', () => {
            cargarAuth();
            lucide.createIcons();
        });
    </script>
</body>
</html>
