<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>GVI - Gestión de Bodega</title>
    <style>
        /* --- ESTADÍSTICAS SUPERIORES --- */
        .stats-bodega {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 14px;
            margin-bottom: 18px;
            margin-top: 8px;
        }
        .stat-card {
            background: var(--panel-claro);
            padding: 14px 16px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.018);
            border: 1px solid rgba(0,0,0,0.05);
        }
        body.dark-mode .stat-card { background: var(--panel-oscuro); border-color: #333; }
        .stat-icon { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: white; font-size: 18px; flex: 0 0 auto; }
        .stat-info span { display: block; font-size: 12px; opacity: 0.6; font-weight: 700; text-transform: uppercase; }
        .stat-info b { font-size: 19px; font-weight: 900; }

        /* --- CONTROLES Y BUSQUEDA --- */
        .controles-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 18px;
            gap: 12px;
            background: var(--panel-claro);
            padding: 12px;
            border-radius: 16px;
            box-shadow: 0 3px 12px rgba(0,0,0,0.018);
        }
        body.dark-mode .controles-top { background: var(--panel-oscuro); border: 1px solid #333; }

        .busqueda-wrapper {
            position: relative;
            flex: 1;
            display: flex;
            align-items: center;
        }
        .busqueda-wrapper i, .busqueda-wrapper svg {
            position: absolute;
            left: 18px;
            opacity: 0.5;
            pointer-events: none;
            width: 18px;
            height: 18px;
        }
        .input-busqueda {
            width: 100%;
            padding: 12px 14px 12px 45px;
            border-radius: 12px;
            border: 1px solid rgba(0,0,0,0.1);
            background: rgba(0,0,0,0.02);
            color: inherit;
            font-size: 14px;
            outline: none;
            transition: border-color 0.16s ease, background-color 0.16s ease;
        }
        body.dark-mode .input-busqueda { background: rgba(255,255,255,0.03); border-color: #444; }
        .input-busqueda:focus { border-color: var(--azul-gvi); background: transparent; }

        /* --- TABLA PREMIUM --- */
        .tabla-contenedor {
            background: var(--panel-claro);
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 5px 16px rgba(0,0,0,0.025);
            border: 1px solid rgba(0,0,0,0.05);
        }
        body.dark-mode .tabla-contenedor { background: var(--panel-oscuro); border-color: #333; }
        
        table { width: 100%; border-collapse: collapse; }
        th { 
            padding: 13px 18px;
            text-align: left; 
            background: rgba(0,0,0,0.02); 
            font-size: 12px; 
            text-transform: uppercase; 
            letter-spacing: 1px; 
            opacity: 0.6; 
        }
        body.dark-mode th { background: rgba(255,255,255,0.02); }
        td { padding: 12px 18px; border-bottom: 1px solid rgba(0,0,0,0.03); }
        body.dark-mode td { border-bottom-color: rgba(255,255,255,0.03); }
        
        tr:hover { background: rgba(0,122,255,0.02); }

        .badge-stock {
            padding: 6px 12px;
            border-radius: 8px;
            font-weight: 800;
            font-size: 12px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        .stock-crítico { background: rgba(255, 59, 48, 0.1); color: #ff3b30; }
        .stock-bajo { background: rgba(255, 149, 0, 0.1); color: #ff9500; }
        .stock-normal { background: rgba(52, 199, 89, 0.1); color: #34c759; }

        /* --- BOTONES RÁPIDOS --- */
        .btn-quick {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: none;
            background: rgba(0,0,0,0.05);
            cursor: pointer;
            transition: background-color 0.14s ease, color 0.14s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        body.dark-mode .btn-quick { background: rgba(255,255,255,0.08); color: white; }
        .btn-quick:hover { background: var(--azul-gvi); color: white; }
        .btn-quick:active { background: rgba(0,122,255,0.18); }

        .acciones-gap { display: flex; gap: 8px; align-items: center; }

        .btn-add { background: var(--azul-gvi); color: white; border: none; padding: 12px 18px; border-radius: 12px; font-weight: 800; cursor: pointer; display: flex; align-items: center; gap: 8px; transition: background-color 0.16s ease, box-shadow 0.16s ease; }
        .btn-add:hover { box-shadow: 0 4px 12px rgba(0,122,255,0.24); }

        .filtro-btn { 
            padding: 8px 16px; border-radius: 50px; border: none;
            background: rgba(0,0,0,0.05); cursor: pointer; font-weight: 800; 
            font-size: 13px; color: inherit; transition: background-color 0.16s ease, color 0.16s ease, box-shadow 0.16s ease;
        }
        body.dark-mode .filtro-btn { background: rgba(255,255,255,0.08); }
        .filtro-btn:hover { background: rgba(0,122,255,0.1); color: var(--azul-gvi); }
        .filtro-btn.activo { background: var(--azul-gvi); color: white; box-shadow: 0 4px 12px rgba(0,122,255,0.3); }

        /* Estilo circular para acciones de tabla */
        .btn-tabla-accion {
            width: 36px; height: 36px; border-radius: 50%; border: none;
            display: inline-flex; align-items: center; justify-content: center;
            background: rgba(0,0,0,0.04); cursor: pointer; transition: background-color 0.14s ease, color 0.14s ease;
            color: inherit;
        }
        body.dark-mode .btn-tabla-accion { background: rgba(255,255,255,0.08); }
        .btn-tabla-accion:hover { background: var(--azul-gvi); color: white; }
        .btn-tabla-accion.btn-borrar:hover { background: #ff3b30; }

        /* MODAL */
        .modal-fondo { display: none; position: fixed; inset: 0; width:100%; height:100%; background:rgba(0,0,0,0.48); z-index:9000; align-items:center; justify-content:center; padding: 18px; box-sizing: border-box; }
        .panel-modal { 
            background: var(--panel-claro); 
            width: 480px; 
            padding: 40px; 
            border-radius: 32px; 
            box-shadow: 0 12px 30px rgba(0,0,0,0.16); 
            max-height: calc(100vh - 36px);
            overflow-y: auto;
        }
        body.dark-mode .panel-modal { background: var(--panel-oscuro); border: 1px solid #333; }

        .panel-admin-auth {
            width: min(390px, calc(100vw - 36px));
            padding: 0;
            overflow: hidden;
            border-radius: 24px;
            text-align: center;
        }

        .admin-auth-header {
            padding: 26px 28px 20px;
            background: linear-gradient(135deg, rgba(255,59,48,0.12), rgba(0,122,255,0.07));
            border-bottom: 1px solid rgba(0,0,0,0.06);
        }

        body.dark-mode .admin-auth-header { border-bottom-color: #333; }

        .admin-auth-icon {
            width: 54px;
            height: 54px;
            margin: 0 auto 12px;
            border-radius: 17px;
            background: #ff3b30;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 8px 18px rgba(255,59,48,0.24);
        }

        .admin-auth-icon svg { width: 28px; height: 28px; }

        .admin-auth-header h2 {
            margin: 0;
            font-size: 22px;
            line-height: 1.1;
        }

        .admin-auth-header p {
            margin: 9px 0 0;
            font-size: 13px;
            line-height: 1.35;
            opacity: 0.68;
            font-weight: 600;
        }

        .admin-auth-body {
            padding: 22px 26px 26px;
        }

        #inputPinAdmin {
            text-align: center;
            letter-spacing: 10px;
            font-size: 26px;
            font-weight: 900;
            padding: 14px 14px 14px 24px;
        }

        .admin-auth-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-top: 18px;
        }

        body.modal-abierto { overflow: hidden; }

        .form-group { margin-bottom: 20px; position: relative; }
        .form-label { display: block; margin-bottom: 8px; font-weight: 700; font-size: 13px; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.5px; }
        
        .input-with-icon { position: relative; display: flex; align-items: center; }
        .input-with-icon i, .input-with-icon svg { position: absolute; left: 15px; opacity: 0.4; width: 18px; height: 18px; }
        
        .form-input { 
            width: 100%; 
            padding: 14px 15px 14px 45px; 
            border-radius: 14px; 
            border: 1px solid rgba(0,0,0,0.1); 
            background: rgba(0,0,0,0.02); 
            font-size: 15px; 
            outline: none; 
            transition: border-color 0.16s ease, box-shadow 0.16s ease, background-color 0.16s ease;
            color: inherit;
        }
        body.dark-mode .form-input { background: rgba(255,255,255,0.05); border-color: #444; }
        .form-input:focus { border-color: var(--azul-gvi); background: transparent; box-shadow: 0 0 0 4px rgba(0,122,255,0.1); }

        .toggle-peso {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 15px 20px;
            background: rgba(0,122,255,0.05);
            border-radius: 16px;
            cursor: pointer;
            transition: background-color 0.16s ease;
        }
        .toggle-peso:hover { background: rgba(0,122,255,0.1); }

        .opciones-comerciales {
            display: grid;
            gap: 12px;
            margin-bottom: 22px;
        }

        .opcion-comercial {
            border: 1px solid rgba(0,0,0,0.08);
            border-radius: 16px;
            padding: 14px;
            background: rgba(0,0,0,0.018);
        }

        body.dark-mode .opcion-comercial {
            border-color: #333;
            background: rgba(255,255,255,0.04);
        }

        .opcion-comercial-head {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: center;
            cursor: pointer;
        }

        .opcion-comercial-head b {
            display: block;
            font-size: 14px;
        }

        .opcion-comercial-head span {
            display: block;
            margin-top: 3px;
            font-size: 11px;
            opacity: 0.58;
            font-weight: 700;
        }

        .opcion-comercial-head input {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

        .opcion-comercial-campos {
            display: none;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-top: 14px;
        }

        .opcion-comercial.activa .opcion-comercial-campos {
            display: grid;
        }

        .badge-precio {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 8px;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 900;
            margin-top: 5px;
        }

        .badge-oferta { background: rgba(255,59,48,0.1); color: #ff3b30; }
        .badge-mayor { background: rgba(0,122,255,0.1); color: var(--azul-gvi); }

        .filtros-bodega {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            justify-content: flex-start;
            margin-bottom: 18px;
        }

        .contenedor.bodega-shell {
            max-width: 1520px;
            margin-top: 28px;
        }

        body.dark-mode .bodega-shell {
            --texto-suave: rgba(246, 247, 251, 0.66);
            --superficie-suave: rgba(255, 255, 255, 0.08);
        }

        .bodega-hero {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            gap: 24px;
            margin: 26px 0 18px;
        }

        .bodega-kicker {
            margin-bottom: 7px;
            font-size: 12px;
            font-weight: 950;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: var(--azul-gvi);
        }

        .bodega-hero h1 {
            margin: 0;
            font-size: clamp(32px, 3.1vw, 48px);
            line-height: 1;
            letter-spacing: -0.04em;
        }

        .bodega-hero p {
            margin: 9px 0 0;
            color: var(--texto-suave);
            font-weight: 750;
        }

        .bodega-health {
            min-width: 260px;
            padding: 14px 16px;
            border: 1px solid rgba(36, 47, 70, 0.1);
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.66);
            box-shadow: 0 18px 46px rgba(42, 53, 77, 0.08);
        }

        body.dark-mode .bodega-health {
            background: rgba(255,255,255,0.045);
            border-color: rgba(255,255,255,0.08);
        }

        .bodega-health span {
            display: block;
            color: var(--texto-suave);
            font-size: 11px;
            font-weight: 950;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .bodega-health b {
            display: block;
            margin-top: 4px;
            font-size: 24px;
            line-height: 1;
            font-variant-numeric: tabular-nums;
        }

        .bodega-health small {
            display: block;
            margin-top: 8px;
            color: var(--texto-suave);
            font-weight: 800;
        }

        .stats-bodega {
            grid-template-columns: repeat(6, minmax(150px, 1fr));
            gap: 12px;
        }

        .stat-card {
            min-height: 76px;
            padding: 14px;
            border-radius: 18px;
            box-shadow: 0 16px 42px rgba(42, 53, 77, 0.07);
            border-color: rgba(36, 47, 70, 0.08);
        }

        body.dark-mode .stat-card {
            border-color: rgba(255,255,255,0.08);
            box-shadow: 0 18px 46px rgba(0,0,0,0.2);
        }

        .stat-icon {
            width: 46px;
            height: 46px;
            border-radius: 15px;
        }

        .stat-info span {
            color: var(--texto-suave);
            opacity: 1;
            font-size: 11px;
            letter-spacing: 0.04em;
        }

        .stat-info b {
            font-size: 22px;
            line-height: 1.1;
            font-variant-numeric: tabular-nums;
        }

        .bodega-command {
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 12px;
            align-items: center;
            margin-bottom: 14px;
            background: var(--panel-claro);
            padding: 12px;
            border-radius: 22px;
            box-shadow: 0 18px 46px rgba(42, 53, 77, 0.08);
            border: 1px solid rgba(36, 47, 70, 0.08);
        }

        body.dark-mode .bodega-command {
            background: var(--panel-oscuro);
            border-color: rgba(255,255,255,0.08);
        }

        .controles-top {
            display: contents;
        }

        .input-busqueda {
            min-height: 58px;
            border-radius: 17px;
            border-color: rgba(36, 47, 70, 0.12);
            background: rgba(15,23,42,0.035);
            font-size: 17px;
            font-weight: 800;
        }

        body.dark-mode .input-busqueda {
            color: var(--texto-oscuro);
            background: rgba(255,255,255,0.055);
            border-color: rgba(255,255,255,0.1);
        }

        .input-busqueda::placeholder {
            color: rgba(17,24,39,0.42);
        }

        body.dark-mode .input-busqueda::placeholder {
            color: rgba(246,247,251,0.38);
        }

        .btn-add {
            min-height: 58px;
            border-radius: 17px;
            padding: 0 22px;
            font-size: 16px;
            box-shadow: 0 14px 28px rgba(61,115,255,0.22);
        }

        .bodega-filter-row {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            align-items: center;
            margin-bottom: 14px;
        }

        .filtros-bodega {
            margin-bottom: 0;
        }

        .filtro-btn {
            min-height: 42px;
            padding: 0 15px;
            border: 1px solid rgba(36,47,70,0.08);
            background: rgba(255,255,255,0.7);
            box-shadow: none;
        }

        body.dark-mode .filtro-btn {
            color: rgba(246,247,251,0.86);
            background: rgba(255,255,255,0.055);
            border-color: rgba(255,255,255,0.08);
        }

        .bodega-view-tools {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--texto-suave);
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
        }

        .tabla-contenedor {
            border-radius: 24px;
            box-shadow: 0 24px 70px rgba(42, 53, 77, 0.1);
            border-color: rgba(36,47,70,0.08);
        }

        body.dark-mode .tabla-contenedor {
            border-color: rgba(255,255,255,0.08);
            box-shadow: 0 24px 70px rgba(0,0,0,0.24);
        }

        .tabla-contenedor table {
            table-layout: fixed;
        }

        .tabla-contenedor th {
            padding: 15px 18px;
            color: var(--texto-suave);
            opacity: 1;
            font-size: 11px;
            background: rgba(15,23,42,0.025);
        }

        body.dark-mode .tabla-contenedor th {
            color: rgba(246,247,251,0.58);
            background: rgba(255,255,255,0.026);
        }

        .tabla-contenedor td {
            padding: 14px 18px;
            vertical-align: middle;
        }

        .producto-cell {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .producto-mark {
            width: 38px;
            height: 38px;
            border-radius: 13px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(61,115,255,0.1);
            color: var(--azul-gvi);
            flex: 0 0 auto;
        }

        .producto-name {
            min-width: 0;
        }

        .producto-name b {
            display: block;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-size: 15px;
        }

        .producto-name small {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-top: 4px;
            color: var(--texto-suave);
            font-size: 11px;
            font-weight: 900;
            text-transform: uppercase;
        }

        .codigo-pill {
            display: inline-flex;
            max-width: 100%;
            padding: 7px 10px;
            border-radius: 10px;
            background: rgba(15,23,42,0.045);
            color: var(--texto-suave);
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
            font-size: 12px;
            font-weight: 800;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        body.dark-mode .codigo-pill {
            background: rgba(255,255,255,0.06);
        }

        .precio-stack {
            font-weight: 950;
            font-variant-numeric: tabular-nums;
        }

        .precio-stack .badge-precio {
            margin-right: 5px;
        }

        .stock-crítico {
            background: rgba(255, 59, 48, 0.12);
            color: #ff453a;
        }

        .stock-sin-stock {
            background: rgba(17, 24, 39, 0.08);
            color: #6b7280;
        }

        body.dark-mode .stock-sin-stock {
            background: rgba(255,255,255,0.08);
            color: rgba(246,247,251,0.7);
        }

        .estado-inventario {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 7px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 950;
            white-space: nowrap;
        }

        .estado-ok { background: rgba(40,199,111,0.1); color: #25b35e; }
        .estado-alerta { background: rgba(255,149,0,0.11); color: #f59f00; }
        .estado-critico { background: rgba(255,59,48,0.11); color: #ff453a; }
        .estado-agotado { background: rgba(107,114,128,0.12); color: #6b7280; }

        .acciones-gap {
            gap: 7px;
        }

        .btn-quick,
        .btn-tabla-accion {
            border: 1px solid rgba(36,47,70,0.08);
            background: rgba(15,23,42,0.045);
        }

        body.dark-mode .btn-quick,
        body.dark-mode .btn-tabla-accion {
            border-color: rgba(255,255,255,0.08);
            background: rgba(255,255,255,0.06);
        }

        .btn-quick.stock-add:hover { background: var(--verde-gvi); }
        .btn-quick.stock-remove:hover { background: var(--alerta-gvi); }

        .empty-bodega {
            padding: 56px 24px !important;
            text-align: center;
        }

        .empty-bodega-box {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            max-width: 430px;
            color: var(--texto-suave);
            font-weight: 800;
            gap: 10px;
        }

        .empty-bodega-box i,
        .empty-bodega-box svg {
            width: 38px;
            height: 38px;
            color: var(--azul-gvi);
        }

        .empty-bodega-box strong {
            color: inherit;
            font-size: 17px;
        }

        @media (max-width: 820px) {
            .bodega-hero {
                align-items: stretch;
                flex-direction: column;
            }

            .stats-bodega {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }

            .bodega-command,
            .bodega-filter-row {
                grid-template-columns: 1fr;
                align-items: stretch;
                flex-direction: column;
            }

            .controles-top {
                align-items: stretch;
                flex-direction: column;
            }

            .btn-add {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <%- include('partials/nav') %>

    <div class="contenedor bodega-shell">
        <div class="bodega-hero">
            <div>
                <div class="bodega-kicker">Inventario</div>
                <h1>Bodega</h1>
                <p>Controla stock, precios, alertas y productos listos para vender.</p>
            </div>
            <div class="bodega-health">
                <span>Estado de inventario</span>
                <b id="statHealth">Sin productos</b>
                <small id="statHealthDetalle">Carga productos para comenzar el control.</small>
            </div>
        </div>

        <!-- ESTADÍSTICAS -->
        <div class="stats-bodega">
            <div class="stat-card">
                <div class="stat-icon" style="background: #3d73ff;"><i data-lucide="layers"></i></div>
                <div class="stat-info">
                    <span>Total Productos</span>
                    <b id="statTotalItems">0</b>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: #ff3b30;"><i data-lucide="alert-triangle"></i></div>
                <div class="stat-info">
                    <span>Stock Crítico</span>
                    <b id="statStockBajo">0</b>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: #6b7280;"><i data-lucide="package-x"></i></div>
                <div class="stat-info">
                    <span>Sin Stock</span>
                    <b id="statSinStock">0</b>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: #34c759;"><i data-lucide="dollar-sign"></i></div>
                <div class="stat-info">
                    <span>Valor Bodega</span>
                    <b id="statValorTotal">$0</b>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: #ff9500;"><i data-lucide="scale"></i></div>
                <div class="stat-info">
                    <span>Por Peso</span>
                    <b id="statPorPeso">0</b>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background: #ff3b30;"><i data-lucide="badge-percent"></i></div>
                <div class="stat-info">
                    <span>Ofertas</span>
                    <b id="statOfertas">0</b>
                </div>
            </div>
        </div>

        <div class="bodega-command">
            <div class="controles-top">
                <div class="busqueda-wrapper">
                    <i data-lucide="search"></i>
                    <input type="text" class="input-busqueda" placeholder="Buscar producto, codigo o alerta..." id="buscarProducto">
                </div>
                <button class="btn-add" onclick="abrirModalNuevo()">
                    <i data-lucide="plus"></i> Nuevo Producto
                </button>
            </div>
        </div>

        <div class="bodega-filter-row">
            <div class="filtros-bodega">
                <button class="filtro-btn activo" data-filtro="todos" onclick="aplicarFiltro('todos')">Todos</button>
                <button class="filtro-btn" data-filtro="critico" onclick="aplicarFiltro('critico')">Stock critico</button>
                <button class="filtro-btn" data-filtro="sin-stock" onclick="aplicarFiltro('sin-stock')">Sin stock</button>
                <button class="filtro-btn" data-filtro="ofertas" onclick="aplicarFiltro('ofertas')">Ofertas</button>
                <button class="filtro-btn" data-filtro="peso" onclick="aplicarFiltro('peso')">Por peso</button>
                <button class="filtro-btn" data-filtro="unidad" onclick="aplicarFiltro('unidad')">Por unidad</button>
            </div>
            <div class="bodega-view-tools">
                <i data-lucide="filter"></i>
                <span id="resultadoBodega">0 productos visibles</span>
            </div>
        </div>

        <div class="tabla-contenedor">
            <table>
                <thead>
                    <tr>
                        <th style="width: 31%;">Producto</th>
                        <th style="width: 16%;">Codigo</th>
                        <th style="width: 18%;">Precio</th>
                        <th style="width: 13%;">Stock</th>
                        <th style="width: 12%;">Estado</th>
                        <th style="width: 10%;">Acciones</th>
                    </tr>
                </thead>
                <tbody id="listaProductos"></tbody>
            </table>
        </div>
    </div>

    <!-- MODAL FORMULARIO -->
    <div id="modalFormulario" class="modal-fondo">
        <div class="panel-modal">
            <h2 id="modalTitulo" style="margin:0 0 30px; font-size: 24px;">Nuevo Producto</h2>
            <form id="formProducto">
                <input type="hidden" id="codigoAnterior">
                
                <div class="form-group">
                    <label class="form-label">Nombre del Producto</label>
                    <div class="input-with-icon">
                        <i data-lucide="tag"></i>
                        <input type="text" id="prodNombre" class="form-input" required placeholder="Ej: Coca Cola 2.5L">
                    </div>
                </div>

                <div class="form-group">
                    <label class="toggle-peso">
                        <span style="font-weight: 700; font-size: 14px;">⚖️ Venta por Kilo (Peso)</span>
                        <input type="checkbox" id="prodPorPeso" onchange="toggleModoPeso()" style="width:20px; height:20px; cursor:pointer;">
                    </label>
                </div>

                <div class="opciones-comerciales">
                    <div class="opcion-comercial" id="boxOferta">
                        <label class="opcion-comercial-head">
                            <span>
                                <b>Oferta</b>
                                <span>Precio promocional opcional.</span>
                            </span>
                            <input type="checkbox" id="prodOfertaActiva" onchange="toggleOpcionesComerciales()">
                        </label>
                        <div class="opcion-comercial-campos">
                            <div>
                                <label class="form-label">Precio Oferta</label>
                                <div class="input-with-icon">
                                    <i data-lucide="badge-percent"></i>
                                    <input type="text" id="prodPrecioOferta" class="form-input" oninput="formatearMoneda(this)" placeholder="Ej: 5.990">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="opcion-comercial" id="boxMayor">
                        <label class="opcion-comercial-head">
                            <span>
                                <b>Precio por Mayor</b>
                                <span>Se aplica cuando alcanza una cantidad minima.</span>
                            </span>
                            <input type="checkbox" id="prodMayorActivo" onchange="toggleOpcionesComerciales()">
                        </label>
                        <div class="opcion-comercial-campos">
                            <div>
                                <label id="labelCantidadMayor" class="form-label">Desde cantidad</label>
                                <div class="input-with-icon">
                                    <i data-lucide="layers"></i>
                                    <input type="number" id="prodCantidadMayor" class="form-input" min="0" step="0.001" placeholder="Ej: 6">
                                </div>
                            </div>
                            <div>
                                <label class="form-label">Precio Mayor</label>
                                <div class="input-with-icon">
                                    <i data-lucide="dollar-sign"></i>
                                    <input type="text" id="prodPrecioMayor" class="form-input" oninput="formatearMoneda(this)" placeholder="Ej: 4.990">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div style="display: flex; gap: 15px; margin-bottom: 20px;">
                    <div style="flex: 1;">
                        <label id="labelPrecio" class="form-label">Precio ($)</label>
                        <div class="input-with-icon">
                            <i data-lucide="dollar-sign"></i>
                            <input type="text" id="prodPrecio" class="form-input" required oninput="formatearMoneda(this)">
                        </div>
                    </div>
                    <div style="flex: 1;">
                        <label id="labelStock" class="form-label">Stock Inicial</label>
                        <div class="input-with-icon">
                            <i data-lucide="box"></i>
                            <input type="number" id="prodStock" class="form-input" required step="0.001">
                        </div>
                    </div>
                </div>

                <div class="form-group" style="margin-bottom: 35px;">
                    <label class="form-label">Código de Barras / SKU</label>
                    <div class="input-with-icon">
                        <i data-lucide="barcode"></i>
                        <input type="text" id="prodCodigo" class="form-input" placeholder="Escanear o dejar vacío para autogenerar">
                        <button type="button" onclick="generarCodigoAleatorio()" 
                                style="position: absolute; right: 8px; background: var(--azul-gvi); color: white; border: none; padding: 6px 12px; border-radius: 10px; font-size: 10px; font-weight: 800; cursor: pointer;">
                            AUTO
                        </button>
                    </div>
                    <small style="font-size: 11px; opacity: 0.5; margin-top: 5px; display: block;">Si el producto no tiene código, el sistema le asignará uno interno.</small>
                </div>

                <div style="display: flex; gap: 15px;">
                    <button type="button" class="btn-cancelar" style="flex:1; border-radius:14px; padding: 14px;" onclick="cerrarModalFormulario()">Cerrar</button>
                    <button type="submit" class="btn-add" style="flex:1.8; justify-content:center; border-radius:14px; padding: 14px;">
                        <i data-lucide="check"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL AUTORIZACIÓN ADMIN -->
    <div id="modalAdminAuth" class="modal-fondo">
        <div class="panel-modal panel-admin-auth">
            <div class="admin-auth-header">
                <div class="admin-auth-icon"><i data-lucide="lock-keyhole"></i></div>
            <h2 style="margin-bottom: 10px;">Autorización Requerida</h2>
            <p style="font-size: 14px; opacity: 0.7; margin-bottom: 20px;">Esta acción requiere privilegios de Administrador. Ingresa el PIN maestro.</p>
            <input type="password" id="inputPinAdmin" class="form-input" style="text-align: center; letter-spacing: 10px; font-size: 28px; padding: 15px;" maxlength="4" placeholder="••••">
            <div style="display: flex; gap: 10px; margin-top: 25px;">
                <button class="btn-cancelar" onclick="cerrarAdminAuth()" style="flex:1;">Cancelar</button>
                <button class="btn-add" onclick="verificarAdminAuth()" style="flex:1;">Verificar</button>
            </div>
        </div>
    </div>

    </div>

    <%- include('partials/scripts') %>
    <script>
        let productosGlobales = [];
        let filtroActual = 'todos';
        let accionPendienteAdmin = null;

        function requerirAdmin(callback) {
            const usr = JSON.parse(localStorage.getItem('gvi_user'));
            if (usr && usr.rol === 'ADMIN') {
                callback(); 
            } else {
                accionPendienteAdmin = callback;
                document.getElementById('inputPinAdmin').value = '';
                document.body.classList.add('modal-abierto');
                document.getElementById('modalAdminAuth').style.display = 'flex';
                document.getElementById('inputPinAdmin').focus();
            }
        }

        function cerrarAdminAuth() {
            document.getElementById('modalAdminAuth').style.display = 'none';
            document.body.classList.remove('modal-abierto');
            accionPendienteAdmin = null;
        }

        async function verificarAdminAuth() {
            const pin = document.getElementById('inputPinAdmin').value;
            try {
                const res = await fetch('/api/verify-admin', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify({ pin })
                });
                const data = await res.json();
                if (data.success) {
                    cerrarAdminAuth();
                    if (accionPendienteAdmin) accionPendienteAdmin();
                } else {
                    alert('PIN de Administrador incorrecto');
                    document.getElementById('inputPinAdmin').value = '';
                    document.getElementById('inputPinAdmin').focus();
                }
            } catch (e) { alert('Error de red'); }
        }

        document.getElementById('inputPinAdmin').addEventListener('keydown', (e) => {
            if (e.key === 'Enter') verificarAdminAuth();
            if (e.key === 'Escape') cerrarAdminAuth();
        });

        async function cargarBodega() {
            try {
                const res = await fetch('/api/productos');
                productosGlobales = await res.json();
                renderizarStats();
                refrescarTabla();
                lucide.createIcons();
            } catch (e) { console.error(e); }
        }

        function renderizarStats() {
            const total = productosGlobales.length;
            const bajo = productosGlobales.filter(p => Number(p.stock) > 0 && Number(p.stock) <= 5).length;
            const sinStock = productosGlobales.filter(p => Number(p.stock) <= 0).length;
            const porPeso = productosGlobales.filter(p => p.vendidoPorPeso).length;
            const ofertas = productosGlobales.filter(p => p.ofertaActiva && Number(p.precioOferta) > 0).length;
            const valor = productosGlobales.reduce((sum, p) => sum + (Number(p.precio || 0) * Number(p.stock || 0)), 0);

            document.getElementById('statTotalItems').innerText = total;
            document.getElementById('statStockBajo').innerText = bajo;
            document.getElementById('statSinStock').innerText = sinStock;
            document.getElementById('statValorTotal').innerText = `$${valor.toLocaleString('es-CL')}`;
            document.getElementById('statPorPeso').innerText = porPeso;
            document.getElementById('statOfertas').innerText = ofertas;

            const health = document.getElementById('statHealth');
            const detail = document.getElementById('statHealthDetalle');
            if (!total) {
                health.innerText = 'Sin productos';
                detail.innerText = 'Carga productos para comenzar el control.';
            } else if (sinStock || bajo) {
                health.innerText = `${sinStock + bajo} alerta${sinStock + bajo === 1 ? '' : 's'}`;
                detail.innerText = `${sinStock} sin stock · ${bajo} con stock bajo.`;
            } else {
                health.innerText = 'Saludable';
                detail.innerText = 'No hay alertas de inventario activas.';
            }
        }

        function estadoProducto(p) {
            const stock = Number(p.stock || 0);
            if (stock <= 0) return { key: 'agotado', stockClass: 'sin-stock', label: 'Sin stock', icon: 'package-x' };
            if (stock <= 2) return { key: 'critico', stockClass: 'crítico', label: 'Critico', icon: 'triangle-alert' };
            if (stock <= 5) return { key: 'alerta', stockClass: 'bajo', label: 'Bajo', icon: 'alert-circle' };
            return { key: 'ok', stockClass: 'normal', label: 'OK', icon: 'check-circle-2' };
        }

        function refrescarTabla() {
            const busqueda = document.getElementById('buscarProducto').value.toLowerCase();
            const filtrados = productosGlobales.filter(p => {
                const estado = estadoProducto(p);
                if (filtroActual === 'peso' && !p.vendidoPorPeso) return false;
                if (filtroActual === 'unidad' && p.vendidoPorPeso) return false;
                if (filtroActual === 'critico' && !(Number(p.stock) > 0 && Number(p.stock) <= 5)) return false;
                if (filtroActual === 'sin-stock' && Number(p.stock) > 0) return false;
                if (filtroActual === 'ofertas' && !(p.ofertaActiva && Number(p.precioOferta) > 0)) return false;
                const texto = `${p.nombre || ''} ${p.codigo || ''} ${estado.label || ''}`.toLowerCase();
                return texto.includes(busqueda);
            });

            const tbody = document.getElementById('listaProductos');
            document.getElementById('resultadoBodega').innerText = `${filtrados.length} producto${filtrados.length === 1 ? '' : 's'} visible${filtrados.length === 1 ? '' : 's'}`;

            if (!filtrados.length) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="6" class="empty-bodega">
                            <div class="empty-bodega-box">
                                <i data-lucide="package-search"></i>
                                <strong>${productosGlobales.length ? 'No hay productos con este filtro' : 'Aun no hay productos en bodega'}</strong>
                                <span>${productosGlobales.length ? 'Prueba otro filtro o busca por codigo/nombre.' : 'Crea el primer producto para comenzar a vender y controlar stock.'}</span>
                                <button class="btn-add" type="button" onclick="abrirModalNuevo()"><i data-lucide="plus"></i> Nuevo Producto</button>
                            </div>
                        </td>
                    </tr>`;
                lucide.createIcons();
                return;
            }

            tbody.innerHTML = filtrados.map(p => {
                const esPeso = p.vendidoPorPeso;
                const estado = estadoProducto(p);
                const stock = Number(p.stock || 0);
                const stockTexto = esPeso ? `${stock.toLocaleString('es-CL')} kg` : `${stock.toLocaleString('es-CL')} un.`;
                const ofertaBadge = p.ofertaActiva && p.precioOferta ? `<span class="badge-precio badge-oferta">OFERTA $${Number(p.precioOferta).toLocaleString('es-CL')}${esPeso ? '/kg' : ''}</span>` : '';
                const mayorBadge = p.mayorActivo && p.precioMayor && p.cantidadMayor ? `<span class="badge-precio badge-mayor">MAYOR ${p.cantidadMayor}${esPeso ? 'kg' : ' un.'} $${Number(p.precioMayor).toLocaleString('es-CL')}${esPeso ? '/kg' : ''}</span>` : '';
                const codigoArg = JSON.stringify(p.codigo);
                const nombreArg = JSON.stringify(p.nombre);
                
                return `
                    <tr>
                        <td>
                            <div class="producto-cell">
                                <div class="producto-mark"><i data-lucide="${esPeso ? 'scale' : 'package'}"></i></div>
                                <div class="producto-name">
                                    <b>${p.nombre}</b>
                                    <small>${esPeso ? 'Venta por peso' : 'Venta por unidad'}</small>
                                </div>
                            </div>
                        </td>
                        <td><span class="codigo-pill">${p.codigo}</span></td>
                        <td class="precio-stack">
                            $${Number(p.precio).toLocaleString('es-CL')}${esPeso ? '/kg' : ''}
                            <div>${ofertaBadge}${mayorBadge}</div>
                        </td>
                        <td>
                            <span class="badge-stock stock-${estado.stockClass}">${stockTexto}</span>
                        </td>
                        <td>
                            <span class="estado-inventario estado-${estado.key}"><i data-lucide="${estado.icon}"></i>${estado.label}</span>
                        </td>
                        <td>
                            <div class="acciones-gap">
                                <button class="btn-quick stock-remove" title="Restar stock" onclick="cambiarStock(${codigoArg}, -1)"><i data-lucide="minus"></i></button>
                                <button class="btn-quick stock-add" title="Sumar stock" onclick="cambiarStock(${codigoArg}, 1)"><i data-lucide="plus"></i></button>
                                <button class="btn-tabla-accion" title="Editar producto" onclick="abrirModalEditar(${codigoArg})">
                                    <i data-lucide="edit-3"></i>
                                </button>
                                <button class="btn-tabla-accion btn-borrar" title="Eliminar producto" onclick="eliminarProducto(${codigoArg}, ${nombreArg})">
                                    <i data-lucide="trash-2"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
            }).join('');
            lucide.createIcons();
        }

        async function cambiarStock(codigo, delta) {
            requerirAdmin(async () => {
                const prod = productosGlobales.find(p => p.codigo === codigo);
                if (!prod) return;
                const nuevoStock = Math.max(0, prod.stock + delta);
                
                try {
                    const res = await fetch(`/api/productos/${codigo}`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ ...prod, stock: nuevoStock })
                    });
                    if (res.ok) cargarBodega();
                } catch (e) { console.error(e); }
            });
        }

        function aplicarFiltro(tipo) {
            filtroActual = tipo;
            document.querySelectorAll('.filtro-btn').forEach(b => b.classList.toggle('activo', b.dataset.filtro === tipo));
            refrescarTabla();
        }

        function toggleModoPeso() {
            const esPeso = document.getElementById('prodPorPeso').checked;
            document.getElementById('labelPrecio').innerText = esPeso ? 'Precio por Kilo ($/kg)' : 'Precio Venta ($)';
            document.getElementById('labelStock').innerText = esPeso ? 'Stock Inicial (kg)' : 'Stock Inicial (un.)';
            document.getElementById('labelCantidadMayor').innerText = esPeso ? 'Desde kilos' : 'Desde cantidad';
            toggleOpcionesComerciales();
        }

        function toggleOpcionesComerciales() {
            const ofertaActiva = document.getElementById('prodOfertaActiva').checked;
            const mayorActivo = document.getElementById('prodMayorActivo').checked;
            document.getElementById('boxOferta').classList.toggle('activa', ofertaActiva);
            document.getElementById('boxMayor').classList.toggle('activa', mayorActivo);
        }

        // --- FUNCIONES MODAL (Adaptadas) ---
        function abrirModalNuevo() {
            requerirAdmin(() => {
                document.getElementById('modalFormulario').style.display = 'flex';
                document.getElementById('modalTitulo').innerText = "📦 Nuevo Producto";
                document.getElementById('formProducto').reset();
                document.getElementById('codigoAnterior').value = "";
                toggleModoPeso();
                toggleOpcionesComerciales();
            });
        }

        function abrirModalEditar(codigo) {
            requerirAdmin(() => {
                const p = productosGlobales.find(prod => prod.codigo === codigo);
                if (!p) return;
                document.getElementById('modalFormulario').style.display = 'flex';
                document.getElementById('modalTitulo').innerText = "✏️ Editar Producto";
                document.getElementById('codigoAnterior').value = p.codigo;
                document.getElementById('prodNombre').value = p.nombre;
                document.getElementById('prodPrecio').value = p.precio.toLocaleString('es-CL');
                document.getElementById('prodStock').value = p.stock;
                document.getElementById('prodPorPeso').checked = p.vendidoPorPeso;
                document.getElementById('prodOfertaActiva').checked = !!p.ofertaActiva;
                document.getElementById('prodPrecioOferta').value = p.precioOferta ? Number(p.precioOferta).toLocaleString('es-CL') : '';
                document.getElementById('prodMayorActivo').checked = !!p.mayorActivo;
                document.getElementById('prodCantidadMayor').value = p.cantidadMayor || '';
                document.getElementById('prodPrecioMayor').value = p.precioMayor ? Number(p.precioMayor).toLocaleString('es-CL') : '';
                document.getElementById('prodCodigo').value = p.codigo;
                toggleModoPeso();
                toggleOpcionesComerciales();
            });
        }

        function cerrarModalFormulario() { document.getElementById('modalFormulario').style.display = 'none'; }

        function formatearMoneda(input) {
            let valor = input.value.replace(/\D/g, "");
            input.value = valor === "" ? "" : Number(valor).toLocaleString('es-CL');
        }

        function generarCodigoAleatorio() {
            const numero = Math.floor(1000 + Math.random() * 9000);
            const prefix = "INT-";
            document.getElementById('prodCodigo').value = prefix + numero;
        }

        document.getElementById('formProducto').addEventListener('submit', async function(e) {
            e.preventDefault();
            const codAntiguo = document.getElementById('codigoAnterior').value;
            let codigoFinal = document.getElementById('prodCodigo').value.trim();
            
            // Si no hay código, generamos uno interno basado en el tiempo para que sea único
            if (!codigoFinal) {
                codigoFinal = "INT-" + Date.now().toString().slice(-6);
            }

            const datos = {
                codigo: codigoFinal,
                nombre: document.getElementById('prodNombre').value,
                precio: Number(document.getElementById('prodPrecio').value.replace(/\./g, "")),
                stock: Number(document.getElementById('prodStock').value),
                vendidoPorPeso: document.getElementById('prodPorPeso').checked,
                ofertaActiva: document.getElementById('prodOfertaActiva').checked,
                precioOferta: Number(document.getElementById('prodPrecioOferta').value.replace(/\./g, "")) || 0,
                mayorActivo: document.getElementById('prodMayorActivo').checked,
                cantidadMayor: Number(document.getElementById('prodCantidadMayor').value) || 0,
                precioMayor: Number(document.getElementById('prodPrecioMayor').value.replace(/\./g, "")) || 0
            };
            const url = codAntiguo === "" ? '/api/productos' : `/api/productos/${codAntiguo}`;
            const method = codAntiguo === "" ? 'POST' : 'PUT';
            
            const res = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(datos)
            });
            if (res.ok) { cerrarModalFormulario(); cargarBodega(); }
            else {
                const error = await res.json().catch(() => ({}));
                alert(error.message || 'No se pudo guardar el producto.');
            }
        });

        async function eliminarProducto(codigo, nombre) {
            requerirAdmin(async () => {
                if(!confirm(`¿Eliminar ${nombre}?`)) return;
                await fetch(`/api/productos/${codigo}`, { method: 'DELETE' });
                cargarBodega();
            });
        }

        document.getElementById('buscarProducto').addEventListener('input', refrescarTabla);
        document.addEventListener('DOMContentLoaded', cargarBodega);
    </script>
</body>
</html>
