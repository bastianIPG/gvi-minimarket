<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('partials/head') %>
    <title>GVI - Gestión de Fiados</title>
    <style>
        .fiados-header { display: flex; justify-content: space-between; align-items: center; margin-top: 40px; margin-bottom: 20px; }
        
        /* Buscador y Resumen Superior */
        .controles-superiores { 
            background: var(--panel-claro); padding: 20px 30px; border-radius: 20px; 
            margin-bottom: 30px; display: flex; gap: 30px; align-items: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.05);
        }
        body.dark-mode .controles-superiores { background: var(--panel-oscuro); border-color: #333; }
        
        .input-busqueda { 
            flex: 1; padding: 15px; border-radius: 12px; border: 1px solid #ddd; 
            outline: none; font-size: 16px; background: transparent; color: inherit;
        }
        .input-busqueda:focus { border-color: var(--azul-gvi); box-shadow: 0 0 0 3px rgba(0,122,255,0.1); }

        .total-pendiente-box { text-align: right; min-width: 200px; }
        .total-pendiente-box div { font-size: 11px; font-weight: 800; opacity: 0.5; text-transform: uppercase; letter-spacing: 1px; }
        .total-pendiente-box b { font-size: 28px; color: #ff3b30; }

        /* Grid de Tarjetas */
        .grid-fiados { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 25px; }
        
        .card-fiado { 
            background: var(--panel-claro); padding: 30px; border-radius: 25px; 
            box-shadow: 0 10px 20px rgba(0,0,0,0.02); border: 1px solid rgba(0,0,0,0.05);
            transition: 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); position: relative;
        }
        body.dark-mode .card-fiado { background: var(--panel-oscuro); border-color: #333; }
        .card-fiado:hover { transform: translateY(-8px); box-shadow: 0 15px 35px rgba(0,0,0,0.1); }
        
        .deuda-monto { font-size: 38px; font-weight: 900; color: #ff3b30; margin: 10px 0; }
        
        .btn-detalle { 
            background: rgba(0,122,255,0.08); color: var(--azul-gvi); border: none; 
            padding: 12px; border-radius: 12px; font-weight: 800; cursor: pointer; width: 100%; margin-bottom: 12px;
            transition: 0.2s;
        }
        .btn-detalle:hover { background: rgba(0,122,255,0.15); }

        .btn-pagar { 
            width: 100%; padding: 15px; border-radius: 12px; border: none; 
            background: #34c759; color: white; font-weight: 800; cursor: pointer; 
            transition: 0.3s; box-shadow: 0 4px 12px rgba(52, 199, 89, 0.2);
        }
        .btn-pagar:hover { background: #2eb350; transform: scale(1.02); }
        
        .badge-p { background: #ff950015; color: #ff9500; padding: 4px 10px; border-radius: 8px; font-size: 11px; font-weight: 800; }

        /* Estilos Impresión */
        @media print {
            body * { display: none !important; }
            #areaImpresion, #areaImpresion * { display: block !important; }
        }
    </style>
</head>
<body>
    <%- include('partials/nav') %>

    <div class="contenedor">
        <div class="fiados-header">
            <h1><span>📓</span> Cuentas Corrientes</h1>
            <div id="contadorCuentas" style="opacity: 0.5; font-weight: bold;">Cargando cuentas...</div>
        </div>

        <div class="controles-superiores">
            <input type="text" id="txtBuscarFiado" class="input-busqueda" placeholder="🔍 Buscar cliente por nombre..." oninput="filtrarFiados()">
            <div class="total-pendiente-box">
                <div>Deuda Total en la Calle</div>
                <b id="sumaTotalDeuda">$0</b>
            </div>
        </div>

        <div id="listaFiados" class="grid-fiados"></div>
    </div>

    <div id="modalDetalle" class="modal-fondo">
        <div class="panel" style="width: 550px; padding: 35px;">
            <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                <div>
                    <h2 id="detNombre" style="margin:0;">Cliente</h2>
                    <p id="detInicio" style="opacity:0.5; font-size:13px; margin-top:5px;"></p>
                </div>
                <span class="badge-p">PENDIENTE</span>
            </div>

            <div style="margin-top: 25px; font-weight: 800; font-size: 11px; opacity: 0.4; text-transform: uppercase; letter-spacing: 1px;">Historial de Retiros</div>
            <div style="max-height: 350px; overflow-y: auto; margin: 15px 0; border: 1px solid rgba(0,0,0,0.05); border-radius: 12px;">
                <table style="width:100%; font-size:13px; border-collapse: collapse;">
                    <thead style="position: sticky; top:0; background: var(--azul-gvi); color:white;">
                        <tr><th style="padding:10px;">Fecha</th><th style="text-align:left;">Producto</th><th>Subtotal</th></tr>
                    </thead>
                    <tbody id="detTablaCuerpo"></tbody>
                </table>
            </div>

            <div style="display:flex; justify-content:space-between; align-items:center; margin-top:20px; padding-top:15px; border-top: 2px solid #eee;">
                <span style="font-weight:bold;">TOTAL ACUMULADO:</span>
                <b id="detTotalMonto" style="font-size:28px; color:#ff3b30;">$0</b>
            </div>

            <button class="btn-cancelar" style="width:100%; margin-top:25px;" onclick="cerrarModal('modalDetalle')">Cerrar Historial</button>
        </div>
    </div>

    <div id="modalPagar" class="modal-fondo">
        <div class="panel" style="width: 480px; padding: 35px; text-align: center;">
            <h2 style="margin-bottom: 5px;">Saldar Cuenta</h2>
            <div id="pagoNombre" style="font-weight: 800; opacity: 0.4; text-transform: uppercase;">CLIENTE</div>
            
            <div style="font-size: 45px; font-weight: 900; color: var(--azul-gvi); margin: 20px 0 30px;" id="pagoTotal">$0</div>

            <div class="metodos-pago-grid" style="grid-template-columns: 1fr 1fr; gap:15px; margin-bottom: 25px;">
                <button class="btn-metodo activo" id="fBtnEfec" onclick="cambiarMetodoPago('Efectivo')">💵 EFECTIVO</button>
                <button class="btn-metodo" id="fBtnTarj" onclick="cambiarMetodoPago('Tarjeta')">💳 TARJETA</button>
            </div>

            <div id="fAreaEfectivo">
                <input type="text" id="fInputPago" class="input-cuadratura" placeholder="¿Con cuánto paga?" 
                       oninput="formatearYVuelto(this)" style="text-align: center; font-size: 24px;">
                <div style="margin-top: 15px; font-size: 22px; font-weight: 800; color: #34c759;">
                    Vuelto: <span id="fVuelto">$0</span>
                </div>
            </div>

            <div style="display: flex; gap: 12px; margin-top: 35px;">
                <button class="btn-cancelar" style="flex: 1;" onclick="cerrarModal('modalPagar')">Cancelar</button>
                <button class="btn-success" style="flex: 2;" onclick="procesarPagoFinal()">✅ Pagar y Generar Boleta</button>
            </div>
        </div>
    </div>

    <div id="areaImpresion" style="display:none; font-family: monospace; width: 80mm; padding: 5mm;"></div>

    <%- include('partials/scripts') %>

    <script>
        let fiadosFull = [];
        let cuentaActiva = null;
        let metodoPagoActivo = 'Efectivo';

        async function cargarFiados() {
            try {
                const res = await fetch('/api/fiados');
                const data = await res.json();
                fiadosFull = data.filter(f => f.estado === "PENDIENTE");
                filtrarFiados();
            } catch (e) { console.error("Error cargando fiados", e); }
        }

        function filtrarFiados() {
            const busqueda = document.getElementById('txtBuscarFiado').value.toLowerCase();
            const filtrados = fiadosFull.filter(f => f.cliente.toLowerCase().includes(busqueda));
            
            const listaDiv = document.getElementById('listaFiados');
            const totalSumaEl = document.getElementById('sumaTotalDeuda');
            const contadorEl = document.getElementById('contadorCuentas');

            let sumaGlobal = 0;
            contadorEl.innerText = `${filtrados.length} clientes con deuda`;

            if(filtrados.length === 0) {
                listaDiv.innerHTML = `<div style="grid-column:1/-1; text-align:center; padding:80px; opacity:0.3;">
                    <span style="font-size:60px;">🔍</span><p>No hay coincidencias.</p></div>`;
                totalSumaEl.innerText = "$0";
                return;
            }

            listaDiv.innerHTML = filtrados.map(f => {
                sumaGlobal += f.total;
                return `
                <div class="card-fiado">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <span class="badge-p">PENDIENTE</span>
                        <small style="opacity:0.4; font-weight:bold;">Desde: ${f.fechaInicio}</small>
                    </div>
                    <h3 style="margin: 15px 0 5px; font-size: 24px;">${f.cliente}</h3>
                    <div class="deuda-monto">$${f.total.toLocaleString('es-CL')}</div>
                    
                    <div style="margin-top:20px;">
                        <button class="btn-detalle" onclick="abrirDetalle(${f.id})">📋 VER DETALLE HISTÓRICO</button>
                        <button class="btn-pagar" onclick="abrirCobro(${f.id})">💰 MARCAR COMO PAGADO</button>
                    </div>
                </div>`;
            }).join('');

            totalSumaEl.innerText = "$" + sumaGlobal.toLocaleString('es-CL');
        }

        // --- LÓGICA DETALLE ---
        function abrirDetalle(id) {
            const f = fiadosFull.find(x => x.id === id);
            document.getElementById('detNombre').innerText = f.cliente;
            document.getElementById('detInicio').innerText = `Cuenta abierta el ${f.fechaInicio}`;
            document.getElementById('detTotalMonto').innerText = "$" + f.total.toLocaleString('es-CL');

            document.getElementById('detTablaCuerpo').innerHTML = f.items.map(i => `
                <tr style="border-bottom: 1px solid #f5f5f5;">
                    <td style="padding:12px; opacity:0.6;">${i.fechaMov || f.fechaInicio}</td>
                    <td><b>${i.cantidad}x</b> ${i.nombre}</td>
                    <td style="text-align:right; padding-right:10px; font-weight:bold;">$${(i.cantidad * i.precio).toLocaleString('es-CL')}</td>
                </tr>
            `).join('');

            document.getElementById('modalDetalle').style.display = 'flex';
        }

        // --- LÓGICA COBRO ---
        function abrirCobro(id) {
            cuentaActiva = fiadosFull.find(x => x.id === id);
            document.getElementById('pagoNombre').innerText = cuentaActiva.cliente;
            document.getElementById('pagoTotal').innerText = "$" + cuentaActiva.total.toLocaleString('es-CL');
            document.getElementById('fInputPago').value = "";
            document.getElementById('fVuelto').innerText = "$0";
            cambiarMetodoPago('Efectivo');
            document.getElementById('modalPagar').style.display = 'flex';
            setTimeout(() => document.getElementById('fInputPago').focus(), 200);
        }

        function cambiarMetodoPago(m) {
            metodoPagoActivo = m;
            document.getElementById('fBtnEfec').classList.toggle('activo', m === 'Efectivo');
            document.getElementById('fBtnTarj').classList.toggle('activo', m === 'Tarjeta');
            document.getElementById('fAreaEfectivo').style.display = (m === 'Efectivo') ? 'block' : 'none';
        }

        function formatearYVuelto(input) {
            let val = input.value.replace(/\D/g, "");
            input.value = val === "" ? "" : "$" + Number(val).toLocaleString('es-CL');
            const pagoNum = Number(val) || 0;
            const vuelto = pagoNum - cuentaActiva.total;
            document.getElementById('fVuelto').innerText = vuelto >= 0 ? "$" + vuelto.toLocaleString('es-CL') : "$0";
        }

        async function procesarPagoFinal() {
            const rawPago = document.getElementById('fInputPago').value.replace(/\D/g, "");
            const pagoRecibido = metodoPagoActivo === 'Efectivo' ? Number(rawPago) : cuentaActiva.total;

            if (metodoPagoActivo === 'Efectivo' && pagoRecibido < cuentaActiva.total) {
                return alert("⚠️ Monto insuficiente para saldar la deuda.");
            }

            const datos = {
                id: cuentaActiva.id,
                metodoPago: metodoPagoActivo,
                pagoCon: pagoRecibido,
                vuelto: pagoRecibido - cuentaActiva.total
            };

            try {
                const res = await fetch('/api/fiados/pagar', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json'},
                    body: JSON.stringify(datos)
                });
                const r = await res.json();
                if(r.success) {
                    imprimirBoletaFiado(r.ventaId, cuentaActiva, datos);
                    alert("✅ Cuenta saldada y registrada en ventas.");
                    cerrarModal('modalPagar');
                    cargarFiados();
                }
            } catch (e) { alert("Error al procesar pago."); }
        }

        function imprimirBoletaFiado(vId, cuenta, pago) {
            const fecha = new Date().toLocaleString();
            const area = document.getElementById('areaImpresion');
            area.innerHTML = `
                <div style="text-align:center;">
                    <h2 style="margin:0;">GVI MINIMARKET</h2>
                    <p style="margin:5px 0;">COMPROBANTE DE PAGO DEUDA</p>
                    <p style="font-size:12px;">Ticket #${vId} | ${fecha}</p>
                    <hr>
                    <p style="text-align:left;"><b>CLIENTE: ${cuenta.cliente}</b></p>
                    <table style="width:100%; font-size:11px; text-align:left;">
                        ${cuenta.items.map(i => `
                            <tr>
                                <td>${i.fechaMov || cuenta.fechaInicio}</td>
                                <td>${i.cantidad}x ${i.nombre.substring(0,15)}</td>
                                <td style="text-align:right;">$${(i.precio*i.cantidad).toLocaleString('es-CL')}</td>
                            </tr>`).join('')}
                    </table>
                    <hr>
                    <div style="text-align:right; font-weight:bold; font-size:16px;">
                        TOTAL PAGADO: $${cuenta.total.toLocaleString('es-CL')}
                    </div>
                    <div style="text-align:right; font-size:12px; margin-top:5px;">
                        Metodo: ${pago.metodoPago}<br>
                        Entregó: $${pago.pagoCon.toLocaleString('es-CL')}<br>
                        Vuelto: $${pago.vuelto.toLocaleString('es-CL')}
                    </div>
                    <p style="margin-top:20px; font-size:12px;">¡Deuda Saldada! Gracias por su preferencia.</p>
                </div>`;
            window.print();
        }

        function cerrarModal(id) { document.getElementById(id).style.display = 'none'; }
        document.addEventListener('DOMContentLoaded', cargarFiados);
    </script>
</body>
</html>